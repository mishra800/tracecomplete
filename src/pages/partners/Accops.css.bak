@import './shared.css';

/* ================================================================
   ACCOPS PREMIUM — VIOLET / PURPLE EDITION
   Accent: #8b5cf6  Secondary: #a78bfa
   Structure mirrors HP v2. All class names prefixed acp2-
   ================================================================ */

.accops-page.acp-v2-page { overflow-x: hidden; }

/* HERO — strip bggg.jpg globe image, use clean dark purple */
.accops-page .acp2-hero,
.accops-page section.acp2-hero,
.acp-v2-page section.acp2-hero,
section.acp2-hero {
  background: linear-gradient(135deg, #07020e 0%, #0e0520 50%, #07020e 100%) !important;
  background-image: none !important;
  padding: 0 !important; overflow: hidden !important;
  position: relative; display: flex; align-items: center;
}
.acp2-hero::before, .acp2-hero::after { display: none !important; }

.acp2-hero-glow-left {
  position: absolute; top: 0; left: 0; width: 50%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(139,92,246,.22) 0%, rgba(109,40,217,.08) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: acp2-glow 7s ease-in-out infinite alternate;
}
.acp2-hero-glow-right {
  position: absolute; bottom: 0; right: 0; width: 55%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(167,139,250,.16) 0%, rgba(139,92,246,.07) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: acp2-glow 9s ease-in-out infinite alternate-reverse;
}
@keyframes acp2-glow { 0%{opacity:.7}100%{opacity:1} }

.acp2-hero-inner {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 52% 48%; gap: 24px; align-items: flex-start;
  padding: 90px 20px 20px; max-width: 1280px; margin: 0 auto; width: 100%;
}
.acp2-headline { font-size: clamp(1.7rem,2.8vw,2.5rem); font-weight: 900; line-height: 1.12; color: #fff; letter-spacing: -.02em; margin-bottom: 6px; }
.acp2-headline-accent { color: #8b5cf6; display: block; }
.acp2-headline-rule { width: 60px; height: 3px; background: linear-gradient(90deg,#8b5cf6,#a78bfa); border-radius: 2px; margin: 14px 0 20px; }
.acp2-desc { font-size: .97rem; color: rgba(255,255,255,.75); line-height: 1.65; margin-bottom: 22px; max-width: 520px; }
.acp2-desc-link { color: #a78bfa; text-decoration: underline; }

.acp2-feature-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.acp2-feat { display: flex; align-items: flex-start; gap: 12px; }
.acp2-feat-icon { min-width: 36px; height: 36px; background: rgba(139,92,246,.18); border: 1px solid rgba(139,92,246,.35); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: .85rem; }
.acp2-feat-body { display: flex; flex-direction: column; }
.acp2-feat-body strong { color: #fff; font-size: .88rem; font-weight: 700; }
.acp2-feat-body span { color: rgba(255,255,255,.6); font-size: .78rem; }

.acp2-stats-row { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
.acp2-stat-card { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(139,92,246,.2); border-radius: 10px; padding: 10px 16px; }
.acp2-stat-card i { color: #a78bfa; font-size: 1.1rem; }
.acp2-stat-num { display: block; font-size: 1.2rem; font-weight: 800; color: #fff; }
.acp2-stat-lbl { display: block; font-size: .62rem; color: rgba(255,255,255,.5); letter-spacing: .06em; text-transform: uppercase; }
.acp2-stat-brand { border-color: rgba(139,92,246,.35); }
.acp2-brand-logo { width: 48px; height: 32px; object-fit: contain; border-radius: 4px; background: #fff; padding: 2px; }

.acp2-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
.acp2-btn-primary { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,#8b5cf6,#a78bfa); color: #fff; font-weight: 700; font-size: .88rem; padding: 12px 24px; border-radius: 8px; text-decoration: none; transition: opacity .2s; }
.acp2-btn-primary:hover { opacity: .88; color: #fff; }
.acp2-btn-ghost { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(139,92,246,.5); color: #a78bfa; font-weight: 600; font-size: .88rem; padding: 12px 22px; border-radius: 8px; text-decoration: none; transition: background .2s; }
.acp2-btn-ghost:hover { background: rgba(139,92,246,.12); color: #a78bfa; }

.acp2-right { position: relative; display: flex; flex-direction: column; gap: 16px; padding-top: 20px; }
.acp2-product-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 420px; height: 420px; background: radial-gradient(circle,rgba(139,92,246,.25) 0%,transparent 70%); pointer-events: none; z-index: 0; }
.acp2-showcase { position: relative; z-index: 2; display: flex; justify-content: center; align-items: flex-end; }
.acp2-hero-product-img { max-width: 340px; width: 100%; object-fit: contain; filter: drop-shadow(0 12px 40px rgba(139,92,246,.45)); border-radius: 12px; }
.acp2-industry-strip { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; background: rgba(255,255,255,.04); border: 1px solid rgba(139,92,246,.18); border-radius: 10px; padding: 12px 16px; z-index: 2; position: relative; }
.acp2-ind-item { display: flex; align-items: center; gap: 5px; font-size: .74rem; color: rgba(255,255,255,.7); white-space: nowrap; }
.acp2-ind-item i { color: #a78bfa; }
.acp2-ind-sep { width: 1px; height: 14px; background: rgba(255,255,255,.15); }

/* WHY CHOOSE */
.acp2-why-section { background: #0e0520; padding: 70px 0 60px; }
.acp2-why-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.acp2-why-header { text-align: center; margin-bottom: 40px; }
.acp2-why-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(139,92,246,.12); border: 1px solid rgba(139,92,246,.3); color: #a78bfa; font-size: .7rem; font-weight: 700; letter-spacing: .1em; padding: 6px 18px; border-radius: 50px; margin-bottom: 16px; text-transform: uppercase; }
.acp2-why-title { font-size: clamp(1.6rem,2.5vw,2.2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.acp2-why-accent { color: #8b5cf6; }
.acp2-why-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 16px; }
.acp2-why-title-rule { width: 48px; height: 3px; background: linear-gradient(90deg,#8b5cf6,#a78bfa); margin: 0 auto; border-radius: 2px; }

.acp2-why-card-outer { display: grid; grid-template-columns: 1fr 1fr; background: rgba(255,255,255,.03); border: 1px solid rgba(139,92,246,.15); border-radius: 20px; overflow: hidden; margin-bottom: 32px; }
.acp2-why-panel { padding: 36px 32px; position: relative; }
.acp2-why-panel-left { border-right: 1px solid rgba(139,92,246,.15); }
.acp2-why-icon-circle { width: 52px; height: 52px; background: rgba(139,92,246,.18); border: 1px solid rgba(139,92,246,.4); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: 1.2rem; margin-bottom: 12px; }
.acp2-why-icon-alt { background: rgba(167,139,250,.12); border-color: rgba(167,139,250,.4); color: #c4b5fd; }
.acp2-why-card-sup { font-size: .7rem; font-weight: 700; color: rgba(255,255,255,.4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 4px; }
.acp2-why-card-title { font-size: 1.25rem; font-weight: 800; margin-bottom: 10px; color: #a78bfa; }
.acp2-why-card-title-alt { color: #c4b5fd; }
.acp2-why-card-desc { color: rgba(255,255,255,.65); font-size: .88rem; line-height: 1.6; margin-bottom: 16px; }
.acp2-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.acp2-why-list li { display: flex; align-items: flex-start; gap: 10px; color: rgba(255,255,255,.75); font-size: .85rem; }
.acp2-why-list-icon { min-width: 28px; height: 28px; background: rgba(139,92,246,.12); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: .8rem; }
.acp2-why-list-check-icon { background: rgba(139,92,246,.12); color: #c4b5fd; }
.acp2-why-list li small { display: block; font-size: .75rem; color: rgba(255,255,255,.4); }

.acp2-why-stats-bar { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0; background: rgba(139,92,246,.08); border: 1px solid rgba(139,92,246,.2); border-radius: 14px; padding: 20px 28px; }
.acp2-why-stat { display: flex; align-items: center; gap: 12px; padding: 8px 28px; }
.acp2-why-stat-sep { width: 1px; height: 40px; background: rgba(255,255,255,.12); }
.acp2-why-stat-icon { width: 38px; height: 38px; background: rgba(139,92,246,.18); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: .95rem; }
.acp2-why-stat-text strong { display: block; color: #fff; font-size: .88rem; font-weight: 700; }
.acp2-why-stat-text span { color: rgba(255,255,255,.5); font-size: .75rem; }

/* PORTFOLIO */
.acp2-port-section { background: #07020e; padding: 70px 0; }
.acp2-port-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.acp2-port-header { text-align: center; margin-bottom: 40px; }
.acp2-port-header-icon { width: 56px; height: 56px; background: rgba(139,92,246,.15); border: 1px solid rgba(139,92,246,.35); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: 1.3rem; margin: 0 auto 12px; }
.acp2-port-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; margin-bottom: 8px; }
.acp2-port-accent { color: #8b5cf6; }
.acp2-port-title-decor { display: flex; align-items: center; justify-content: center; gap: 8px; margin: 8px 0; }
.acp2-port-decor-line { flex: 0 0 40px; height: 2px; background: linear-gradient(90deg,transparent,rgba(139,92,246,.5)); }
.acp2-port-decor-dot { width: 8px; height: 8px; border-radius: 50%; background: #8b5cf6; }
.acp2-port-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; }
.acp2-port-top-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 20px; }
.acp2-port-card { background: rgba(255,255,255,.03); border: 1px solid rgba(139,92,246,.15); border-radius: 16px; overflow: hidden; transition: border-color .3s,transform .3s; }
.acp2-port-card:hover { border-color: rgba(139,92,246,.5); transform: translateY(-4px); }
.acp2-port-card-img { height: 140px; position: relative; }
.acp2-port-img-a { background: linear-gradient(135deg,#0e0520,#1a0840); }
.acp2-port-img-b { background: linear-gradient(135deg,#080315,#12062c); }
.acp2-port-img-c { background: linear-gradient(135deg,#0a0418,#160735); }
.acp2-port-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(7,2,14,.9)); }
.acp2-port-card-body { padding: 18px 20px; }
.acp2-port-card-icon { width: 40px; height: 40px; background: rgba(139,92,246,.18); border: 1px solid rgba(139,92,246,.35); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: .9rem; margin-bottom: 10px; }
.acp2-port-card-title { font-size: 1rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.acp2-port-card-desc { color: rgba(255,255,255,.6); font-size: .82rem; line-height: 1.55; margin-bottom: 10px; }
.acp2-port-list { list-style: none; padding: 0; margin: 0 0 12px; display: flex; flex-direction: column; gap: 5px; }
.acp2-port-list li { color: rgba(255,255,255,.7); font-size: .8rem; display: flex; align-items: center; gap: 7px; }
.acp2-port-list li i { color: #8b5cf6; font-size: .75rem; }
.acp2-port-link { color: #a78bfa; font-size: .82rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
.acp2-port-link:hover { gap: 10px; color: #a78bfa; }
.acp2-port-bottom-row { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; }
.acp2-port-dc-card { background: rgba(255,255,255,.03); border: 1px solid rgba(139,92,246,.15); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.acp2-port-dc-img { height: 120px; background: linear-gradient(135deg,#060212,#100528); position: relative; }
.acp2-port-dc-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(7,2,14,.9)); }
.acp2-port-dc-body { padding: 18px 20px; flex: 1; }
.acp2-port-why-panel { background: rgba(139,92,246,.07); border: 1px solid rgba(139,92,246,.2); border-radius: 16px; padding: 24px 22px; }
.acp2-port-why-title { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 18px; }
.acp2-port-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }
.acp2-port-why-item { display: flex; flex-direction: column; gap: 4px; }
.acp2-port-why-icon { width: 32px; height: 32px; background: rgba(139,92,246,.18); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: .85rem; margin-bottom: 6px; }
.acp2-port-why-item strong { color: #fff; font-size: .85rem; font-weight: 700; }
.acp2-port-why-item span { color: rgba(255,255,255,.5); font-size: .77rem; line-height: 1.4; }
.acp2-port-cta-bar { display: flex; align-items: center; gap: 14px; background: rgba(139,92,246,.1); border: 1px solid rgba(139,92,246,.25); border-radius: 10px; padding: 14px 16px; }
.acp2-port-cta-icon { width: 36px; height: 36px; background: rgba(139,92,246,.25); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: .95rem; flex-shrink: 0; }
.acp2-port-cta-text { flex: 1; }
.acp2-port-cta-text strong { display: block; color: #fff; font-size: .82rem; font-weight: 700; }
.acp2-port-cta-text span { color: rgba(255,255,255,.5); font-size: .76rem; }
.acp2-port-cta-btn { display: inline-flex; align-items: center; gap: 5px; background: linear-gradient(135deg,#8b5cf6,#a78bfa); color: #fff; font-size: .78rem; font-weight: 700; padding: 9px 16px; border-radius: 7px; text-decoration: none; white-space: nowrap; }

/* INDUSTRIES */
.acp2-ind-section { background: #0e0520; padding: 70px 0; position: relative; overflow: hidden; }
.acp2-ind-bg-glow { position: absolute; width: 400px; height: 400px; border-radius: 50%; pointer-events: none; z-index: 0; }
.acp2-ind-bg-glow-left { top: -100px; left: -100px; background: radial-gradient(circle,rgba(139,92,246,.1) 0%,transparent 70%); }
.acp2-ind-bg-glow-right { bottom: -100px; right: -100px; background: radial-gradient(circle,rgba(167,139,250,.08) 0%,transparent 70%); }
.acp2-ind-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.acp2-ind-header { text-align: center; margin-bottom: 40px; }
.acp2-ind-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(139,92,246,.1); border: 1px solid rgba(139,92,246,.25); color: #a78bfa; font-size: .68rem; font-weight: 700; letter-spacing: .1em; padding: 6px 16px; border-radius: 50px; margin-bottom: 14px; text-transform: uppercase; }
.acp2-ind-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: #8b5cf6; }
.acp2-ind-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.acp2-ind-accent { color: #8b5cf6; }
.acp2-ind-subtitle { color: rgba(255,255,255,.6); font-size: .92rem; }
.acp2-ind-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
.acp2-ind-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 22px; position: relative; overflow: hidden; transition: border-color .3s,transform .3s; }
.acp2-ind-card:hover { transform: translateY(-4px); }
.acp2-ind-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.acp2-ind-icon-wrap { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: .95rem; }

.acp2-ind-card-violet  { border-color: rgba(139,92,246,.25); } .acp2-ind-card-violet:hover  { border-color: rgba(139,92,246,.6); }
.acp2-ind-icon-violet  { background: rgba(139,92,246,.18); color: #a78bfa; }
.acp2-ind-rule-violet  { height: 2px; background: linear-gradient(90deg,#8b5cf6,transparent); margin-bottom: 10px; border-radius: 1px; }
.acp2-ind-arrow-violet { color: #a78bfa; }

.acp2-ind-card-purple  { border-color: rgba(168,85,247,.25); } .acp2-ind-card-purple:hover  { border-color: rgba(168,85,247,.6); }
.acp2-ind-icon-purple  { background: rgba(168,85,247,.18); color: #d8b4fe; }
.acp2-ind-rule-purple  { height: 2px; background: linear-gradient(90deg,#a855f7,transparent); margin-bottom: 10px; border-radius: 1px; }
.acp2-ind-arrow-purple { color: #d8b4fe; }

.acp2-ind-card-indigo  { border-color: rgba(99,102,241,.25); } .acp2-ind-card-indigo:hover  { border-color: rgba(99,102,241,.6); }
.acp2-ind-icon-indigo  { background: rgba(99,102,241,.18); color: #a5b4fc; }
.acp2-ind-rule-indigo  { height: 2px; background: linear-gradient(90deg,#6366f1,transparent); margin-bottom: 10px; border-radius: 1px; }
.acp2-ind-arrow-indigo { color: #a5b4fc; }

.acp2-ind-card-fuchsia { border-color: rgba(217,70,239,.25); } .acp2-ind-card-fuchsia:hover { border-color: rgba(217,70,239,.6); }
.acp2-ind-icon-fuchsia { background: rgba(217,70,239,.18); color: #f0abfc; }
.acp2-ind-rule-fuchsia { height: 2px; background: linear-gradient(90deg,#d946ef,transparent); margin-bottom: 10px; border-radius: 1px; }
.acp2-ind-arrow-fuchsia{ color: #f0abfc; }

.acp2-ind-card-pink    { border-color: rgba(236,72,153,.25); } .acp2-ind-card-pink:hover    { border-color: rgba(236,72,153,.6); }
.acp2-ind-icon-pink    { background: rgba(236,72,153,.18); color: #f9a8d4; }
.acp2-ind-rule-pink    { height: 2px; background: linear-gradient(90deg,#ec4899,transparent); margin-bottom: 10px; border-radius: 1px; }
.acp2-ind-arrow-pink   { color: #f9a8d4; }

.acp2-ind-card-lavender{ border-color: rgba(192,132,252,.25); } .acp2-ind-card-lavender:hover{ border-color: rgba(192,132,252,.6); }
.acp2-ind-icon-lavender{ background: rgba(192,132,252,.18); color: #e9d5ff; }
.acp2-ind-rule-lavender{ height: 2px; background: linear-gradient(90deg,#c084fc,transparent); margin-bottom: 10px; border-radius: 1px; }
.acp2-ind-arrow-lavender{ color: #e9d5ff; }

.acp2-ind-num { font-size: 1.3rem; font-weight: 900; color: rgba(255,255,255,.08); }
.acp2-ind-card-title { font-size: .95rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.acp2-ind-card-desc { color: rgba(255,255,255,.6); font-size: .8rem; line-height: 1.5; margin-bottom: 12px; }
.acp2-ind-arrow { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); text-decoration: none; transition: background .2s; }
.acp2-ind-arrow:hover { background: rgba(255,255,255,.12); }
.acp2-ind-card-bg-pattern { position: absolute; right: -20px; bottom: -20px; width: 80px; height: 80px; border-radius: 50%; background: rgba(139,92,246,.04); pointer-events: none; }

/* OFFER */
.acp2-offer-section { background: #07020e; padding: 60px 0; }
.acp2-offer-container { max-width: 900px; margin: 0 auto; padding: 0 24px; }
.acp2-offer-banner { position: relative; background: rgba(139,92,246,.08); border: 1px solid rgba(139,92,246,.3); border-radius: 20px; padding: 48px 44px; overflow: hidden; }
.acp2-offer-glow { position: absolute; top: -60px; right: -60px; width: 280px; height: 280px; background: radial-gradient(circle,rgba(139,92,246,.2) 0%,transparent 70%); pointer-events: none; }
.acp2-offer-content { position: relative; z-index: 1; text-align: center; }
.acp2-offer-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(139,92,246,.2); border: 1px solid rgba(139,92,246,.4); color: #a78bfa; font-size: .72rem; font-weight: 700; letter-spacing: .12em; padding: 5px 14px; border-radius: 50px; margin-bottom: 12px; text-transform: uppercase; }
.acp2-offer-title { font-size: 1.8rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.acp2-offer-title i { color: #8b5cf6; margin-right: 6px; }
.acp2-offer-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 14px; }
.acp2-offer-desc { color: rgba(255,255,255,.7); font-size: .88rem; line-height: 1.6; max-width: 620px; margin: 0 auto 24px; }
.acp2-offer-highlights { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 28px; }
.acp2-offer-point { display: flex; align-items: center; gap: 7px; background: rgba(139,92,246,.1); border: 1px solid rgba(139,92,246,.2); border-radius: 8px; padding: 7px 14px; color: rgba(255,255,255,.8); font-size: .82rem; }
.acp2-offer-check { color: #8b5cf6; font-weight: 700; }
.acp2-contact-btn { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,#8b5cf6,#a78bfa); color: #fff; font-weight: 700; font-size: .92rem; padding: 14px 32px; border-radius: 10px; text-decoration: none; transition: opacity .2s; margin-top: 4px; }
.acp2-contact-btn:hover { opacity: .88; color: #fff; }

/* RESPONSIVE */
@media (max-width: 1024px) {
  .acp2-hero-inner { grid-template-columns: 1fr; padding: 80px 20px 30px; }
  .acp2-right { display: none; }
  .acp2-why-card-outer { grid-template-columns: 1fr; }
  .acp2-why-panel-left { border-right: none; border-bottom: 1px solid rgba(139,92,246,.15); }
  .acp2-port-top-row { grid-template-columns: 1fr 1fr; }
  .acp2-port-bottom-row { grid-template-columns: 1fr; }
  .acp2-ind-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .acp2-port-top-row { grid-template-columns: 1fr; }
  .acp2-ind-grid { grid-template-columns: 1fr; }
  .acp2-why-stats-bar { flex-direction: column; gap: 8px; }
  .acp2-why-stat-sep { display: none; }
  .acp2-offer-banner { padding: 32px 20px; }
}

/* ── Career CTA — Accops page with bggg.jpg background ── */
.accops-page.acp-v2-page .career-cta-section {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(rgba(4, 1, 8, 0.82), rgba(7, 3, 18, 0.88)),
    url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}
.accops-page.acp-v2-page .career-cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(139,92,246,0.14) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 50%, rgba(109,40,217,0.09) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}
.accops-page.acp-v2-page .career-cta-section .career-cta-container {
  position: relative;
  z-index: 1;
}
.accops-page.acp-v2-page .career-cta-section .career-cta-title {
  background: linear-gradient(135deg, #ffffff 0%, #a78bfa 60%, #ffffff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
