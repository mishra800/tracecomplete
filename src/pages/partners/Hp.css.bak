@import './shared.css';

/* ================================================================
   HP PREMIUM — SKY BLUE EDITION
   Accent: #00bfff (sky blue)  Secondary: #38d9ff
   Structure mirrors Lenovo v2. All class names prefixed hp2-
   ================================================================ */

/* ── Page wrapper ── */
.sophos-page:has(.hp-v2-page),
.sophos-page:has(.hp-page.hp-v2-page) {
  background: #040d1e !important;
  background-image: none !important;
}

.hp-page.hp-v2-page {
  overflow-x: hidden;
}

/* ================================================================
   HERO SECTION
   ================================================================ */

.sophos-page .hp2-hero,
.hp-page .hp2-hero,
.hp-v2-page .hp2-hero,
section.hp2-hero {
  background: linear-gradient(135deg, #040d1e 0%, #060f2a 50%, #040d1e 100%) !important;
  padding: 0 !important;
  overflow: hidden !important;
  min-height: unset !important;
}

.sophos-page .hp2-hero::before,
.hp-page .hp2-hero::before,
.hp-v2-page .hp2-hero::before,
section.hp2-hero::before,
.sophos-page .hp2-hero::after,
.hp-page .hp2-hero::after,
.hp-v2-page .hp2-hero::after,
section.hp2-hero::after {
  display: none !important;
}

.hp2-hero {
  position: relative;
  min-height: unset;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hp2-hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

/* Sky-blue glow overlays */
.hp2-hero-glow-left {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: radial-gradient(ellipse at center,
    rgba(0, 191, 255, 0.22) 0%,
    rgba(0, 140, 220, 0.10) 50%,
    transparent 80%);
  z-index: 0;
  pointer-events: none;
  animation: hp2-glow-pulse 7s ease-in-out infinite alternate;
}

.hp2-hero-glow-right {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 55%;
  height: 100%;
  background: radial-gradient(ellipse at center,
    rgba(0, 191, 255, 0.16) 0%,
    rgba(0, 160, 230, 0.08) 50%,
    transparent 80%);
  z-index: 0;
  pointer-events: none;
  animation: hp2-glow-pulse 9s ease-in-out infinite alternate-reverse;
}

@keyframes hp2-glow-pulse {
  0%   { opacity: 0.7; }
  100% { opacity: 1; }
}

.hp2-hero-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 52% 48%;
  gap: 24px;
  align-items: flex-start;
  padding: 90px 20px 20px;
  max-width: 1280px;
  margin: 0 auto;
  width: 100%;
}

/* ── LEFT COLUMN ── */
.hp2-headline {
  font-size: clamp(1.7rem, 2.8vw, 2.5rem);
  font-weight: 900;
  line-height: 1.12;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin-bottom: 6px;
}
.hp2-headline-accent {
  color: #00bfff;
  display: block;
}

.hp2-headline-rule {
  width: 40px;
  height: 3px;
  background: #00bfff;
  border-radius: 2px;
  margin: 10px 0 12px;
}

.hp2-desc {
  font-size: 0.88rem;
  color: #b0c8e8;
  line-height: 1.6;
  max-width: 480px;
  margin-bottom: 14px;
}
.hp2-desc-link {
  color: #38d9ff;
  text-decoration: none;
  font-weight: 600;
}
.hp2-desc-link:hover { text-decoration: underline; }

/* Feature row */
.hp2-feature-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 14px;
}

.hp2-feat {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 10px;
  border-radius: 10px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(0,191,255,0.15);
  transition: border-color 0.3s, background 0.3s;
}
.hp2-feat:hover {
  border-color: rgba(0,191,255,0.35);
  background: rgba(0,140,220,0.08);
}
.hp2-feat-icon {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  background: rgba(0,160,220,0.25);
  border: 1px solid rgba(0,191,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
}
.hp2-feat-icon i {
  font-size: 0.85rem;
  color: #38d9ff;
}
.hp2-feat-body strong {
  display: block;
  font-size: 0.82rem;
  font-weight: 700;
  color: #dce8ff;
  margin-bottom: 2px;
}
.hp2-feat-body span {
  font-size: 0.72rem;
  color: #6888aa;
  line-height: 1.4;
}

/* Stats row */
.hp2-stats-row {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}

.hp2-stat-card {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 10px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(0,191,255,0.2);
  backdrop-filter: blur(8px);
  min-width: 100px;
  flex: 1;
}
.hp2-stat-card > i {
  font-size: 1.2rem;
  color: #00bfff;
  flex-shrink: 0;
}
.hp2-stat-card > div {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.hp2-stat-num {
  font-size: 1.4rem;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -0.02em;
  line-height: 1;
}
.hp2-stat-lbl {
  font-size: 0.6rem;
  font-weight: 700;
  color: #5a7aa0;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  line-height: 1.4;
}

.hp2-stat-brand {
  border-color: rgba(0,191,255,0.3);
  background: rgba(0,191,255,0.07);
  flex-direction: column;
  align-items: flex-start;
  gap: 4px;
}
.hp2-brand-logo {
  width: 90px;
  height: auto;
  object-fit: contain;
  border-radius: 6px;
  display: block;
}

/* CTA buttons */
.hp2-cta-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.hp2-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 22px;
  border-radius: 50px;
  background: linear-gradient(135deg, #007aaa 0%, #00bfff 60%, #38d9ff 100%);
  background-size: 200% auto;
  color: #fff;
  font-size: 0.85rem;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 6px 24px rgba(0,191,255,0.4);
  transition: all 0.4s ease;
}
.hp2-btn-primary:hover {
  background-position: right center;
  transform: translateY(-3px);
  box-shadow: 0 12px 36px rgba(0,191,255,0.6);
  color: #fff;
}

.hp2-btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 11px 18px;
  border-radius: 50px;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.18);
  color: #c0d4f0;
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
}
.hp2-btn-ghost:hover {
  border-color: rgba(0,191,255,0.5);
  background: rgba(0,191,255,0.08);
  color: #fff;
  transform: translateY(-2px);
}

/* Industry strip */
.hp2-industry-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  padding: 12px 12px 6px;
  border-top: 1px solid rgba(0,191,255,0.2);
  row-gap: 8px;
  column-gap: 0;
  width: 100%;
  max-width: 520px;
  margin-top: 12px;
  position: relative;
  z-index: 3;
}
.hp2-ind-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.92rem;
  font-weight: 600;
  color: #c8e8ff;
  padding: 4px 12px;
  transition: color 0.2s;
  cursor: default;
  white-space: nowrap;
}
.hp2-ind-item i {
  font-size: 1.05rem;
  color: #00bfff;
}
.hp2-ind-item:hover { color: #ffffff; }
.hp2-ind-item:hover i { color: #7eeeff; }
.hp2-ind-sep {
  width: 1px;
  height: 16px;
  background: rgba(0,191,255,0.25);
  flex-shrink: 0;
}

/* ── RIGHT COLUMN — Product Showcase ── */
.hp2-right {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: unset;
  margin-top: -10px;
}

.hp2-product-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 85% 70% at 55% 50%,
      rgba(0,191,255,0.28) 0%,
      rgba(0,140,220,0.12) 50%,
      transparent 80%),
    radial-gradient(ellipse 60% 40% at 50% 90%,
      rgba(0,191,255,0.18) 0%,
      transparent 60%);
  pointer-events: none;
  z-index: 0;
  animation: hp2-glow-breathe 6s ease-in-out infinite;
}

@keyframes hp2-glow-breathe {
  0%, 100% { opacity: 0.8; }
  50%       { opacity: 1; }
}

.hp2-showcase {
  position: relative;
  width: 440px;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.hp2-showcase::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    105deg,
    transparent 30%,
    rgba(0, 191, 255, 0.06) 50%,
    transparent 70%
  );
  z-index: 10;
  pointer-events: none;
  border-radius: 50%;
  animation: hp2-scan 8s ease-in-out infinite;
}

@keyframes hp2-scan {
  0%        { left: -100%; opacity: 0; }
  10%       { opacity: 1; }
  50%, 100% { left: 150%; opacity: 0; }
}

.hp2-hero-product-img {
  width: 100%;
  max-width: 380px;
  height: auto;
  object-fit: contain;
  display: block;
  position: relative;
  z-index: 2;
  border-radius: 12px;
  filter:
    drop-shadow(0 30px 60px rgba(0,0,0,0.7))
    drop-shadow(0 0 60px rgba(0,191,255,0.3))
    drop-shadow(0 -10px 40px rgba(0,160,220,0.18));
  animation: hp2-float 6s ease-in-out infinite;
  transform-origin: center bottom;
}

@keyframes hp2-float {
  0%, 100% { transform: translateY(0) scale(1); }
  50%       { transform: translateY(-14px) scale(1.012); }
}

/* Glowing platform */
.hp2-platform {
  position: absolute;
  bottom: -10px;
  left: 50%;
  transform: translateX(-50%);
  width: 360px;
  height: 90px;
  pointer-events: none;
  z-index: 1;
}
.hp2-plat-ring {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 0;
  border-radius: 50%;
  border: 1px solid rgba(0,191,255,0.3);
  animation: hp2-ring-pulse 4s ease-in-out infinite;
}
.hp2-plat-ring-1 {
  width: 360px; height: 44px;
  background: radial-gradient(ellipse at 50% 80%, rgba(0,191,255,0.18) 0%, transparent 70%);
}
.hp2-plat-ring-2 {
  width: 240px; height: 28px;
  background: radial-gradient(ellipse at 50% 80%, rgba(0,191,255,0.28) 0%, transparent 70%);
  animation-delay: 0.5s;
}
.hp2-plat-ring-3 {
  width: 130px; height: 16px;
  background: radial-gradient(ellipse at 50% 80%, rgba(0,191,255,0.55) 0%, transparent 70%);
  animation-delay: 1s;
}
.hp2-plat-surface {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 2px;
  height: 60px;
  background: linear-gradient(to top, rgba(0,191,255,0.7), transparent);
  filter: blur(3px);
}

.hp2-platform::after {
  content: '';
  position: absolute;
  bottom: 8px;
  left: 50%;
  transform: translateX(-50%);
  width: 300px;
  height: 3px;
  background: radial-gradient(ellipse at 50% 50%, rgba(0,191,255,0.8) 0%, transparent 70%);
  filter: blur(4px);
  border-radius: 50%;
  animation: hp2-beam-pulse 3s ease-in-out infinite;
}

@keyframes hp2-ring-pulse {
  0%, 100% { opacity: 0.5; }
  50%       { opacity: 1; }
}
@keyframes hp2-beam-pulse {
  0%, 100% { opacity: 0.4; width: 250px; }
  50%       { opacity: 1;   width: 360px; }
}

/* RESPONSIVE — HERO */
@media (max-width: 1100px) {
  .hp2-hero-inner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 50px 20px 60px;
    align-items: center;
  }
  .hp2-right { justify-content: center; margin-top: 0; }
  .hp2-headline { font-size: clamp(2rem, 5vw, 2.8rem); }
  .hp2-showcase { width: 440px; }
  .hp2-hero-product-img { max-width: 380px; }
}

@media (max-width: 768px) {
  .hp2-hero-inner { padding: 90px 16px 32px; }
  .hp2-feature-row { grid-template-columns: 1fr; gap: 10px; }
  .hp2-showcase { width: 340px; }
  .hp2-hero-product-img { max-width: 300px; }
  .hp2-plat-ring-1 { width: 340px; }
  .hp2-plat-ring-2 { width: 220px; }
  .hp2-stats-row { gap: 8px; }
  .hp2-stat-card { min-width: 90px; padding: 10px 12px; }
  .hp2-stat-num { font-size: 1.15rem; }
  .hp2-cta-row { flex-direction: column; align-items: flex-start; gap: 12px; }
  .hp2-btn-primary, .hp2-btn-ghost { width: 100%; justify-content: center; }
  .hp2-industry-strip { flex-wrap: wrap; }
}

@media (max-width: 480px) {
  .hp2-hero-inner { padding: 85px 14px 28px; }
  .hp2-headline { font-size: 1.8rem; }
  .hp2-showcase { width: 280px; }
  .hp2-hero-product-img { max-width: 240px; }
  .hp2-plat-ring-1 { width: 280px; }
  .hp2-plat-ring-2 { width: 180px; }
  .hp2-industry-strip { max-width: 280px; flex-wrap: wrap; }
}


/* ================================================================
   WHY CHOOSE SECTION
   ================================================================ */

.hp2-why-section {
  background: #040d1e;
  padding: 90px 0 0;
  position: relative;
  overflow: hidden;
}

.hp2-why-section::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 900px;
  height: 500px;
  background: radial-gradient(ellipse at 50% 0%,
    rgba(0, 191, 255, 0.1) 0%,
    transparent 70%);
  pointer-events: none;
}

.hp2-why-container {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 24px 80px;
}

.hp2-why-header {
  text-align: center;
  margin-bottom: 48px;
}

.hp2-why-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 9px 22px;
  border-radius: 50px;
  border: 1px solid rgba(0, 191, 255, 0.35);
  background: rgba(0, 100, 160, 0.18);
  backdrop-filter: blur(10px);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #70d8ff;
  margin-bottom: 28px;
}
.hp2-why-badge i {
  color: #00bfff;
  font-size: 0.85rem;
}

.hp2-why-title {
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 900;
  line-height: 1.15;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}

.hp2-why-accent { color: #00bfff; }

.hp2-why-subtitle {
  font-size: 1rem;
  color: #8aaac8;
  margin-bottom: 20px;
}

.hp2-why-title-rule {
  width: 60px;
  height: 3px;
  background: linear-gradient(90deg, #00bfff, #38d9ff);
  border-radius: 2px;
  margin: 0 auto;
}

.hp2-why-card-outer {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(0,191,255,0.15);
  border-radius: 20px;
  overflow: hidden;
  min-height: 440px;
  position: relative;
  backdrop-filter: blur(6px);
  box-shadow:
    0 30px 80px rgba(0,0,0,0.5),
    inset 0 1px 0 rgba(255,255,255,0.05);
}

.hp2-why-panel {
  position: relative;
  display: flex;
  overflow: hidden;
}

.hp2-why-panel-left { flex-direction: row; align-items: stretch; }
.hp2-why-panel-right { flex-direction: row; align-items: stretch; }

.hp2-why-img-wrap { position: relative; flex-shrink: 0; }
.hp2-why-img-right { width: 180px; overflow: hidden; }

.hp2-why-img-gradient-right {
  position: absolute;
  inset: 0;
  background: linear-gradient(to left, transparent 0%, rgba(8,20,50,0.7) 100%);
  pointer-events: none;
  z-index: 2;
}

.hp2-why-server-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(160deg, rgba(0,20,50,0.9) 0%, rgba(2,8,28,0.98) 100%),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 18px,
      rgba(0,191,255,0.04) 18px,
      rgba(0,191,255,0.04) 20px
    ),
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 28px,
      rgba(0,191,255,0.04) 28px,
      rgba(0,191,255,0.04) 30px
    );
  z-index: 1;
}
.hp2-why-server-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 80% 60%,
    rgba(0,191,255,0.15) 0%, transparent 70%);
}

.hp2-why-content {
  flex: 1;
  padding: 40px 36px 40px 32px;
  position: relative;
  z-index: 3;
}
.hp2-why-panel-right .hp2-why-content { padding: 40px 32px 40px 36px; }

.hp2-why-icon-row { margin-bottom: 16px; }

.hp2-why-icon-circle {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  background: rgba(0,160,220,0.22);
  border: 1px solid rgba(0,191,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.hp2-why-icon-circle i {
  font-size: 1.2rem;
  color: #38d9ff;
}

.hp2-why-icon-teal {
  background: rgba(0,130,130,0.2);
  border-color: rgba(0,200,200,0.25);
}
.hp2-why-icon-teal i { color: #00d4e0; }

.hp2-why-card-sup {
  font-size: 0.78rem;
  font-weight: 600;
  color: #607a9a;
  letter-spacing: 0.3px;
  margin-bottom: 2px;
}

.hp2-why-card-title {
  font-size: 1.3rem;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 14px;
}

.hp2-why-card-title-sky { color: #00bfff; }
.hp2-why-card-title-teal { color: #00c8d8; }

.hp2-why-card-desc {
  font-size: 0.85rem;
  color: #8aaac8;
  line-height: 1.7;
  margin-bottom: 20px;
}

.hp2-why-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 11px;
}

.hp2-why-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.84rem;
  color: #c8ddf4;
  line-height: 1.4;
}

.hp2-why-list li small {
  display: block;
  color: #6888aa;
  font-size: 0.77rem;
}

.hp2-why-list-icon {
  flex-shrink: 0;
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: rgba(0,160,220,0.18);
  border: 1px solid rgba(0,191,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
}
.hp2-why-list-icon i {
  font-size: 0.75rem;
  color: #38d9ff;
}

.hp2-why-list-check-icon {
  background: rgba(0,160,120,0.15);
  border-color: rgba(0,200,160,0.2);
}
.hp2-why-list-check-icon i { color: #00d4a0; }

.hp2-why-divider {
  width: 1px;
  background: linear-gradient(
    to bottom,
    transparent 5%,
    rgba(0,191,255,0.25) 25%,
    rgba(0,191,255,0.35) 50%,
    rgba(0,191,255,0.25) 75%,
    transparent 95%
  );
  flex-shrink: 0;
  align-self: stretch;
}

.hp2-why-stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-top: 32px;
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(0,191,255,0.12);
  border-radius: 16px;
  padding: 22px 32px;
  flex-wrap: wrap;
  row-gap: 20px;
}

.hp2-why-stat {
  display: flex;
  align-items: center;
  gap: 14px;
  flex: 1;
  justify-content: center;
  min-width: 160px;
}

.hp2-why-stat-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: rgba(0,160,220,0.18);
  border: 1px solid rgba(0,191,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hp2-why-stat-icon i {
  font-size: 1rem;
  color: #38d9ff;
}

.hp2-why-stat-text { display: flex; flex-direction: column; gap: 2px; }
.hp2-why-stat-text strong { font-size: 0.95rem; font-weight: 700; color: #dce8ff; }
.hp2-why-stat-text span { font-size: 0.75rem; color: #5a7aa0; }

.hp2-why-stat-sep {
  width: 1px;
  height: 40px;
  background: rgba(0,191,255,0.18);
  flex-shrink: 0;
  margin: 0 8px;
}

/* RESPONSIVE — WHY */
@media (max-width: 1024px) {
  .hp2-why-card-outer { grid-template-columns: 1fr; grid-template-rows: auto auto auto; }
  .hp2-why-divider { width: 100%; height: 1px; background: linear-gradient(to right, transparent 5%, rgba(0,191,255,0.25) 50%, transparent 95%); align-self: auto; }
  .hp2-why-img-right { display: none; }
}

@media (max-width: 768px) {
  .hp2-why-section { padding: 60px 0 0; }
  .hp2-why-container { padding: 0 16px 60px; }
  .hp2-why-title { font-size: 1.9rem; }
  .hp2-why-content { padding: 24px 20px; }
  .hp2-why-panel-right .hp2-why-content { padding: 24px 20px; }
  .hp2-why-stats-bar { gap: 12px; padding: 18px 16px; }
  .hp2-why-stat-sep { display: none; }
  .hp2-why-stat { min-width: 130px; flex: 0 0 calc(50% - 12px); }
}

@media (max-width: 480px) {
  .hp2-why-badge { font-size: 0.62rem; padding: 7px 14px; }
  .hp2-why-title { font-size: 1.55rem; }
  .hp2-why-stat { flex: 0 0 100%; justify-content: flex-start; }
}


/* ================================================================
   COMPLETE HP PORTFOLIO SECTION
   ================================================================ */

.hp2-port-section {
  background: #040d1e;
  padding: 80px 0 90px;
  position: relative;
  overflow: hidden;
}

.hp2-port-section::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse at 50% 0%, rgba(0,191,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.hp2-port-container {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 24px;
}

.hp2-port-header {
  text-align: center;
  margin-bottom: 48px;
}

.hp2-port-header-icon {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: rgba(0,160,220,0.18);
  border: 1px solid rgba(0,191,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}
.hp2-port-header-icon i { font-size: 1.3rem; color: #38d9ff; }

.hp2-port-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin-bottom: 14px;
}

.hp2-port-accent { color: #00bfff; }

.hp2-port-title-decor {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 14px;
}
.hp2-port-decor-line {
  width: 60px;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(0,191,255,0.6));
  border-radius: 2px;
}
.hp2-port-decor-line:last-child { background: linear-gradient(90deg, rgba(0,191,255,0.6), transparent); }
.hp2-port-decor-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #00bfff;
  box-shadow: 0 0 8px rgba(0,191,255,0.8);
}

.hp2-port-subtitle { font-size: 0.95rem; color: #6888aa; }

.hp2-port-top-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 20px;
}

.hp2-port-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(0,191,255,0.12);
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
}
.hp2-port-card:hover {
  border-color: rgba(0,191,255,0.38);
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 30px rgba(0,191,255,0.07);
}

.hp2-port-card-img {
  position: relative;
  height: 200px;
  overflow: hidden;
  background: #070f28;
}

.hp2-port-img-laptop {
  background:
    linear-gradient(160deg, rgba(0,20,50,0.95) 0%, rgba(2,8,28,0.98) 100%),
    repeating-linear-gradient(135deg, transparent, transparent 20px, rgba(0,191,255,0.04) 20px, rgba(0,191,255,0.04) 22px);
}
.hp2-port-img-server {
  background:
    linear-gradient(160deg, rgba(0,20,50,0.95) 0%, rgba(3,10,30,0.98) 100%),
    repeating-linear-gradient(135deg, transparent, transparent 20px, rgba(0,191,255,0.04) 20px, rgba(0,191,255,0.04) 22px);
}
.hp2-port-img-hybrid {
  background:
    linear-gradient(160deg, rgba(0,20,50,0.95) 0%, rgba(2,8,28,0.98) 100%),
    repeating-linear-gradient(135deg, transparent, transparent 20px, rgba(0,191,255,0.05) 20px, rgba(0,191,255,0.05) 22px);
}

.hp2-port-img-laptop::after,
.hp2-port-img-server::after,
.hp2-port-img-hybrid::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 50% 80%, rgba(0,191,255,0.18) 0%, transparent 70%);
  pointer-events: none;
}

.hp2-port-card-img-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60px;
  background: linear-gradient(to bottom, transparent, rgba(5,14,40,0.9));
  z-index: 3;
  pointer-events: none;
}

.hp2-port-card-body {
  padding: 22px 22px 26px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hp2-port-card-icon {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: rgba(0,160,220,0.18);
  border: 1px solid rgba(0,191,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
}
.hp2-port-card-icon i { font-size: 1rem; color: #38d9ff; }

.hp2-port-card-title {
  font-size: 1.1rem;
  font-weight: 800;
  color: #e8f0ff;
  margin-bottom: 8px;
  line-height: 1.3;
}

.hp2-port-card-desc {
  font-size: 0.82rem;
  color: #6888aa;
  line-height: 1.65;
  margin-bottom: 14px;
}

.hp2-port-list {
  list-style: none;
  padding: 0;
  margin: 0 0 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.hp2-port-list li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.83rem;
  color: #b0c8e8;
}
.hp2-port-list li i { color: #00bfff; font-size: 0.75rem; flex-shrink: 0; }

.hp2-port-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.83rem;
  font-weight: 700;
  color: #00bfff;
  text-decoration: none;
  transition: gap 0.2s, color 0.2s;
  margin-top: auto;
}
.hp2-port-link:hover { gap: 12px; color: #38d9ff; }
.hp2-port-link i { font-size: 0.75rem; }

/* Bottom row */
.hp2-port-bottom-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.hp2-port-dc-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(0,191,255,0.12);
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: row;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.hp2-port-dc-card:hover {
  border-color: rgba(0,191,255,0.32);
  box-shadow: 0 16px 40px rgba(0,0,0,0.35);
}

.hp2-port-dc-img {
  position: relative;
  width: 200px;
  flex-shrink: 0;
  overflow: hidden;
  background:
    linear-gradient(160deg, rgba(0,15,40,0.96) 0%, rgba(2,8,28,0.99) 100%),
    repeating-linear-gradient(90deg, transparent, transparent 16px, rgba(0,191,255,0.04) 16px, rgba(0,191,255,0.04) 18px),
    repeating-linear-gradient(0deg, transparent, transparent 26px, rgba(0,191,255,0.03) 26px, rgba(0,191,255,0.03) 28px);
}
.hp2-port-dc-img::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 30% 70%, rgba(0,191,255,0.16) 0%, transparent 70%);
}

.hp2-port-dc-img-overlay {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 60px;
  background: linear-gradient(to right, transparent, rgba(6,15,45,0.9));
  z-index: 3;
}

.hp2-port-dc-body {
  padding: 28px 26px;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.hp2-port-dc-icon { margin-bottom: 14px; }

.hp2-port-why-panel {
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(0,191,255,0.12);
  border-radius: 16px;
  padding: 28px 28px 24px;
  display: flex;
  flex-direction: column;
}

.hp2-port-why-title {
  font-size: 1.3rem;
  font-weight: 800;
  color: #e8f0ff;
  margin-bottom: 24px;
}

.hp2-port-why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px 24px;
  flex: 1;
  margin-bottom: 24px;
}

.hp2-port-why-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.hp2-port-why-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(0,160,220,0.18);
  border: 1px solid rgba(0,191,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
}
.hp2-port-why-icon i { font-size: 0.9rem; color: #38d9ff; }

.hp2-port-why-item strong { font-size: 0.88rem; font-weight: 700; color: #c8ddf4; }
.hp2-port-why-item span { font-size: 0.77rem; color: #5a7aa0; line-height: 1.5; }

.hp2-port-cta-bar {
  display: flex;
  align-items: center;
  gap: 14px;
  background: rgba(0,191,255,0.07);
  border: 1px solid rgba(0,191,255,0.18);
  border-radius: 12px;
  padding: 14px 16px;
  flex-wrap: wrap;
  row-gap: 10px;
}

.hp2-port-cta-icon {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  background: rgba(0,191,255,0.12);
  border: 1px solid rgba(0,191,255,0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hp2-port-cta-icon i { font-size: 0.95rem; color: #38d9ff; }

.hp2-port-cta-text { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 120px; }
.hp2-port-cta-text strong { font-size: 0.84rem; font-weight: 700; color: #dce8ff; }
.hp2-port-cta-text span { font-size: 0.75rem; color: #5a7aa0; }

.hp2-port-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 8px;
  background: linear-gradient(135deg, #007aaa 0%, #00bfff 100%);
  color: #fff;
  font-size: 0.82rem;
  font-weight: 700;
  text-decoration: none;
  white-space: nowrap;
  transition: all 0.3s ease;
  box-shadow: 0 4px 16px rgba(0,191,255,0.3);
  flex-shrink: 0;
}
.hp2-port-cta-btn:hover {
  background: linear-gradient(135deg, #00bfff 0%, #38d9ff 100%);
  box-shadow: 0 6px 24px rgba(0,191,255,0.5);
  color: #fff;
  transform: translateY(-1px);
}
.hp2-port-cta-btn i { font-size: 0.72rem; }

/* RESPONSIVE — PORTFOLIO */
@media (max-width: 1024px) {
  .hp2-port-top-row { grid-template-columns: 1fr 1fr; }
  .hp2-port-top-row .hp2-port-card:nth-child(3) { grid-column: span 2; display: grid; grid-template-columns: 260px 1fr; }
  .hp2-port-top-row .hp2-port-card:nth-child(3) .hp2-port-card-img { height: auto; }
  .hp2-port-bottom-row { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .hp2-port-section { padding: 60px 0 70px; }
  .hp2-port-top-row { grid-template-columns: 1fr; }
  .hp2-port-top-row .hp2-port-card:nth-child(3) { grid-column: auto; display: flex; flex-direction: column; }
  .hp2-port-top-row .hp2-port-card:nth-child(3) .hp2-port-card-img { height: 200px; }
  .hp2-port-dc-card { flex-direction: column; }
  .hp2-port-dc-img { width: 100%; height: 180px; }
  .hp2-port-dc-img-overlay { right: auto; bottom: 0; left: 0; width: 100%; height: 60px; background: linear-gradient(to bottom, transparent, rgba(6,15,45,0.9)); }
  .hp2-port-why-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
  .hp2-port-cta-bar { flex-direction: column; align-items: flex-start; }
  .hp2-port-cta-btn { width: 100%; justify-content: center; }
}

@media (max-width: 480px) {
  .hp2-port-container { padding: 0 16px; }
  .hp2-port-title { font-size: 1.7rem; }
  .hp2-port-why-grid { grid-template-columns: 1fr; }
}


/* ================================================================
   INDUSTRIES SECTION
   ================================================================ */

.hp2-ind-section {
  background: #040d1e;
  padding: 90px 0;
  position: relative;
  overflow: hidden;
}

.hp2-ind-bg-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  filter: blur(90px);
}
.hp2-ind-bg-glow-left {
  width: 500px; height: 500px;
  top: -80px; left: -120px;
  background: radial-gradient(circle, rgba(0,191,255,0.14) 0%, transparent 70%);
}
.hp2-ind-bg-glow-right {
  width: 600px; height: 500px;
  bottom: -100px; right: -140px;
  background: radial-gradient(circle, rgba(0,140,220,0.12) 0%, transparent 70%);
}

.hp2-ind-container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 24px;
  position: relative;
  z-index: 2;
}

.hp2-ind-header { text-align: center; margin-bottom: 56px; }

.hp2-ind-badge {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 8px 22px;
  border-radius: 50px;
  border: 1px solid rgba(0,191,255,0.35);
  background: rgba(0,130,180,0.12);
  backdrop-filter: blur(8px);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 1.8px;
  text-transform: uppercase;
  color: #38d9ff;
  margin-bottom: 28px;
}
.hp2-ind-badge i { font-size: 0.75rem; color: #38d9ff; }
.hp2-ind-badge-dot {
  display: inline-block;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: #00bfff;
  opacity: 0.7;
}

.hp2-ind-title {
  font-size: clamp(2.1rem, 4vw, 3.2rem);
  font-weight: 900;
  line-height: 1.15;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}

.hp2-ind-accent { color: #00bfff; }
.hp2-ind-subtitle { font-size: 0.97rem; color: #7a96b8; margin: 0; }

.hp2-ind-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.hp2-ind-card {
  position: relative;
  border-radius: 16px;
  padding: 28px 24px;
  background: rgba(8,18,48,0.7);
  border: 1px solid rgba(0,191,255,0.15);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 0;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  backdrop-filter: blur(6px);
}
.hp2-ind-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(0,0,0,0.5); }

.hp2-ind-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14px;
}

.hp2-ind-num {
  font-size: 0.78rem;
  font-weight: 700;
  color: rgba(255,255,255,0.22);
  letter-spacing: 0.5px;
  line-height: 1;
  margin-top: 4px;
}

.hp2-ind-icon-wrap {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.3s;
}
.hp2-ind-card:hover .hp2-ind-icon-wrap { transform: scale(1.08); }
.hp2-ind-icon-wrap i { font-size: 1.25rem; }

.hp2-ind-num-rule { width: 28px; height: 2px; border-radius: 2px; margin-bottom: 16px; }
.hp2-ind-card-title { font-size: 1rem; font-weight: 800; color: #e0ecff; line-height: 1.35; margin: 0 0 10px; }
.hp2-ind-card-desc { font-size: 0.8rem; color: #6a88aa; line-height: 1.65; flex: 1; margin: 0 0 20px; }

.hp2-ind-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px; height: 36px;
  border-radius: 50%;
  text-decoration: none;
  font-size: 0.85rem;
  flex-shrink: 0;
  transition: transform 0.25s, box-shadow 0.25s;
  margin-top: auto;
}
.hp2-ind-arrow:hover { transform: scale(1.12) translateX(2px); }
.hp2-ind-arrow i { font-size: 0.8rem; }

.hp2-ind-card-bg-pattern {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: 0.08;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 12px,
    rgba(255,255,255,0.4) 12px,
    rgba(255,255,255,0.4) 13px
  );
}
.hp2-ind-card-bg-wave {
  background:
    radial-gradient(ellipse 80% 40% at 50% 100%, rgba(255,140,0,0.2) 0%, transparent 70%),
    repeating-linear-gradient(-45deg, transparent, transparent 12px, rgba(255,255,255,0.3) 12px, rgba(255,255,255,0.3) 13px);
}

.hp2-ind-card-top,
.hp2-ind-num-rule,
.hp2-ind-card-title,
.hp2-ind-card-desc,
.hp2-ind-arrow { position: relative; z-index: 2; }

/* ── SKY (Card 1 — Large Enterprises — PRIMARY sky blue) ── */
.hp2-ind-card-sky { border-color: rgba(0,191,255,0.25); background: linear-gradient(145deg, rgba(0,20,50,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-sky:hover { border-color: rgba(0,191,255,0.5); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(0,191,255,0.1); }
.hp2-ind-icon-sky { background: rgba(0,191,255,0.12); border: 1px solid rgba(0,191,255,0.3); }
.hp2-ind-icon-sky i { color: #38d9ff; }
.hp2-ind-rule-sky { background: #00bfff; }
.hp2-ind-arrow-sky { background: rgba(0,191,255,0.15); color: #38d9ff; border: 1px solid rgba(0,191,255,0.3); }
.hp2-ind-arrow-sky:hover { background: #00bfff; color: #fff; box-shadow: 0 6px 20px rgba(0,191,255,0.4); }

/* ── TEAL (Card 2 — Banking) ── */
.hp2-ind-card-teal { border-color: rgba(0,180,160,0.22); background: linear-gradient(145deg, rgba(0,30,40,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-teal:hover { border-color: rgba(0,210,190,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(0,180,160,0.1); }
.hp2-ind-icon-teal { background: rgba(0,180,160,0.15); border: 1px solid rgba(0,210,190,0.3); }
.hp2-ind-icon-teal i { color: #00d4c0; }
.hp2-ind-rule-teal { background: #00c8b0; }
.hp2-ind-arrow-teal { background: rgba(0,200,180,0.15); color: #00d4c0; border: 1px solid rgba(0,200,180,0.3); }
.hp2-ind-arrow-teal:hover { background: #00c8b0; color: #fff; box-shadow: 0 6px 20px rgba(0,200,180,0.4); }

/* ── GREEN (Card 3 — Healthcare) ── */
.hp2-ind-card-green { border-color: rgba(0,180,80,0.22); background: linear-gradient(145deg, rgba(0,25,15,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-green:hover { border-color: rgba(0,220,100,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(0,180,80,0.1); }
.hp2-ind-icon-green { background: rgba(0,180,80,0.15); border: 1px solid rgba(0,220,100,0.3); }
.hp2-ind-icon-green i { color: #22e060; }
.hp2-ind-rule-green { background: #00cc60; }
.hp2-ind-arrow-green { background: rgba(0,200,80,0.15); color: #22e060; border: 1px solid rgba(0,200,80,0.3); }
.hp2-ind-arrow-green:hover { background: #00cc60; color: #fff; box-shadow: 0 6px 20px rgba(0,200,80,0.4); }

/* ── INDIGO (Card 4 — Education) ── */
.hp2-ind-card-indigo { border-color: rgba(100,80,240,0.22); background: linear-gradient(145deg, rgba(15,10,50,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-indigo:hover { border-color: rgba(130,110,255,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(100,80,240,0.12); }
.hp2-ind-icon-indigo { background: rgba(100,80,240,0.15); border: 1px solid rgba(130,110,255,0.3); }
.hp2-ind-icon-indigo i { color: #a080ff; }
.hp2-ind-rule-indigo { background: #8060f0; }
.hp2-ind-arrow-indigo { background: rgba(100,80,240,0.15); color: #a080ff; border: 1px solid rgba(130,110,255,0.3); }
.hp2-ind-arrow-indigo:hover { background: #8060f0; color: #fff; box-shadow: 0 6px 20px rgba(100,80,240,0.4); }

/* ── ORANGE (Card 5 — Manufacturing) ── */
.hp2-ind-card-orange { border-color: rgba(240,120,0,0.22); background: linear-gradient(145deg, rgba(40,15,0,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-orange:hover { border-color: rgba(255,150,30,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(240,120,0,0.12); }
.hp2-ind-icon-orange { background: rgba(240,120,0,0.15); border: 1px solid rgba(255,150,30,0.3); }
.hp2-ind-icon-orange i { color: #ff9030; }
.hp2-ind-rule-orange { background: #f07000; }
.hp2-ind-arrow-orange { background: rgba(240,120,0,0.15); color: #ff9030; border: 1px solid rgba(255,150,30,0.3); }
.hp2-ind-arrow-orange:hover { background: #f07000; color: #fff; box-shadow: 0 6px 20px rgba(240,120,0,0.4); }

/* ── CYAN (Card 6 — Government) ── */
.hp2-ind-card-cyan { border-color: rgba(0,190,230,0.22); background: linear-gradient(145deg, rgba(0,20,35,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-cyan:hover { border-color: rgba(0,220,255,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(0,190,230,0.1); }
.hp2-ind-icon-cyan { background: rgba(0,190,230,0.15); border: 1px solid rgba(0,220,255,0.3); }
.hp2-ind-icon-cyan i { color: #00d8f8; }
.hp2-ind-rule-cyan { background: #00c4e0; }
.hp2-ind-arrow-cyan { background: rgba(0,190,230,0.15); color: #00d8f8; border: 1px solid rgba(0,220,255,0.3); }
.hp2-ind-arrow-cyan:hover { background: #00c4e0; color: #fff; box-shadow: 0 6px 20px rgba(0,190,230,0.4); }

/* ── PINK (Card 7 — Retail) ── */
.hp2-ind-card-pink { border-color: rgba(220,0,140,0.22); background: linear-gradient(145deg, rgba(35,0,25,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-pink:hover { border-color: rgba(255,30,170,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(220,0,140,0.12); }
.hp2-ind-icon-pink { background: rgba(220,0,140,0.15); border: 1px solid rgba(255,30,170,0.3); }
.hp2-ind-icon-pink i { color: #ff40c0; }
.hp2-ind-rule-pink { background: #e0008a; }
.hp2-ind-arrow-pink { background: rgba(220,0,140,0.15); color: #ff40c0; border: 1px solid rgba(255,30,170,0.3); }
.hp2-ind-arrow-pink:hover { background: #e0008a; color: #fff; box-shadow: 0 6px 20px rgba(220,0,140,0.4); }

/* ── PURPLE (Card 8 — IT & Software) ── */
.hp2-ind-card-purple { border-color: rgba(150,60,220,0.22); background: linear-gradient(145deg, rgba(20,5,45,0.88) 0%, rgba(8,18,48,0.75) 100%); }
.hp2-ind-card-purple:hover { border-color: rgba(180,100,255,0.45); box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 40px rgba(150,60,220,0.12); }
.hp2-ind-icon-purple { background: rgba(150,60,220,0.15); border: 1px solid rgba(180,100,255,0.3); }
.hp2-ind-icon-purple i { color: #c070ff; }
.hp2-ind-rule-purple { background: #9040d8; }
.hp2-ind-arrow-purple { background: rgba(150,60,220,0.15); color: #c070ff; border: 1px solid rgba(180,100,255,0.3); }
.hp2-ind-arrow-purple:hover { background: #9040d8; color: #fff; box-shadow: 0 6px 20px rgba(150,60,220,0.4); }

/* RESPONSIVE — INDUSTRIES */
@media (max-width: 1100px) { .hp2-ind-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; } }
@media (max-width: 640px) {
  .hp2-ind-section { padding: 60px 0; }
  .hp2-ind-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .hp2-ind-card { padding: 20px 16px; }
  .hp2-ind-title { font-size: 1.8rem; }
}
@media (max-width: 420px) { .hp2-ind-grid { grid-template-columns: 1fr; } }


/* ================================================================
   FREE POC SECTION
   ================================================================ */

.hp2-poc-section {
  position: relative;
  background: #050d20;
  padding: 0;
  overflow: hidden;
}

.hp2-poc-particles {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.hp2-poc-particle {
  position: absolute;
  display: block;
  width: 2px; height: 2px;
  border-radius: 50%;
  background: rgba(0,191,255,0.55);
  animation: hp2-poc-drift linear infinite;
}

.hp2-poc-particle:nth-child(1)  { left: 5%;   top: 15%; width: 3px; height: 3px; animation-duration: 18s; animation-delay: 0s;   opacity: 0.6; }
.hp2-poc-particle:nth-child(2)  { left: 12%;  top: 70%; width: 2px; height: 2px; animation-duration: 22s; animation-delay: 1s;   opacity: 0.4; }
.hp2-poc-particle:nth-child(3)  { left: 20%;  top: 35%; width: 4px; height: 4px; animation-duration: 16s; animation-delay: 2s;   opacity: 0.5; background: rgba(0,191,255,0.6); }
.hp2-poc-particle:nth-child(4)  { left: 28%;  top: 80%; width: 2px; height: 2px; animation-duration: 25s; animation-delay: 0.5s; opacity: 0.3; }
.hp2-poc-particle:nth-child(5)  { left: 35%;  top: 20%; width: 3px; height: 3px; animation-duration: 20s; animation-delay: 3s;   opacity: 0.5; }
.hp2-poc-particle:nth-child(6)  { left: 42%;  top: 55%; width: 2px; height: 2px; animation-duration: 14s; animation-delay: 1.5s; opacity: 0.4; }
.hp2-poc-particle:nth-child(7)  { left: 50%;  top: 10%; width: 3px; height: 3px; animation-duration: 19s; animation-delay: 4s;   opacity: 0.55; background: rgba(56,217,255,0.5); }
.hp2-poc-particle:nth-child(8)  { left: 58%;  top: 65%; width: 2px; height: 2px; animation-duration: 23s; animation-delay: 0.8s; opacity: 0.35; }
.hp2-poc-particle:nth-child(9)  { left: 65%;  top: 40%; width: 4px; height: 4px; animation-duration: 17s; animation-delay: 2.5s; opacity: 0.5; }
.hp2-poc-particle:nth-child(10) { left: 72%;  top: 85%; width: 2px; height: 2px; animation-duration: 21s; animation-delay: 1.2s; opacity: 0.3; }
.hp2-poc-particle:nth-child(11) { left: 80%;  top: 25%; width: 3px; height: 3px; animation-duration: 15s; animation-delay: 3.5s; opacity: 0.5; }
.hp2-poc-particle:nth-child(12) { left: 88%;  top: 60%; width: 2px; height: 2px; animation-duration: 24s; animation-delay: 0.3s; opacity: 0.4; }
.hp2-poc-particle:nth-child(13) { left: 93%;  top: 45%; width: 3px; height: 3px; animation-duration: 18s; animation-delay: 2s;   opacity: 0.5; background: rgba(0,191,255,0.5); }
.hp2-poc-particle:nth-child(14) { left: 8%;   top: 50%; width: 2px; height: 2px; animation-duration: 26s; animation-delay: 1.8s; opacity: 0.3; }
.hp2-poc-particle:nth-child(15) { left: 16%;  top: 90%; width: 3px; height: 3px; animation-duration: 20s; animation-delay: 0.7s; opacity: 0.45; }
.hp2-poc-particle:nth-child(16) { left: 24%;  top: 5%;  width: 2px; height: 2px; animation-duration: 22s; animation-delay: 3.2s; opacity: 0.35; }
.hp2-poc-particle:nth-child(17) { left: 33%;  top: 62%; width: 4px; height: 4px; animation-duration: 16s; animation-delay: 1s;   opacity: 0.5; }
.hp2-poc-particle:nth-child(18) { left: 47%;  top: 78%; width: 2px; height: 2px; animation-duration: 19s; animation-delay: 2.8s; opacity: 0.4; }
.hp2-poc-particle:nth-child(19) { left: 55%;  top: 30%; width: 3px; height: 3px; animation-duration: 23s; animation-delay: 0.4s; opacity: 0.5; }
.hp2-poc-particle:nth-child(20) { left: 63%;  top: 92%; width: 2px; height: 2px; animation-duration: 18s; animation-delay: 4.2s; opacity: 0.3; }
.hp2-poc-particle:nth-child(21) { left: 70%;  top: 12%; width: 3px; height: 3px; animation-duration: 21s; animation-delay: 1.6s; opacity: 0.45; }
.hp2-poc-particle:nth-child(22) { left: 78%;  top: 50%; width: 2px; height: 2px; animation-duration: 17s; animation-delay: 3s;   opacity: 0.4; }
.hp2-poc-particle:nth-child(23) { left: 85%;  top: 75%; width: 4px; height: 4px; animation-duration: 20s; animation-delay: 0.9s; opacity: 0.5; }
.hp2-poc-particle:nth-child(24) { left: 91%;  top: 20%; width: 2px; height: 2px; animation-duration: 25s; animation-delay: 2.4s; opacity: 0.35; }
.hp2-poc-particle:nth-child(25) { left: 3%;   top: 38%; width: 3px; height: 3px; animation-duration: 19s; animation-delay: 1.4s; opacity: 0.5; }
.hp2-poc-particle:nth-child(26) { left: 10%;  top: 82%; width: 2px; height: 2px; animation-duration: 22s; animation-delay: 3.6s; opacity: 0.3; }
.hp2-poc-particle:nth-child(27) { left: 18%;  top: 48%; width: 3px; height: 3px; animation-duration: 16s; animation-delay: 0.6s; opacity: 0.45; }
.hp2-poc-particle:nth-child(28) { left: 26%;  top: 8%;  width: 2px; height: 2px; animation-duration: 24s; animation-delay: 4.5s; opacity: 0.4; }
.hp2-poc-particle:nth-child(29) { left: 38%;  top: 95%; width: 4px; height: 4px; animation-duration: 18s; animation-delay: 1.9s; opacity: 0.5; }
.hp2-poc-particle:nth-child(30) { left: 48%;  top: 42%; width: 2px; height: 2px; animation-duration: 20s; animation-delay: 2.2s; opacity: 0.35; }
.hp2-poc-particle:nth-child(31) { left: 57%;  top: 18%; width: 3px; height: 3px; animation-duration: 23s; animation-delay: 0.2s; opacity: 0.5; }
.hp2-poc-particle:nth-child(32) { left: 66%;  top: 72%; width: 2px; height: 2px; animation-duration: 17s; animation-delay: 3.8s; opacity: 0.4; }
.hp2-poc-particle:nth-child(33) { left: 74%;  top: 32%; width: 3px; height: 3px; animation-duration: 21s; animation-delay: 1.1s; opacity: 0.45; }
.hp2-poc-particle:nth-child(34) { left: 82%;  top: 88%; width: 2px; height: 2px; animation-duration: 18s; animation-delay: 4s;   opacity: 0.3; }
.hp2-poc-particle:nth-child(35) { left: 90%;  top: 58%; width: 4px; height: 4px; animation-duration: 16s; animation-delay: 2.6s; opacity: 0.5; }
.hp2-poc-particle:nth-child(36) { left: 96%;  top: 8%;  width: 2px; height: 2px; animation-duration: 22s; animation-delay: 0.1s; opacity: 0.35; }
.hp2-poc-particle:nth-child(37) { left: 14%;  top: 28%; width: 3px; height: 3px; animation-duration: 19s; animation-delay: 3.4s; opacity: 0.5; }
.hp2-poc-particle:nth-child(38) { left: 44%;  top: 68%; width: 2px; height: 2px; animation-duration: 25s; animation-delay: 1.7s; opacity: 0.4; }
.hp2-poc-particle:nth-child(39) { left: 75%;  top: 55%; width: 3px; height: 3px; animation-duration: 20s; animation-delay: 2.9s; opacity: 0.45; }
.hp2-poc-particle:nth-child(40) { left: 97%;  top: 35%; width: 2px; height: 2px; animation-duration: 23s; animation-delay: 0.5s; opacity: 0.35; }

@keyframes hp2-poc-drift {
  0%   { transform: translateY(0) translateX(0); opacity: 0; }
  10%  { opacity: 1; }
  90%  { opacity: 0.8; }
  100% { transform: translateY(-120px) translateX(20px); opacity: 0; }
}

.hp2-poc-glow-tl {
  position: absolute;
  top: -20%; left: -10%;
  width: 60vw; height: 80%;
  background: radial-gradient(ellipse at 20% 20%, rgba(0,191,255,0.18) 0%, rgba(0,140,220,0.08) 40%, transparent 70%);
  pointer-events: none; z-index: 0;
  animation: hp2-glow-pulse 8s ease-in-out infinite alternate;
}
.hp2-poc-glow-br {
  position: absolute;
  bottom: -20%; right: -10%;
  width: 55vw; height: 80%;
  background: radial-gradient(ellipse at 80% 80%, rgba(0,191,255,0.14) 0%, rgba(0,160,220,0.06) 40%, transparent 70%);
  pointer-events: none; z-index: 0;
  animation: hp2-glow-pulse 10s ease-in-out infinite alternate-reverse;
}

.hp2-poc-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: minmax(0, 48%) minmax(0, 52%);
  gap: 48px;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 72px 24px;
}

.hp2-poc-left {
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: visible;
}

.hp2-poc-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 18px;
  border-radius: 50px;
  background: rgba(0,100,160,0.3);
  border: 1px solid rgba(0,191,255,0.35);
  backdrop-filter: blur(8px);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 1.6px;
  text-transform: uppercase;
  color: #70d8ff;
  margin-bottom: 22px;
}
.hp2-poc-badge i { font-size: 0.78rem; color: #00bfff; }

.hp2-poc-headline {
  font-size: clamp(2.2rem, 4vw, 3.2rem);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 0;
  letter-spacing: -0.02em;
  color: #ffffff;
  word-break: break-word;
  overflow-wrap: break-word;
}
.hp2-poc-free { color: #00bfff; font-size: inherit; font-weight: inherit; }
.hp2-poc-headline-white { color: #ffffff; display: block; }

.hp2-poc-rule {
  width: 42px; height: 3px;
  background: #00bfff;
  border-radius: 2px;
  margin: 16px 0 20px;
}

.hp2-poc-subtitle {
  font-size: 0.95rem;
  font-weight: 500;
  color: #e8f0ff;
  line-height: 1.6;
  margin-bottom: 12px;
}
.hp2-poc-link-text { color: #00bfff; font-weight: 600; }

.hp2-poc-desc {
  font-size: 0.85rem;
  color: #7a9ac0;
  line-height: 1.75;
  margin-bottom: 28px;
  overflow-wrap: break-word;
  word-break: break-word;
}

.hp2-poc-cta-btn {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  gap: 12px;
  padding: 14px 32px;
  border-radius: 50px;
  background: linear-gradient(135deg, #007aaa 0%, #00bfff 55%, #38d9ff 100%);
  background-size: 200% auto;
  color: #ffffff;
  font-size: 0.85rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  text-decoration: none;
  box-shadow: 0 8px 28px rgba(0,191,255,0.45);
  transition: all 0.4s ease;
  margin-bottom: 24px;
  width: fit-content;
}
.hp2-poc-cta-btn:hover {
  background-position: right center;
  transform: translateY(-3px);
  box-shadow: 0 14px 40px rgba(0,191,255,0.6);
  color: #fff;
}
.hp2-poc-cta-btn i {
  font-size: 0.85rem;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  width: 28px; height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hp2-poc-trust { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; }
.hp2-poc-trust-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  color: #5a7aa0;
  font-weight: 500;
}
.hp2-poc-trust-item i { color: #00bfff; font-size: 0.78rem; }

/* RIGHT — 2×3 icon grid */
.hp2-poc-right {
  display: flex;
  flex-direction: column;
  gap: 0;
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(0,191,255,0.18);
  border-radius: 20px;
  overflow: hidden;
  backdrop-filter: blur(8px);
  box-shadow:
    0 30px 60px rgba(0,0,0,0.45),
    inset 0 1px 0 rgba(255,255,255,0.04);
}

.hp2-poc-grid-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.hp2-poc-grid-divider {
  height: 1px;
  background: linear-gradient(
    to right,
    transparent 5%,
    rgba(0,191,255,0.25) 25%,
    rgba(0,191,255,0.35) 50%,
    rgba(0,191,255,0.25) 75%,
    transparent 95%
  );
}

.hp2-poc-feat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32px 20px 24px;
  position: relative;
  border-right: 1px solid rgba(0,191,255,0.15);
  transition: background 0.3s;
}
.hp2-poc-feat-card:last-child { border-right: none; }
.hp2-poc-feat-card:hover { background: rgba(0,191,255,0.05); }

.hp2-poc-feat-circle {
  width: 72px; height: 72px;
  border-radius: 50%;
  background: rgba(0,100,160,0.45);
  border: 1.5px solid rgba(0,191,255,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  position: relative;
  box-shadow:
    0 0 0 8px rgba(0,191,255,0.07),
    0 0 20px rgba(0,191,255,0.18);
  transition: box-shadow 0.3s, border-color 0.3s;
}
.hp2-poc-feat-card:hover .hp2-poc-feat-circle {
  box-shadow:
    0 0 0 10px rgba(0,191,255,0.1),
    0 0 30px rgba(0,191,255,0.32);
  border-color: rgba(0,191,255,0.55);
}

.hp2-poc-feat-circle::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 50%;
  transform: translateX(-50%);
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #00bfff;
  box-shadow: 0 0 8px #00bfff;
  animation: hp2-poc-dot-blink 2s ease-in-out infinite;
}
.hp2-poc-feat-card:nth-child(1) .hp2-poc-feat-circle::after { animation-delay: 0s; }
.hp2-poc-feat-card:nth-child(2) .hp2-poc-feat-circle::after { animation-delay: 0.4s; }
.hp2-poc-feat-card:nth-child(3) .hp2-poc-feat-circle::after { animation-delay: 0.8s; }

@keyframes hp2-poc-dot-blink {
  0%, 100% { opacity: 0.4; transform: translateX(-50%) scale(1); }
  50%       { opacity: 1;   transform: translateX(-50%) scale(1.3); }
}

.hp2-poc-feat-circle i {
  font-size: 1.3rem;
  color: #38d9ff;
  filter: drop-shadow(0 0 6px rgba(0,191,255,0.5));
}

.hp2-poc-feat-label {
  font-size: 0.82rem;
  font-weight: 500;
  color: #c0d4f0;
  line-height: 1.5;
  margin: 0 0 14px;
}

.hp2-poc-feat-rule {
  width: 28px; height: 2px;
  border-radius: 2px;
  background: linear-gradient(90deg, #00bfff, #38d9ff);
  margin-top: auto;
  opacity: 0.6;
}

/* RESPONSIVE — POC */
@media (max-width: 1024px) {
  .hp2-poc-inner { grid-template-columns: 1fr; gap: 36px; padding: 60px 20px 56px; }
  .hp2-poc-left { max-width: 580px; }
  .hp2-poc-headline { font-size: clamp(2.2rem, 5.5vw, 3rem); }
}
@media (max-width: 768px) {
  .hp2-poc-inner { padding: 48px 16px 44px; gap: 28px; }
  .hp2-poc-headline { font-size: 2.4rem; }
  .hp2-poc-feat-card { padding: 24px 12px 18px; }
  .hp2-poc-feat-circle { width: 58px; height: 58px; }
  .hp2-poc-feat-circle i { font-size: 1.1rem; }
  .hp2-poc-feat-label { font-size: 0.76rem; }
}
@media (max-width: 540px) {
  .hp2-poc-headline { font-size: 2rem; }
  .hp2-poc-feat-card { padding: 20px 8px 16px; }
  .hp2-poc-feat-circle { width: 50px; height: 50px; }
  .hp2-poc-feat-circle i { font-size: 1rem; }
  .hp2-poc-feat-label { font-size: 0.7rem; }
  .hp2-poc-trust { gap: 14px; }
  .hp2-poc-cta-btn { font-size: 0.78rem; padding: 13px 24px; }
}

/* ── Career CTA — HP page with bggg.jpg background ── */
.hp-page.hp-v2-page .career-cta-section {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(rgba(2, 8, 22, 0.82), rgba(4, 12, 34, 0.88)),
    url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}

.hp-page.hp-v2-page .career-cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(0,191,255,0.14) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 50%, rgba(0,160,220,0.09) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

.hp-page.hp-v2-page .career-cta-section .career-cta-container {
  position: relative;
  z-index: 1;
}
