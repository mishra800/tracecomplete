@import './shared.css';

/* ================================================================
   TENABLE PREMIUM — CRIMSON RED EDITION
   Accent: #e5484d  Secondary: #f87171
   Structure mirrors Motadata v2. All class names prefixed tnb2-
   ================================================================ */

.tenable-page.tnb-v2-page { overflow-x: hidden; }

/* HERO */
.tenable-page .tnb2-hero,
section.tnb2-hero {
  background: linear-gradient(135deg, #0e0203 0%, #1a0405 50%, #0e0203 100%) !important;
  background-image: none !important;
  padding: 0 !important; overflow: hidden !important;
  position: relative; display: flex; align-items: center;
}

.tnb2-hero-glow-left {
  position: absolute; top: 0; left: 0; width: 50%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(229,72,77,.22) 0%, rgba(229,72,77,.08) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: tnb2-glow 7s ease-in-out infinite alternate;
}
.tnb2-hero-glow-right {
  position: absolute; bottom: 0; right: 0; width: 55%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(248,113,113,.16) 0%, rgba(229,72,77,.07) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: tnb2-glow 9s ease-in-out infinite alternate-reverse;
}
@keyframes tnb2-glow { 0%{opacity:.7}100%{opacity:1} }

.tnb2-hero-inner {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 52% 48%; gap: 24px; align-items: flex-start;
  padding: 90px 20px 20px; max-width: 1280px; margin: 0 auto; width: 100%;
}
.tnb2-headline { font-size: clamp(1.7rem,2.8vw,2.5rem); font-weight: 900; line-height: 1.12; color: #fff; letter-spacing: -.02em; margin-bottom: 6px; }
.tnb2-headline-accent { color: #e5484d; display: block; }
.tnb2-headline-rule { width: 60px; height: 3px; background: linear-gradient(90deg,#e5484d,#f87171); border-radius: 2px; margin: 14px 0 20px; }
.tnb2-desc { font-size: .97rem; color: rgba(255,255,255,.75); line-height: 1.65; margin-bottom: 22px; max-width: 520px; }
.tnb2-desc-link { color: #f87171; text-decoration: underline; }

.tnb2-feature-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.tnb2-feat { display: flex; align-items: flex-start; gap: 12px; }
.tnb2-feat-icon { min-width: 36px; height: 36px; background: rgba(229,72,77,.18); border: 1px solid rgba(229,72,77,.35); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: .85rem; }
.tnb2-feat-body { display: flex; flex-direction: column; }
.tnb2-feat-body strong { color: #fff; font-size: .88rem; font-weight: 700; }
.tnb2-feat-body span { color: rgba(255,255,255,.6); font-size: .78rem; }

.tnb2-stats-row { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
.tnb2-stat-card { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(229,72,77,.2); border-radius: 10px; padding: 10px 16px; }
.tnb2-stat-card i { color: #f87171; font-size: 1.1rem; }
.tnb2-stat-num { display: block; font-size: 1.2rem; font-weight: 800; color: #fff; }
.tnb2-stat-lbl { display: block; font-size: .62rem; color: rgba(255,255,255,.5); letter-spacing: .06em; text-transform: uppercase; }
.tnb2-stat-brand { border-color: rgba(229,72,77,.35); }
.tnb2-brand-logo { width: 48px; height: 32px; object-fit: contain; border-radius: 4px; background: #fff; padding: 2px; }

.tnb2-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
.tnb2-btn-primary { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,#e5484d,#f87171); color: #fff; font-weight: 700; font-size: .88rem; padding: 12px 24px; border-radius: 8px; text-decoration: none; transition: opacity .2s; }
.tnb2-btn-primary:hover { opacity: .88; color: #fff; }
.tnb2-btn-ghost { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(229,72,77,.5); color: #f87171; font-weight: 600; font-size: .88rem; padding: 12px 22px; border-radius: 8px; text-decoration: none; transition: background .2s; }
.tnb2-btn-ghost:hover { background: rgba(229,72,77,.12); color: #f87171; }

.tnb2-right { position: relative; display: flex; flex-direction: column; gap: 16px; padding-top: 20px; }
.tnb2-product-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 420px; height: 420px; background: radial-gradient(circle,rgba(229,72,77,.25) 0%,transparent 70%); pointer-events: none; z-index: 0; }
.tnb2-showcase { position: relative; z-index: 2; display: flex; justify-content: center; align-items: flex-end; }
.tnb2-hero-product-img { max-width: 340px; width: 100%; object-fit: contain; filter: drop-shadow(0 12px 40px rgba(229,72,77,.45)); border-radius: 12px; }
.tnb2-industry-strip { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; background: rgba(255,255,255,.04); border: 1px solid rgba(229,72,77,.18); border-radius: 10px; padding: 12px 16px; z-index: 2; position: relative; }
.tnb2-ind-item { display: flex; align-items: center; gap: 5px; font-size: .74rem; color: rgba(255,255,255,.7); white-space: nowrap; }
.tnb2-ind-item i { color: #f87171; }
.tnb2-ind-sep { width: 1px; height: 14px; background: rgba(255,255,255,.15); }

/* WHY CHOOSE */
.tnb2-why-section { background: #1a0405; padding: 70px 0 60px; }
.tnb2-why-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.tnb2-why-header { text-align: center; margin-bottom: 40px; }
.tnb2-why-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(229,72,77,.12); border: 1px solid rgba(229,72,77,.3); color: #f87171; font-size: .7rem; font-weight: 700; letter-spacing: .1em; padding: 6px 18px; border-radius: 50px; margin-bottom: 16px; text-transform: uppercase; }
.tnb2-why-title { font-size: clamp(1.6rem,2.5vw,2.2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.tnb2-why-accent { color: #e5484d; }
.tnb2-why-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 16px; }
.tnb2-why-title-rule { width: 48px; height: 3px; background: linear-gradient(90deg,#e5484d,#f87171); margin: 0 auto; border-radius: 2px; }

.tnb2-why-card-outer { display: grid; grid-template-columns: 1fr 1fr; background: rgba(255,255,255,.03); border: 1px solid rgba(229,72,77,.15); border-radius: 20px; overflow: hidden; margin-bottom: 32px; }
.tnb2-why-panel { padding: 36px 32px; position: relative; }
.tnb2-why-panel-left { border-right: 1px solid rgba(229,72,77,.15); }
.tnb2-why-icon-circle { width: 52px; height: 52px; background: rgba(229,72,77,.18); border: 1px solid rgba(229,72,77,.4); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: 1.2rem; margin-bottom: 12px; }
.tnb2-why-icon-alt { background: rgba(248,113,113,.12); border-color: rgba(248,113,113,.4); }
.tnb2-why-card-sup { font-size: .7rem; font-weight: 700; color: rgba(255,255,255,.4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 4px; }
.tnb2-why-card-title { font-size: 1.25rem; font-weight: 800; margin-bottom: 10px; color: #f87171; }
.tnb2-why-card-title-alt { color: #fca5a5; }
.tnb2-why-card-desc { color: rgba(255,255,255,.65); font-size: .88rem; line-height: 1.6; margin-bottom: 16px; }
.tnb2-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.tnb2-why-list li { display: flex; align-items: flex-start; gap: 10px; color: rgba(255,255,255,.75); font-size: .85rem; }
.tnb2-why-list-icon { min-width: 28px; height: 28px; background: rgba(229,72,77,.12); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: .8rem; }
.tnb2-why-list-check-icon { color: #fca5a5; }
.tnb2-why-list li small { display: block; font-size: .75rem; color: rgba(255,255,255,.4); }

.tnb2-why-stats-bar { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; background: rgba(229,72,77,.08); border: 1px solid rgba(229,72,77,.2); border-radius: 14px; padding: 20px 28px; }
.tnb2-why-stat { display: flex; align-items: center; gap: 12px; padding: 8px 28px; }
.tnb2-why-stat-sep { width: 1px; height: 40px; background: rgba(255,255,255,.12); }
.tnb2-why-stat-icon { width: 38px; height: 38px; background: rgba(229,72,77,.18); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: .95rem; }
.tnb2-why-stat-text strong { display: block; color: #fff; font-size: .88rem; font-weight: 700; }
.tnb2-why-stat-text span { color: rgba(255,255,255,.5); font-size: .75rem; }

/* PORTFOLIO */
.tnb2-port-section { background: #0e0203; padding: 70px 0; }
.tnb2-port-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.tnb2-port-header { text-align: center; margin-bottom: 40px; }
.tnb2-port-header-icon { width: 56px; height: 56px; background: rgba(229,72,77,.15); border: 1px solid rgba(229,72,77,.35); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: 1.3rem; margin: 0 auto 12px; }
.tnb2-port-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; margin-bottom: 8px; }
.tnb2-port-accent { color: #e5484d; }
.tnb2-port-title-decor { display: flex; align-items: center; justify-content: center; gap: 8px; margin: 8px 0; }
.tnb2-port-decor-line { flex: 0 0 40px; height: 2px; background: linear-gradient(90deg,transparent,rgba(229,72,77,.5)); }
.tnb2-port-decor-dot { width: 8px; height: 8px; border-radius: 50%; background: #e5484d; }
.tnb2-port-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; }
.tnb2-port-top-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 20px; }
.tnb2-port-card { background: rgba(255,255,255,.03); border: 1px solid rgba(229,72,77,.15); border-radius: 16px; overflow: hidden; transition: border-color .3s,transform .3s; }
.tnb2-port-card:hover { border-color: rgba(229,72,77,.5); transform: translateY(-4px); }
.tnb2-port-card-img { height: 140px; position: relative; }
.tnb2-port-img-a { background: linear-gradient(135deg,#1a0405,#3a0a0c); }
.tnb2-port-img-b { background: linear-gradient(135deg,#140204,#2e0608); }
.tnb2-port-img-c { background: linear-gradient(135deg,#0e0203,#280508); }
.tnb2-port-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(14,2,3,.9)); }
.tnb2-port-card-body { padding: 18px 20px; }
.tnb2-port-card-icon { width: 40px; height: 40px; background: rgba(229,72,77,.18); border: 1px solid rgba(229,72,77,.35); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: .9rem; margin-bottom: 10px; }
.tnb2-port-card-title { font-size: 1rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.tnb2-port-card-desc { color: rgba(255,255,255,.6); font-size: .82rem; line-height: 1.55; margin-bottom: 10px; }
.tnb2-port-list { list-style: none; padding: 0; margin: 0 0 12px; display: flex; flex-direction: column; gap: 5px; }
.tnb2-port-list li { color: rgba(255,255,255,.7); font-size: .8rem; display: flex; align-items: center; gap: 7px; }
.tnb2-port-list li i { color: #e5484d; font-size: .75rem; }
.tnb2-port-link { color: #f87171; font-size: .82rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
.tnb2-port-link:hover { gap: 10px; }
.tnb2-port-bottom-row { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; }
.tnb2-port-dc-card { background: rgba(255,255,255,.03); border: 1px solid rgba(229,72,77,.15); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.tnb2-port-dc-img { height: 120px; background: linear-gradient(135deg,#140203,#260607); position: relative; }
.tnb2-port-dc-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(14,2,3,.9)); }
.tnb2-port-dc-body { padding: 18px 20px; flex: 1; }
.tnb2-port-why-panel { background: rgba(229,72,77,.07); border: 1px solid rgba(229,72,77,.2); border-radius: 16px; padding: 24px 22px; }
.tnb2-port-why-title { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 18px; }
.tnb2-port-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }
.tnb2-port-why-item { display: flex; flex-direction: column; gap: 4px; }
.tnb2-port-why-icon { width: 32px; height: 32px; background: rgba(229,72,77,.18); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: .85rem; margin-bottom: 6px; }
.tnb2-port-why-item strong { color: #fff; font-size: .85rem; font-weight: 700; }
.tnb2-port-why-item span { color: rgba(255,255,255,.5); font-size: .77rem; line-height: 1.4; }
.tnb2-port-cta-bar { display: flex; align-items: center; gap: 14px; background: rgba(229,72,77,.1); border: 1px solid rgba(229,72,77,.25); border-radius: 10px; padding: 14px 16px; }
.tnb2-port-cta-icon { width: 36px; height: 36px; background: rgba(229,72,77,.25); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #f87171; font-size: .95rem; flex-shrink: 0; }
.tnb2-port-cta-text { flex: 1; }
.tnb2-port-cta-text strong { display: block; color: #fff; font-size: .82rem; font-weight: 700; }
.tnb2-port-cta-text span { color: rgba(255,255,255,.5); font-size: .76rem; }
.tnb2-port-cta-btn { display: inline-flex; align-items: center; gap: 5px; background: linear-gradient(135deg,#e5484d,#f87171); color: #fff; font-size: .78rem; font-weight: 700; padding: 9px 16px; border-radius: 7px; text-decoration: none; white-space: nowrap; }

/* INDUSTRIES */
.tnb2-ind-section { background: #1a0405; padding: 70px 0; position: relative; overflow: hidden; }
.tnb2-ind-bg-glow { position: absolute; width: 400px; height: 400px; border-radius: 50%; pointer-events: none; z-index: 0; }
.tnb2-ind-bg-glow-left { top: -100px; left: -100px; background: radial-gradient(circle,rgba(229,72,77,.1) 0%,transparent 70%); }
.tnb2-ind-bg-glow-right { bottom: -100px; right: -100px; background: radial-gradient(circle,rgba(248,113,113,.08) 0%,transparent 70%); }
.tnb2-ind-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.tnb2-ind-header { text-align: center; margin-bottom: 40px; }
.tnb2-ind-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(229,72,77,.1); border: 1px solid rgba(229,72,77,.25); color: #f87171; font-size: .68rem; font-weight: 700; letter-spacing: .1em; padding: 6px 16px; border-radius: 50px; margin-bottom: 14px; text-transform: uppercase; }
.tnb2-ind-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: #e5484d; }
.tnb2-ind-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.tnb2-ind-accent { color: #e5484d; }
.tnb2-ind-subtitle { color: rgba(255,255,255,.6); font-size: .92rem; }
.tnb2-ind-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
.tnb2-ind-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 22px; position: relative; overflow: hidden; transition: border-color .3s,transform .3s; }
.tnb2-ind-card:hover { transform: translateY(-4px); }
.tnb2-ind-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.tnb2-ind-icon-wrap { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: .95rem; }

.tnb2-ind-card-red     { border-color: rgba(229,72,77,.25); }  .tnb2-ind-card-red:hover     { border-color: rgba(229,72,77,.6); }
.tnb2-ind-icon-red     { background: rgba(229,72,77,.18); color: #f87171; }
.tnb2-ind-rule-red     { height: 2px; background: linear-gradient(90deg,#e5484d,transparent); margin-bottom: 10px; border-radius: 1px; }
.tnb2-ind-arrow-red    { color: #f87171; }

.tnb2-ind-card-rose    { border-color: rgba(251,113,133,.25); } .tnb2-ind-card-rose:hover    { border-color: rgba(251,113,133,.6); }
.tnb2-ind-icon-rose    { background: rgba(251,113,133,.18); color: #fda4af; }
.tnb2-ind-rule-rose    { height: 2px; background: linear-gradient(90deg,#fb7185,transparent); margin-bottom: 10px; border-radius: 1px; }
.tnb2-ind-arrow-rose   { color: #fda4af; }

.tnb2-ind-card-orange  { border-color: rgba(249,115,22,.25); }  .tnb2-ind-card-orange:hover  { border-color: rgba(249,115,22,.6); }
.tnb2-ind-icon-orange  { background: rgba(249,115,22,.18); color: #fdba74; }
.tnb2-ind-rule-orange  { height: 2px; background: linear-gradient(90deg,#f97316,transparent); margin-bottom: 10px; border-radius: 1px; }
.tnb2-ind-arrow-orange { color: #fdba74; }

.tnb2-ind-card-amber   { border-color: rgba(245,158,11,.25); }  .tnb2-ind-card-amber:hover   { border-color: rgba(245,158,11,.6); }
.tnb2-ind-icon-amber   { background: rgba(245,158,11,.18); color: #fcd34d; }
.tnb2-ind-rule-amber   { height: 2px; background: linear-gradient(90deg,#f59e0b,transparent); margin-bottom: 10px; border-radius: 1px; }
.tnb2-ind-arrow-amber  { color: #fcd34d; }

.tnb2-ind-card-crimson { border-color: rgba(220,38,38,.25); }   .tnb2-ind-card-crimson:hover { border-color: rgba(220,38,38,.6); }
.tnb2-ind-icon-crimson { background: rgba(220,38,38,.18); color: #fca5a5; }
.tnb2-ind-rule-crimson { height: 2px; background: linear-gradient(90deg,#dc2626,transparent); margin-bottom: 10px; border-radius: 1px; }
.tnb2-ind-arrow-crimson{ color: #fca5a5; }

.tnb2-ind-card-pink    { border-color: rgba(236,72,153,.25); }  .tnb2-ind-card-pink:hover    { border-color: rgba(236,72,153,.6); }
.tnb2-ind-icon-pink    { background: rgba(236,72,153,.18); color: #f9a8d4; }
.tnb2-ind-rule-pink    { height: 2px; background: linear-gradient(90deg,#ec4899,transparent); margin-bottom: 10px; border-radius: 1px; }
.tnb2-ind-arrow-pink   { color: #f9a8d4; }

.tnb2-ind-num { font-size: 1.3rem; font-weight: 900; color: rgba(255,255,255,.08); }
.tnb2-ind-card-title { font-size: .95rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.tnb2-ind-card-desc { color: rgba(255,255,255,.6); font-size: .8rem; line-height: 1.5; margin-bottom: 12px; }
.tnb2-ind-arrow { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); text-decoration: none; transition: background .2s; }
.tnb2-ind-arrow:hover { background: rgba(255,255,255,.12); }
.tnb2-ind-card-bg-pattern { position: absolute; right: -20px; bottom: -20px; width: 80px; height: 80px; border-radius: 50%; background: rgba(229,72,77,.04); pointer-events: none; }

/* ── SPECIAL OFFER — Greythr-style two-column card ── */
.tnb2-special-offer { padding: 80px 0 100px; position: relative; }

.tnb2-offer-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 48px;
  background: linear-gradient(135deg, #0e0203 0%, #1a0305 50%, #0d0203 100%);
  border: 1px solid rgba(229, 72, 77, 0.25);
  border-radius: 24px;
  padding: 56px 52px;
  overflow: hidden;
  box-shadow: 0 0 80px rgba(229, 72, 77, 0.16), inset 0 1px 0 rgba(255,255,255,0.04);
}
.tnb2-offer-card::before {
  content: ''; display: block; height: 2px; width: 100%;
  background: linear-gradient(90deg, transparent, rgba(248,113,113,.80), #e5484d, rgba(248,113,113,.80), transparent);
  background-size: 200% 100%;
  animation: tnb2-shimmer 3s linear infinite;
  position: absolute; top: 0; left: 0; right: 0; border-radius: 24px 24px 0 0;
}
@keyframes tnb2-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes tnb2-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-10px); }
}
@keyframes tnb2-star-twinkle {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.3); }
}

.tnb2-offer-glow-left {
  position: absolute; top: -60px; left: -60px;
  width: 320px; height: 320px; border-radius: 50%;
  background: radial-gradient(circle, rgba(229,72,77,0.20) 0%, transparent 70%);
  pointer-events: none;
}
.tnb2-offer-glow-right {
  position: absolute; bottom: -80px; right: -60px;
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(248,113,113,0.14) 0%, transparent 70%);
  pointer-events: none;
}
.tnb2-offer-stars { position: absolute; inset: 0; pointer-events: none; }
.tnb2-star { position: absolute; color: rgba(248,113,113,0.7); animation: tnb2-star-twinkle 3s ease-in-out infinite; }
.tnb2-star-1 { top: 12%; left: 48%; font-size: 1.1rem; animation-delay: 0s; }
.tnb2-star-2 { top: 8%;  right: 8%; font-size: 1.4rem; animation-delay: 0.6s; }
.tnb2-star-3 { bottom: 18%; left: 42%; font-size: 0.8rem; animation-delay: 1.1s; }
.tnb2-star-4 { top: 55%; right: 4%; font-size: 1rem; animation-delay: 1.7s; }

.tnb2-offer-img-col {
  flex: 0 0 280px;
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
}
.tnb2-offer-img {
  width: 100%; max-width: 270px; object-fit: contain;
  filter: drop-shadow(0 12px 40px rgba(229,72,77,0.40));
  animation: tnb2-float 4s ease-in-out infinite;
}
.tnb2-offer-content {
  flex: 1; position: relative; z-index: 2;
  display: flex; flex-direction: column; gap: 20px;
}
.tnb2-offer-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(229, 72, 77, 0.15); border: 1px solid rgba(229, 72, 77, 0.38);
  color: #f87171; font-size: 0.72rem; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 6px 18px; border-radius: 100px; width: fit-content;
}
.tnb2-offer-title {
  font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900;
  color: #ffffff; line-height: 1.15; margin: 0;
}
.tnb2-offer-free {
  background: linear-gradient(90deg, #e5484d, #f87171);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.tnb2-offer-pill {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid rgba(229,72,77,0.40); border-radius: 100px;
  padding: 7px 20px; color: #fca5a5;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 1.8px;
  text-transform: uppercase; width: fit-content;
}
.tnb2-offer-pill-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #e5484d; box-shadow: 0 0 6px rgba(229,72,77,0.8);
}
.tnb2-offer-desc {
  font-size: 0.96rem; color: #e0b8b8; line-height: 1.75; max-width: 600px; margin: 0;
}
.tnb2-offer-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
}
.tnb2-offer-feature {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(229,72,77,0.18);
  border-radius: 14px; padding: 18px 18px 14px;
  display: flex; flex-direction: column; gap: 10px;
  transition: border-color 0.3s, background 0.3s;
}
.tnb2-offer-feature:hover {
  border-color: rgba(229,72,77,0.45); background: rgba(229,72,77,0.07);
}
.tnb2-offer-feat-icon {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(229,72,77,0.18); border: 1px solid rgba(229,72,77,0.35);
  display: flex; align-items: center; justify-content: center;
  color: #f87171; font-size: 0.95rem;
}
.tnb2-offer-feature span { font-size: 0.88rem; font-weight: 700; color: #ffdede; line-height: 1.3; }
.tnb2-offer-feat-bar { width: 32px; height: 2px; border-radius: 2px; background: linear-gradient(90deg, #e5484d, #f87171); }

.tnb2-offer-modules-row { display: flex; flex-direction: column; gap: 10px; }
.tnb2-offer-modules-label {
  font-size: 0.82rem; color: #906868;
  display: flex; align-items: center; gap: 10px;
}
.tnb2-offer-modules-label::before, .tnb2-offer-modules-label::after {
  content: ''; flex: 1; height: 1px; background: rgba(229,72,77,0.25);
}
.tnb2-offer-modules-list { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 6px; }
.tnb2-offer-module { font-size: 0.83rem; color: #e0b8b8; display: flex; align-items: center; gap: 5px; }
.tnb2-offer-module i { color: #e5484d; }
.tnb2-offer-sep { color: rgba(229,72,77,0.4); font-size: 0.9rem; }

.tnb2-contact-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #e5484d 0%, #dc2626 100%);
  color: #fff; font-size: 0.88rem; font-weight: 800;
  letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;
  padding: 16px 36px; border-radius: 100px; width: fit-content;
  box-shadow: 0 8px 28px rgba(229,72,77,0.45);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.tnb2-contact-btn:hover {
  transform: translateY(-3px); box-shadow: 0 14px 40px rgba(229,72,77,0.65); color: #fff;
}

@media (max-width: 900px) {
  .tnb2-offer-card { flex-direction: column; padding: 40px 28px; gap: 32px; }
  .tnb2-offer-img-col { flex: none; width: 220px; }
  .tnb2-offer-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .tnb2-offer-title { font-size: 1.7rem; }
  .tnb2-offer-modules-list { flex-direction: column; align-items: flex-start; }
  .tnb2-offer-sep { display: none; }
}

/* Career CTA */
.tenable-page.tnb-v2-page .career-cta-section {
  position: relative; overflow: hidden;
  background: linear-gradient(rgba(8,1,2,0.85), rgba(14,2,3,0.9)), url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}
.tenable-page.tnb-v2-page .career-cta-section::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 20% 50%, rgba(229,72,77,0.14) 0%, transparent 60%), radial-gradient(ellipse at 80% 50%, rgba(229,72,77,0.09) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}
.tenable-page.tnb-v2-page .career-cta-section .career-cta-container { position: relative; z-index: 1; }
.tenable-page.tnb-v2-page .career-cta-section .career-cta-title {
  background: linear-gradient(135deg, #ffffff 0%, #f87171 60%, #ffffff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .tnb2-hero-inner { grid-template-columns: 1fr; padding: 80px 20px 30px; }
  .tnb2-right { display: none; }
  .tnb2-why-card-outer { grid-template-columns: 1fr; }
  .tnb2-why-panel-left { border-right: none; border-bottom: 1px solid rgba(229,72,77,.15); }
  .tnb2-port-top-row { grid-template-columns: 1fr 1fr; }
  .tnb2-port-bottom-row { grid-template-columns: 1fr; }
  .tnb2-ind-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .tnb2-port-top-row { grid-template-columns: 1fr; }
  .tnb2-ind-grid { grid-template-columns: 1fr; }
  .tnb2-why-stats-bar { flex-direction: column; gap: 8px; }
  .tnb2-why-stat-sep { display: none; }
  .tnb2-offer-banner { padding: 32px 20px; }
}
