@import './shared.css';

/* ================================================================
   VEEAM PREMIUM — FOREST GREEN EDITION
   Accent: #00b159  Secondary: #22c55e
   Structure mirrors Motadata v2. All class names prefixed veeam2-
   ================================================================ */

.veeam-page.veeam-v2-page { overflow-x: hidden; }

/* HERO */
.veeam-page .veeam2-hero,
section.veeam2-hero {
  background: linear-gradient(135deg, #020c05 0%, #041508 50%, #020c05 100%) !important;
  background-image: none !important;
  padding: 0 !important; overflow: hidden !important;
  position: relative; display: flex; align-items: center;
}

.veeam2-hero-glow-left {
  position: absolute; top: 0; left: 0; width: 50%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(0,177,89,.22) 0%, rgba(0,177,89,.08) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: veeam2-glow 7s ease-in-out infinite alternate;
}
.veeam2-hero-glow-right {
  position: absolute; bottom: 0; right: 0; width: 55%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(34,197,94,.16) 0%, rgba(0,177,89,.07) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: veeam2-glow 9s ease-in-out infinite alternate-reverse;
}
@keyframes veeam2-glow { 0%{opacity:.7}100%{opacity:1} }

.veeam2-hero-inner {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 52% 48%; gap: 24px; align-items: flex-start;
  padding: 90px 20px 20px; max-width: 1280px; margin: 0 auto; width: 100%;
}
.veeam2-headline { font-size: clamp(1.7rem,2.8vw,2.5rem); font-weight: 900; line-height: 1.12; color: #fff; letter-spacing: -.02em; margin-bottom: 6px; }
.veeam2-headline-accent { color: #00b159; display: block; }
.veeam2-headline-rule { width: 60px; height: 3px; background: linear-gradient(90deg,#00b159,#22c55e); border-radius: 2px; margin: 14px 0 20px; }
.veeam2-desc { font-size: .97rem; color: rgba(255,255,255,.75); line-height: 1.65; margin-bottom: 22px; max-width: 520px; }
.veeam2-desc-link { color: #22c55e; text-decoration: underline; }

.veeam2-feature-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.veeam2-feat { display: flex; align-items: flex-start; gap: 12px; }
.veeam2-feat-icon { min-width: 36px; height: 36px; background: rgba(0,177,89,.18); border: 1px solid rgba(0,177,89,.35); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: .85rem; }
.veeam2-feat-body { display: flex; flex-direction: column; }
.veeam2-feat-body strong { color: #fff; font-size: .88rem; font-weight: 700; }
.veeam2-feat-body span { color: rgba(255,255,255,.6); font-size: .78rem; }

.veeam2-stats-row { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
.veeam2-stat-card { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(0,177,89,.2); border-radius: 10px; padding: 10px 16px; }
.veeam2-stat-card i { color: #22c55e; font-size: 1.1rem; }
.veeam2-stat-num { display: block; font-size: 1.2rem; font-weight: 800; color: #fff; }
.veeam2-stat-lbl { display: block; font-size: .62rem; color: rgba(255,255,255,.5); letter-spacing: .06em; text-transform: uppercase; }
.veeam2-stat-brand { border-color: rgba(0,177,89,.35); }
.veeam2-brand-logo { width: 48px; height: 32px; object-fit: contain; border-radius: 4px; background: #fff; padding: 2px; }

.veeam2-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
.veeam2-btn-primary { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,#00b159,#22c55e); color: #fff; font-weight: 700; font-size: .88rem; padding: 12px 24px; border-radius: 8px; text-decoration: none; transition: opacity .2s; }
.veeam2-btn-primary:hover { opacity: .88; color: #fff; }
.veeam2-btn-ghost { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(0,177,89,.5); color: #22c55e; font-weight: 600; font-size: .88rem; padding: 12px 22px; border-radius: 8px; text-decoration: none; transition: background .2s; }
.veeam2-btn-ghost:hover { background: rgba(0,177,89,.12); color: #22c55e; }

.veeam2-right { position: relative; display: flex; flex-direction: column; gap: 16px; padding-top: 20px; }
.veeam2-product-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 420px; height: 420px; background: radial-gradient(circle,rgba(0,177,89,.25) 0%,transparent 70%); pointer-events: none; z-index: 0; }
.veeam2-showcase { position: relative; z-index: 2; display: flex; justify-content: center; align-items: flex-end; }
.veeam2-hero-product-img { max-width: 340px; width: 100%; object-fit: contain; filter: drop-shadow(0 12px 40px rgba(0,177,89,.45)); border-radius: 12px; }
.veeam2-industry-strip { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; background: rgba(255,255,255,.04); border: 1px solid rgba(0,177,89,.18); border-radius: 10px; padding: 12px 16px; z-index: 2; position: relative; }
.veeam2-ind-item { display: flex; align-items: center; gap: 5px; font-size: .74rem; color: rgba(255,255,255,.7); white-space: nowrap; }
.veeam2-ind-item i { color: #22c55e; }
.veeam2-ind-sep { width: 1px; height: 14px; background: rgba(255,255,255,.15); }

/* WHY CHOOSE */
.veeam2-why-section { background: #041508; padding: 70px 0 60px; }
.veeam2-why-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.veeam2-why-header { text-align: center; margin-bottom: 40px; }
.veeam2-why-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,177,89,.12); border: 1px solid rgba(0,177,89,.3); color: #22c55e; font-size: .7rem; font-weight: 700; letter-spacing: .1em; padding: 6px 18px; border-radius: 50px; margin-bottom: 16px; text-transform: uppercase; }
.veeam2-why-title { font-size: clamp(1.6rem,2.5vw,2.2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.veeam2-why-accent { color: #00b159; }
.veeam2-why-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 16px; }
.veeam2-why-title-rule { width: 48px; height: 3px; background: linear-gradient(90deg,#00b159,#22c55e); margin: 0 auto; border-radius: 2px; }

.veeam2-why-card-outer { display: grid; grid-template-columns: 1fr 1fr; background: rgba(255,255,255,.03); border: 1px solid rgba(0,177,89,.15); border-radius: 20px; overflow: hidden; margin-bottom: 32px; }
.veeam2-why-panel { padding: 36px 32px; position: relative; }
.veeam2-why-panel-left { border-right: 1px solid rgba(0,177,89,.15); }
.veeam2-why-icon-circle { width: 52px; height: 52px; background: rgba(0,177,89,.18); border: 1px solid rgba(0,177,89,.4); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: 1.2rem; margin-bottom: 12px; }
.veeam2-why-icon-alt { background: rgba(34,197,94,.12); border-color: rgba(34,197,94,.4); }
.veeam2-why-card-sup { font-size: .7rem; font-weight: 700; color: rgba(255,255,255,.4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 4px; }
.veeam2-why-card-title { font-size: 1.25rem; font-weight: 800; margin-bottom: 10px; color: #22c55e; }
.veeam2-why-card-title-alt { color: #86efac; }
.veeam2-why-card-desc { color: rgba(255,255,255,.65); font-size: .88rem; line-height: 1.6; margin-bottom: 16px; }
.veeam2-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.veeam2-why-list li { display: flex; align-items: flex-start; gap: 10px; color: rgba(255,255,255,.75); font-size: .85rem; }
.veeam2-why-list-icon { min-width: 28px; height: 28px; background: rgba(0,177,89,.12); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: .8rem; }
.veeam2-why-list-check-icon { color: #86efac; }
.veeam2-why-list li small { display: block; font-size: .75rem; color: rgba(255,255,255,.4); }

.veeam2-why-stats-bar { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; background: rgba(0,177,89,.08); border: 1px solid rgba(0,177,89,.2); border-radius: 14px; padding: 20px 28px; }
.veeam2-why-stat { display: flex; align-items: center; gap: 12px; padding: 8px 28px; }
.veeam2-why-stat-sep { width: 1px; height: 40px; background: rgba(255,255,255,.12); }
.veeam2-why-stat-icon { width: 38px; height: 38px; background: rgba(0,177,89,.18); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: .95rem; }
.veeam2-why-stat-text strong { display: block; color: #fff; font-size: .88rem; font-weight: 700; }
.veeam2-why-stat-text span { color: rgba(255,255,255,.5); font-size: .75rem; }

/* PORTFOLIO */
.veeam2-port-section { background: #020c05; padding: 70px 0; }
.veeam2-port-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.veeam2-port-header { text-align: center; margin-bottom: 40px; }
.veeam2-port-header-icon { width: 56px; height: 56px; background: rgba(0,177,89,.15); border: 1px solid rgba(0,177,89,.35); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: 1.3rem; margin: 0 auto 12px; }
.veeam2-port-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; margin-bottom: 8px; }
.veeam2-port-accent { color: #00b159; }
.veeam2-port-title-decor { display: flex; align-items: center; justify-content: center; gap: 8px; margin: 8px 0; }
.veeam2-port-decor-line { flex: 0 0 40px; height: 2px; background: linear-gradient(90deg,transparent,rgba(0,177,89,.5)); }
.veeam2-port-decor-dot { width: 8px; height: 8px; border-radius: 50%; background: #00b159; }
.veeam2-port-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; }
.veeam2-port-top-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 20px; }
.veeam2-port-card { background: rgba(255,255,255,.03); border: 1px solid rgba(0,177,89,.15); border-radius: 16px; overflow: hidden; transition: border-color .3s,transform .3s; }
.veeam2-port-card:hover { border-color: rgba(0,177,89,.5); transform: translateY(-4px); }
.veeam2-port-card-img { height: 140px; position: relative; }
.veeam2-port-img-a { background: linear-gradient(135deg,#041508,#0a2e10); }
.veeam2-port-img-b { background: linear-gradient(135deg,#021006,#062612); }
.veeam2-port-img-c { background: linear-gradient(135deg,#030e04,#052010); }
.veeam2-port-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(2,12,5,.9)); }
.veeam2-port-card-body { padding: 18px 20px; }
.veeam2-port-card-icon { width: 40px; height: 40px; background: rgba(0,177,89,.18); border: 1px solid rgba(0,177,89,.35); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: .9rem; margin-bottom: 10px; }
.veeam2-port-card-title { font-size: 1rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.veeam2-port-card-desc { color: rgba(255,255,255,.6); font-size: .82rem; line-height: 1.55; margin-bottom: 10px; }
.veeam2-port-list { list-style: none; padding: 0; margin: 0 0 12px; display: flex; flex-direction: column; gap: 5px; }
.veeam2-port-list li { color: rgba(255,255,255,.7); font-size: .8rem; display: flex; align-items: center; gap: 7px; }
.veeam2-port-list li i { color: #00b159; font-size: .75rem; }
.veeam2-port-link { color: #22c55e; font-size: .82rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
.veeam2-port-link:hover { gap: 10px; }
.veeam2-port-bottom-row { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; }
.veeam2-port-dc-card { background: rgba(255,255,255,.03); border: 1px solid rgba(0,177,89,.15); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.veeam2-port-dc-img { height: 120px; background: linear-gradient(135deg,#031006,#062016); position: relative; }
.veeam2-port-dc-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(2,12,5,.9)); }
.veeam2-port-dc-body { padding: 18px 20px; flex: 1; }
.veeam2-port-why-panel { background: rgba(0,177,89,.07); border: 1px solid rgba(0,177,89,.2); border-radius: 16px; padding: 24px 22px; }
.veeam2-port-why-title { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 18px; }
.veeam2-port-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }
.veeam2-port-why-item { display: flex; flex-direction: column; gap: 4px; }
.veeam2-port-why-icon { width: 32px; height: 32px; background: rgba(0,177,89,.18); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: .85rem; margin-bottom: 6px; }
.veeam2-port-why-item strong { color: #fff; font-size: .85rem; font-weight: 700; }
.veeam2-port-why-item span { color: rgba(255,255,255,.5); font-size: .77rem; line-height: 1.4; }
.veeam2-port-cta-bar { display: flex; align-items: center; gap: 14px; background: rgba(0,177,89,.1); border: 1px solid rgba(0,177,89,.25); border-radius: 10px; padding: 14px 16px; }
.veeam2-port-cta-icon { width: 36px; height: 36px; background: rgba(0,177,89,.25); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #22c55e; font-size: .95rem; flex-shrink: 0; }
.veeam2-port-cta-text { flex: 1; }
.veeam2-port-cta-text strong { display: block; color: #fff; font-size: .82rem; font-weight: 700; }
.veeam2-port-cta-text span { color: rgba(255,255,255,.5); font-size: .76rem; }
.veeam2-port-cta-btn { display: inline-flex; align-items: center; gap: 5px; background: linear-gradient(135deg,#00b159,#22c55e); color: #fff; font-size: .78rem; font-weight: 700; padding: 9px 16px; border-radius: 7px; text-decoration: none; white-space: nowrap; }

/* INDUSTRIES */
.veeam2-ind-section { background: #041508; padding: 70px 0; position: relative; overflow: hidden; }
.veeam2-ind-bg-glow { position: absolute; width: 400px; height: 400px; border-radius: 50%; pointer-events: none; z-index: 0; }
.veeam2-ind-bg-glow-left { top: -100px; left: -100px; background: radial-gradient(circle,rgba(0,177,89,.1) 0%,transparent 70%); }
.veeam2-ind-bg-glow-right { bottom: -100px; right: -100px; background: radial-gradient(circle,rgba(34,197,94,.08) 0%,transparent 70%); }
.veeam2-ind-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.veeam2-ind-header { text-align: center; margin-bottom: 40px; }
.veeam2-ind-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,177,89,.1); border: 1px solid rgba(0,177,89,.25); color: #22c55e; font-size: .68rem; font-weight: 700; letter-spacing: .1em; padding: 6px 16px; border-radius: 50px; margin-bottom: 14px; text-transform: uppercase; }
.veeam2-ind-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: #00b159; }
.veeam2-ind-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.veeam2-ind-accent { color: #00b159; }
.veeam2-ind-subtitle { color: rgba(255,255,255,.6); font-size: .92rem; }
.veeam2-ind-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
.veeam2-ind-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 22px; position: relative; overflow: hidden; transition: border-color .3s,transform .3s; }
.veeam2-ind-card:hover { transform: translateY(-4px); }
.veeam2-ind-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.veeam2-ind-icon-wrap { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: .95rem; }

.veeam2-ind-card-forest  { border-color: rgba(0,177,89,.25); }  .veeam2-ind-card-forest:hover  { border-color: rgba(0,177,89,.6); }
.veeam2-ind-icon-forest  { background: rgba(0,177,89,.18); color: #22c55e; }
.veeam2-ind-rule-forest  { height: 2px; background: linear-gradient(90deg,#00b159,transparent); margin-bottom: 10px; border-radius: 1px; }
.veeam2-ind-arrow-forest { color: #22c55e; }

.veeam2-ind-card-green   { border-color: rgba(34,197,94,.25); }  .veeam2-ind-card-green:hover   { border-color: rgba(34,197,94,.6); }
.veeam2-ind-icon-green   { background: rgba(34,197,94,.18); color: #4ade80; }
.veeam2-ind-rule-green   { height: 2px; background: linear-gradient(90deg,#22c55e,transparent); margin-bottom: 10px; border-radius: 1px; }
.veeam2-ind-arrow-green  { color: #4ade80; }

.veeam2-ind-card-emerald { border-color: rgba(16,185,129,.25); } .veeam2-ind-card-emerald:hover { border-color: rgba(16,185,129,.6); }
.veeam2-ind-icon-emerald { background: rgba(16,185,129,.18); color: #34d399; }
.veeam2-ind-rule-emerald { height: 2px; background: linear-gradient(90deg,#10b981,transparent); margin-bottom: 10px; border-radius: 1px; }
.veeam2-ind-arrow-emerald{ color: #34d399; }

.veeam2-ind-card-lime    { border-color: rgba(132,204,22,.25); } .veeam2-ind-card-lime:hover    { border-color: rgba(132,204,22,.6); }
.veeam2-ind-icon-lime    { background: rgba(132,204,22,.18); color: #bef264; }
.veeam2-ind-rule-lime    { height: 2px; background: linear-gradient(90deg,#84cc16,transparent); margin-bottom: 10px; border-radius: 1px; }
.veeam2-ind-arrow-lime   { color: #bef264; }

.veeam2-ind-card-teal    { border-color: rgba(20,184,166,.25); } .veeam2-ind-card-teal:hover    { border-color: rgba(20,184,166,.6); }
.veeam2-ind-icon-teal    { background: rgba(20,184,166,.18); color: #2dd4bf; }
.veeam2-ind-rule-teal    { height: 2px; background: linear-gradient(90deg,#14b8a6,transparent); margin-bottom: 10px; border-radius: 1px; }
.veeam2-ind-arrow-teal   { color: #2dd4bf; }

.veeam2-ind-card-sage    { border-color: rgba(101,163,13,.25); } .veeam2-ind-card-sage:hover    { border-color: rgba(101,163,13,.6); }
.veeam2-ind-icon-sage    { background: rgba(101,163,13,.18); color: #a3e635; }
.veeam2-ind-rule-sage    { height: 2px; background: linear-gradient(90deg,#65a30d,transparent); margin-bottom: 10px; border-radius: 1px; }
.veeam2-ind-arrow-sage   { color: #a3e635; }

.veeam2-ind-num { font-size: 1.3rem; font-weight: 900; color: rgba(255,255,255,.08); }
.veeam2-ind-card-title { font-size: .95rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.veeam2-ind-card-desc { color: rgba(255,255,255,.6); font-size: .8rem; line-height: 1.5; margin-bottom: 12px; }
.veeam2-ind-arrow { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); text-decoration: none; transition: background .2s; }
.veeam2-ind-arrow:hover { background: rgba(255,255,255,.12); }
.veeam2-ind-card-bg-pattern { position: absolute; right: -20px; bottom: -20px; width: 80px; height: 80px; border-radius: 50%; background: rgba(0,177,89,.04); pointer-events: none; }

/* ── SPECIAL OFFER — Greythr-style two-column card ── */
.veeam2-special-offer { padding: 80px 0 100px; position: relative; }

.veeam2-offer-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 48px;
  background: linear-gradient(135deg, #020c05 0%, #051a0a 50%, #030e06 100%);
  border: 1px solid rgba(0, 177, 89, 0.25);
  border-radius: 24px;
  padding: 56px 52px;
  overflow: hidden;
  box-shadow: 0 0 80px rgba(0, 177, 89, 0.16), inset 0 1px 0 rgba(255,255,255,0.04);
}
.veeam2-offer-card::before {
  content: ''; display: block; height: 2px; width: 100%;
  background: linear-gradient(90deg, transparent, rgba(34,197,94,.80), #00b159, rgba(34,197,94,.80), transparent);
  background-size: 200% 100%;
  animation: veeam2-shimmer 3s linear infinite;
  position: absolute; top: 0; left: 0; right: 0; border-radius: 24px 24px 0 0;
}
@keyframes veeam2-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes veeam2-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-10px); }
}
@keyframes veeam2-star-twinkle {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.3); }
}

.veeam2-offer-glow-left {
  position: absolute; top: -60px; left: -60px;
  width: 320px; height: 320px; border-radius: 50%;
  background: radial-gradient(circle, rgba(0,177,89,0.20) 0%, transparent 70%);
  pointer-events: none;
}
.veeam2-offer-glow-right {
  position: absolute; bottom: -80px; right: -60px;
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(34,197,94,0.14) 0%, transparent 70%);
  pointer-events: none;
}
.veeam2-offer-stars { position: absolute; inset: 0; pointer-events: none; }
.veeam2-star { position: absolute; color: rgba(34,197,94,0.7); animation: veeam2-star-twinkle 3s ease-in-out infinite; }
.veeam2-star-1 { top: 12%; left: 48%; font-size: 1.1rem; animation-delay: 0s; }
.veeam2-star-2 { top: 8%;  right: 8%; font-size: 1.4rem; animation-delay: 0.6s; }
.veeam2-star-3 { bottom: 18%; left: 42%; font-size: 0.8rem; animation-delay: 1.1s; }
.veeam2-star-4 { top: 55%; right: 4%; font-size: 1rem; animation-delay: 1.7s; }

.veeam2-offer-img-col {
  flex: 0 0 280px;
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
}
.veeam2-offer-img {
  width: 100%; max-width: 270px; object-fit: contain;
  filter: drop-shadow(0 12px 40px rgba(0,177,89,0.40));
  animation: veeam2-float 4s ease-in-out infinite;
}
.veeam2-offer-content {
  flex: 1; position: relative; z-index: 2;
  display: flex; flex-direction: column; gap: 20px;
}
.veeam2-offer-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(0, 177, 89, 0.15); border: 1px solid rgba(0, 177, 89, 0.38);
  color: #22c55e; font-size: 0.72rem; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 6px 18px; border-radius: 100px; width: fit-content;
}
.veeam2-offer-title {
  font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900;
  color: #ffffff; line-height: 1.15; margin: 0;
}
.veeam2-offer-free {
  background: linear-gradient(90deg, #00b159, #22c55e);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.veeam2-offer-pill {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid rgba(0,177,89,0.40); border-radius: 100px;
  padding: 7px 20px; color: #86efac;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 1.8px;
  text-transform: uppercase; width: fit-content;
}
.veeam2-offer-pill-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #00b159; box-shadow: 0 0 6px rgba(0,177,89,0.8);
}
.veeam2-offer-desc {
  font-size: 0.96rem; color: #b8d8c4; line-height: 1.75; max-width: 600px; margin: 0;
}
.veeam2-offer-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
}
.veeam2-offer-feature {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(0,177,89,0.18);
  border-radius: 14px; padding: 18px 18px 14px;
  display: flex; flex-direction: column; gap: 10px;
  transition: border-color 0.3s, background 0.3s;
}
.veeam2-offer-feature:hover {
  border-color: rgba(0,177,89,0.45); background: rgba(0,177,89,0.07);
}
.veeam2-offer-feat-icon {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(0,177,89,0.18); border: 1px solid rgba(0,177,89,0.35);
  display: flex; align-items: center; justify-content: center;
  color: #22c55e; font-size: 0.95rem;
}
.veeam2-offer-feature span { font-size: 0.88rem; font-weight: 700; color: #d4f0e0; line-height: 1.3; }
.veeam2-offer-feat-bar { width: 32px; height: 2px; border-radius: 2px; background: linear-gradient(90deg, #00b159, #22c55e); }

.veeam2-offer-modules-row { display: flex; flex-direction: column; gap: 10px; }
.veeam2-offer-modules-label {
  font-size: 0.82rem; color: #6a9070;
  display: flex; align-items: center; gap: 10px;
}
.veeam2-offer-modules-label::before, .veeam2-offer-modules-label::after {
  content: ''; flex: 1; height: 1px; background: rgba(0,177,89,0.25);
}
.veeam2-offer-modules-list { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 6px; }
.veeam2-offer-module { font-size: 0.83rem; color: #b8d8c4; display: flex; align-items: center; gap: 5px; }
.veeam2-offer-module i { color: #00b159; }
.veeam2-offer-sep { color: rgba(0,177,89,0.4); font-size: 0.9rem; }

.veeam2-contact-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #00b159 0%, #16a34a 100%);
  color: #fff; font-size: 0.88rem; font-weight: 800;
  letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;
  padding: 16px 36px; border-radius: 100px; width: fit-content;
  box-shadow: 0 8px 28px rgba(0,177,89,0.45);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.veeam2-contact-btn:hover {
  transform: translateY(-3px); box-shadow: 0 14px 40px rgba(0,177,89,0.65); color: #fff;
}

@media (max-width: 900px) {
  .veeam2-offer-card { flex-direction: column; padding: 40px 28px; gap: 32px; }
  .veeam2-offer-img-col { flex: none; width: 220px; }
  .veeam2-offer-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .veeam2-offer-title { font-size: 1.7rem; }
  .veeam2-offer-modules-list { flex-direction: column; align-items: flex-start; }
  .veeam2-offer-sep { display: none; }
}

/* Career CTA */
.veeam-page.veeam-v2-page .career-cta-section {
  position: relative; overflow: hidden;
  background: linear-gradient(rgba(1,6,2,0.85), rgba(2,12,5,0.9)), url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}
.veeam-page.veeam-v2-page .career-cta-section::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 20% 50%, rgba(0,177,89,0.14) 0%, transparent 60%), radial-gradient(ellipse at 80% 50%, rgba(0,177,89,0.09) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}
.veeam-page.veeam-v2-page .career-cta-section .career-cta-container { position: relative; z-index: 1; }
.veeam-page.veeam-v2-page .career-cta-section .career-cta-title {
  background: linear-gradient(135deg, #ffffff 0%, #22c55e 60%, #ffffff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .veeam2-hero-inner { grid-template-columns: 1fr; padding: 80px 20px 30px; }
  .veeam2-right { display: none; }
  .veeam2-why-card-outer { grid-template-columns: 1fr; }
  .veeam2-why-panel-left { border-right: none; border-bottom: 1px solid rgba(0,177,89,.15); }
  .veeam2-port-top-row { grid-template-columns: 1fr 1fr; }
  .veeam2-port-bottom-row { grid-template-columns: 1fr; }
  .veeam2-ind-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .veeam2-port-top-row { grid-template-columns: 1fr; }
  .veeam2-ind-grid { grid-template-columns: 1fr; }
  .veeam2-why-stats-bar { flex-direction: column; gap: 8px; }
  .veeam2-why-stat-sep { display: none; }
  .veeam2-offer-banner { padding: 32px 20px; }
}
