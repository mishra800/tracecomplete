              <div className="hpe2-ind-card" key={item.num} data-aos="fade-up" data-aos-duration="700">
                <div className="hpe2-ind-card-top">
                  <div className="hpe2-ind-icon-wrap"><i className={item.icon}></i></div>
                  <span className="hpe2-ind-num">{item.num}</span>
                </div>
                <div className="hpe2-ind-num-rule"></div>
                <h3 className="hpe2-ind-card-title">{item.title}</h3>
                <p className="hpe2-ind-card-desc">{item.desc}</p>
                <a href="/contact-us" className="hpe2-ind-arrow" aria-label={`Learn more about ${item.title}`}>
                  <i className="fas fa-arrow-right"></i>
                </a>
                <div className="hpe2-ind-card-bg-pattern" aria-hidden="true"></div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Use Cases Slider */}
      <UseCaseSlider
        useCases={hpeUseCases}
        partnerColor="#00b08b"
        title="HPE Server Use Cases"
        subtitle="Successful Deployments by Trace Network across diverse industry sectors"
