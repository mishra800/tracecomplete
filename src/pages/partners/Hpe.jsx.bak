              <div className="hpe2-offer-pill">
                <span className="hpe2-offer-pill-dot"></span>
                EXCLUSIVE OFFERS ON HPE SERVER &amp; INFRASTRUCTURE SOLUTIONS
                <span className="hpe2-offer-pill-dot"></span>
              </div>

              <p className="hpe2-offer-desc">
                Experience the power of HPE servers firsthand — zero risk, zero commitment.
                Our certified team will set up a complete proof of concept tailored to your
                infrastructure environment so you can see the results before you invest.
              </p>

              {/* Feature grid */}
              <div className="hpe2-offer-grid">
                {[
                  { icon: 'fas fa-server',          label: 'FREE Infrastructure POC'          },
                  { icon: 'fas fa-desktop',          label: 'Guided Server Demo'               },
                  { icon: 'fas fa-sliders-h',        label: 'Tailored Migration Consultation'  },
                  { icon: 'fas fa-headset',          label: 'Priority Implementation Support'  },
                ].map((pt) => (
                  <div className="hpe2-offer-feature" key={pt.label}>
                    <div className="hpe2-offer-feat-icon">
                      <i className={pt.icon}></i>
                    </div>
                    <span>{pt.label}</span>
                    <div className="hpe2-offer-feat-bar"></div>
                  </div>
                ))}
              </div>

              {/* Modules row */}
              <div className="hpe2-offer-modules-row">
                <span className="hpe2-offer-modules-label">Get Expert Guidance for:</span>
                <div className="hpe2-offer-modules-list">
                  {['ProLiant Rack Servers', 'Tower Servers', 'Hybrid Cloud', 'Storage & Data Mgmt'].map((m, i) => (
                    <React.Fragment key={m}>
                      <span className="hpe2-offer-module">
                        <i className="fas fa-check-circle"></i> {m}
                      </span>
                      {i < 3 && <span className="hpe2-offer-sep">|</span>}
                    </React.Fragment>
                  ))}
                </div>
              </div>

              <Link to="/contact-us" className="hpe2-contact-btn">
                <i className="fas fa-paper-plane"></i>
                &nbsp; CONTACT TRACE NETWORK &nbsp;&#8594;
              </Link>

            </div>
