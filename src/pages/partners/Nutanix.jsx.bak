            <div className="premium-service-card"><div className="premium-icon-wrapper"><img src="/assets/images/iso-certificate.png" alt="iso-certificate" /></div><p><strong>ISO 27001-Certified Cybersecurity Provider</strong> Following stringent change management and compliance practices.</p></div>
            <div className="premium-service-card"><div className="premium-icon-wrapper"><img src="/assets/images/frame.png" alt="frame" /></div><p><strong>Proven Deployment Framework</strong> Assess → Design → Deploy → Optimise → Support ensures maximum ROI.</p></div>
            <div className="premium-service-card"><div className="premium-icon-wrapper"><img src="/assets/images/agile.png" alt="agile" /></div><p><strong>Flexible MSSP &amp; Security Pricing Models</strong> CapEx, OpEx, or MSSP models to align with your business goals.</p></div>
          </div>
        </div>
      </section>

      {/* Career CTA */}
      <section className="career-cta-section">
        <div className="career-cta-container">
          <h2 className="career-cta-title">Ready to Modernize Your IT Infrastructure?</h2>
          <p className="career-cta-text">Speak with a senior HCI consultant today. In 30 minutes you'll know:<br /><br />&#8226; Infrastructure bottlenecks holding your business back<br />&#8226; Quick wins to reduce TCO and improve uptime<br />&#8226; An exact timeline &amp; cost estimate&mdash;no obligations</p>
          <div className="about-two__btn-box"><a href="tel:7032224513" className="btn-get-started"><span className="btn-text">Book Your Free Strategy Call </span><span className="btn-arrow"></span></a></div>
        </div>
      </section>

      {/* Special Offer */}
      <section className="ntx2-special-offer" data-aos="fade-up" data-aos-duration="900">
        <div className="container">
          <div className="ntx2-offer-card">

            {/* Glows */}
            <div className="ntx2-offer-glow-left"  aria-hidden="true"></div>
            <div className="ntx2-offer-glow-right" aria-hidden="true"></div>
            <div className="ntx2-offer-stars"      aria-hidden="true">
              <span className="ntx2-star ntx2-star-1">&#10022;</span>
              <span className="ntx2-star ntx2-star-2">&#10022;</span>
              <span className="ntx2-star ntx2-star-3">&#10022;</span>
              <span className="ntx2-star ntx2-star-4">&#10022;</span>
            </div>

            {/* LEFT — image */}
            <div className="ntx2-offer-img-col">
              <img
                src="/assets/images/partners/nutanix.png"
                alt="Nutanix HCI Platform"
                className="ntx2-offer-img"
              />
            </div>

            {/* RIGHT — content */}
            <div className="ntx2-offer-content">

              <div className="ntx2-offer-badge">
                <i className="fas fa-gift"></i>&nbsp; SPECIAL OFFER
              </div>

              <h2 className="ntx2-offer-title">
                <span className="ntx2-offer-free">FREE</span> POC &amp; Assessment
              </h2>

              <div className="ntx2-offer-pill">
                <span className="ntx2-offer-pill-dot"></span>
                EXCLUSIVE OFFERS ON NUTANIX HCI SOLUTIONS
                <span className="ntx2-offer-pill-dot"></span>
              </div>

              <p className="ntx2-offer-desc">
                Experience the power of Nutanix hyperconverged infrastructure firsthand — zero risk, zero commitment.
                Our certified team will set up a complete proof of concept tailored to your environment so you can
                see measurable results before you invest.
              </p>

              {/* Feature grid */}
              <div className="ntx2-offer-grid">
                {[
                  { icon: 'fas fa-flask',          label: 'FREE HCI Proof of Concept'        },
                  { icon: 'fas fa-desktop',         label: 'Guided Platform Demo'             },
                  { icon: 'fas fa-people-arrows',   label: 'Seamless Migration Consultation'  },
                  { icon: 'fas fa-headset',         label: 'Priority Implementation Support'  },
                ].map((pt) => (
                  <div className="ntx2-offer-feature" key={pt.label}>
                    <div className="ntx2-offer-feat-icon">
                      <i className={pt.icon}></i>
                    </div>
                    <span>{pt.label}</span>
                    <div className="ntx2-offer-feat-bar"></div>
                  </div>
                ))}
              </div>

              {/* Modules row */}
              <div className="ntx2-offer-modules-row">
                <span className="ntx2-offer-modules-label">Get Expert Guidance for:</span>
                <div className="ntx2-offer-modules-list">
                  {['HCI Infrastructure', 'Cloud & Hybrid', 'Unified Storage', 'AI & Data Platform'].map((m, i) => (
                    <React.Fragment key={m}>
                      <span className="ntx2-offer-module">
                        <i className="fas fa-check-circle"></i> {m}
                      </span>
                      {i < 3 && <span className="ntx2-offer-sep">|</span>}
                    </React.Fragment>
                  ))}
                </div>
              </div>

              <Link to="/contact-us" className="ntx2-contact-btn">
                <i className="fas fa-paper-plane"></i>
                &nbsp; CONTACT TRACE NETWORK &nbsp;&#8594;
              </Link>

            </div>
          </div>
        </div>
      </section>

    </div>
  );
}
