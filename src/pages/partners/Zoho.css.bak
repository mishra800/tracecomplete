@import './shared.css';

/* ================================================================
   ZOHO PREMIUM — RED-ORANGE EDITION
   Accent: #e8232a   Secondary: #ff5a5a
   ================================================================ */

.zoho-page.zh2-page { overflow-x: hidden; }

.zoho-page .zh2-hero, section.zh2-hero {
  background: linear-gradient(135deg, #040d1e 0%, #0a0508 50%, #040d1e 100%) !important;
  padding: 0 !important; overflow: hidden !important; min-height: unset !important;
}
.zh2-hero { position: relative; display: flex; align-items: center; overflow: hidden; }
.zh2-hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.zh2-hero-glow-left { position: absolute; top: 0; left: 0; width: 50%; height: 100%; z-index: 0; pointer-events: none; background: radial-gradient(ellipse at center, rgba(232,35,42,0.22) 0%, rgba(180,0,10,0.10) 50%, transparent 80%); animation: zh2-glow-pulse 7s ease-in-out infinite alternate; }
.zh2-hero-glow-right { position: absolute; bottom: 0; right: 0; width: 55%; height: 100%; z-index: 0; pointer-events: none; background: radial-gradient(ellipse at center, rgba(232,35,42,0.16) 0%, rgba(180,0,10,0.08) 50%, transparent 80%); animation: zh2-glow-pulse 9s ease-in-out infinite alternate-reverse; }
@keyframes zh2-glow-pulse { 0% { opacity: 0.7; } 100% { opacity: 1; } }
.zh2-hero-inner { position: relative; z-index: 2; display: grid; grid-template-columns: 52% 48%; gap: 24px; align-items: flex-start; padding: 90px 20px 20px; max-width: 1280px; margin: 0 auto; width: 100%; }
.zh2-headline { font-size: clamp(1.7rem,2.8vw,2.5rem); font-weight: 900; line-height: 1.12; color: #fff; letter-spacing: -0.02em; margin-bottom: 6px; }
.zh2-headline-accent { color: #e8232a; display: block; }
.zh2-headline-rule { width: 40px; height: 3px; background: #e8232a; border-radius: 2px; margin: 10px 0 12px; }
.zh2-desc { font-size: 0.88rem; color: #b0c8e8; line-height: 1.6; max-width: 480px; margin-bottom: 14px; }
.zh2-desc-link { color: #ff5a5a; text-decoration: none; font-weight: 600; }
.zh2-desc-link:hover { text-decoration: underline; }
.zh2-feature-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 14px; }
.zh2-feat { display: flex; flex-direction: column; gap: 4px; padding: 10px; border-radius: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(232,35,42,0.15); transition: border-color 0.3s, background 0.3s; }
.zh2-feat:hover { border-color: rgba(232,35,42,0.35); background: rgba(180,0,10,0.08); }
.zh2-feat-icon { width: 34px; height: 34px; border-radius: 8px; background: rgba(232,35,42,0.2); border: 1px solid rgba(232,35,42,0.3); display: flex; align-items: center; justify-content: center; margin-bottom: 4px; }
.zh2-feat-icon i { font-size: 0.85rem; color: #ff5a5a; }
.zh2-feat-body strong { display: block; font-size: 0.82rem; font-weight: 700; color: #dce8ff; margin-bottom: 2px; }
.zh2-feat-body span { font-size: 0.72rem; color: #6888aa; line-height: 1.4; }
.zh2-stats-row { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
.zh2-stat-card { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(232,35,42,0.2); backdrop-filter: blur(8px); min-width: 100px; flex: 1; }
.zh2-stat-card > i { font-size: 1.2rem; color: #e8232a; flex-shrink: 0; }
.zh2-stat-card > div { display: flex; flex-direction: column; gap: 2px; }
.zh2-stat-num { font-size: 1.4rem; font-weight: 900; color: #fff; letter-spacing: -0.02em; line-height: 1; }
.zh2-stat-lbl { font-size: 0.6rem; font-weight: 700; color: #5a7aa0; letter-spacing: 0.8px; text-transform: uppercase; line-height: 1.4; }
.zh2-stat-brand { border-color: rgba(232,35,42,0.3); background: rgba(232,35,42,0.07); flex-direction: column; align-items: flex-start; gap: 4px; }
.zh2-brand-logo { width: 90px; height: auto; object-fit: contain; border-radius: 6px; display: block; }
.zh2-cta-row { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
.zh2-btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 50px; background: linear-gradient(135deg, #aa0008 0%, #e8232a 60%, #ff5a5a 100%); background-size: 200% auto; color: #fff; font-size: 0.85rem; font-weight: 700; text-decoration: none; box-shadow: 0 6px 24px rgba(232,35,42,0.4); transition: all 0.4s ease; }
.zh2-btn-primary:hover { background-position: right center; transform: translateY(-3px); box-shadow: 0 12px 36px rgba(232,35,42,0.6); color: #fff; }
.zh2-btn-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 11px 18px; border-radius: 50px; background: transparent; border: 1px solid rgba(255,255,255,0.18); color: #c0d4f0; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: all 0.3s ease; }
.zh2-btn-ghost:hover { border-color: rgba(232,35,42,0.5); background: rgba(232,35,42,0.08); color: #fff; transform: translateY(-2px); }
.zh2-industry-strip { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; padding: 12px 12px 6px; border-top: 1px solid rgba(232,35,42,0.2); row-gap: 8px; width: 100%; max-width: 520px; margin-top: 12px; position: relative; z-index: 3; }
.zh2-ind-item { display: inline-flex; align-items: center; gap: 8px; font-size: 0.92rem; font-weight: 600; color: #c8e8ff; padding: 4px 12px; white-space: nowrap; }
.zh2-ind-item i { font-size: 1.05rem; color: #e8232a; }
.zh2-ind-item:hover { color: #fff; }
.zh2-ind-sep { width: 1px; height: 16px; background: rgba(232,35,42,0.25); flex-shrink: 0; }
.zh2-right { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; margin-top: -10px; }
.zh2-product-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 85% 70% at 55% 50%, rgba(232,35,42,0.28) 0%, rgba(180,0,10,0.12) 50%, transparent 80%); pointer-events: none; z-index: 0; animation: zh2-glow-breathe 6s ease-in-out infinite; }
@keyframes zh2-glow-breathe { 0%,100% { opacity: 0.8; } 50% { opacity: 1; } }
.zh2-showcase { position: relative; width: 440px; z-index: 2; display: flex; align-items: center; justify-content: center; }
.zh2-hero-product-img { width: 100%; max-width: 380px; height: auto; object-fit: contain; display: block; position: relative; z-index: 2; border-radius: 12px; filter: drop-shadow(0 30px 60px rgba(0,0,0,0.7)) drop-shadow(0 0 60px rgba(232,35,42,0.3)); animation: zh2-float 6s ease-in-out infinite; }
@keyframes zh2-float { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-14px) scale(1.012); } }
.zh2-platform { position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); width: 360px; height: 90px; pointer-events: none; z-index: 1; }
.zh2-plat-ring { position: absolute; left: 50%; transform: translateX(-50%); bottom: 0; border-radius: 50%; border: 1px solid rgba(232,35,42,0.3); animation: zh2-ring-pulse 4s ease-in-out infinite; }
.zh2-plat-ring-1 { width: 360px; height: 44px; background: radial-gradient(ellipse at 50% 80%, rgba(232,35,42,0.18) 0%, transparent 70%); }
.zh2-plat-ring-2 { width: 240px; height: 28px; background: radial-gradient(ellipse at 50% 80%, rgba(232,35,42,0.28) 0%, transparent 70%); animation-delay: 0.5s; }
.zh2-plat-ring-3 { width: 130px; height: 16px; background: radial-gradient(ellipse at 50% 80%, rgba(232,35,42,0.55) 0%, transparent 70%); animation-delay: 1s; }
.zh2-plat-surface { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 2px; height: 60px; background: linear-gradient(to top, rgba(232,35,42,0.7), transparent); filter: blur(3px); }
@keyframes zh2-ring-pulse { 0%,100% { opacity: 0.5; } 50% { opacity: 1; } }
@media (max-width:1100px) { .zh2-hero-inner { grid-template-columns: 1fr; padding: 50px 20px 60px; } .zh2-right { justify-content: center; margin-top: 0; } }
@media (max-width:768px) { .zh2-hero-inner { padding: 90px 16px 32px; } .zh2-feature-row { grid-template-columns: 1fr; } .zh2-cta-row { flex-direction: column; align-items: flex-start; } .zh2-btn-primary, .zh2-btn-ghost { width: 100%; justify-content: center; } }

/* WHY SECTION */
.zh2-why-section { background: #040d1e; padding: 90px 0 0; position: relative; overflow: hidden; }
.zh2-why-section::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 900px; height: 500px; background: radial-gradient(ellipse at 50% 0%, rgba(232,35,42,0.1) 0%, transparent 70%); pointer-events: none; }
.zh2-why-container { max-width: 1180px; margin: 0 auto; padding: 0 24px 80px; }
.zh2-why-header { text-align: center; margin-bottom: 48px; }
.zh2-why-badge { display: inline-flex; align-items: center; gap: 10px; padding: 9px 22px; border-radius: 50px; border: 1px solid rgba(232,35,42,0.35); background: rgba(160,0,10,0.18); backdrop-filter: blur(10px); font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #fca5a5; margin-bottom: 28px; }
.zh2-why-badge i { color: #e8232a; font-size: 0.85rem; }
.zh2-why-title { font-size: clamp(2rem,4vw,3.2rem); font-weight: 900; line-height: 1.15; color: #fff; letter-spacing: -0.02em; margin-bottom: 16px; }
.zh2-why-accent { color: #e8232a; }
.zh2-why-subtitle { font-size: 1rem; color: #8aaac8; margin-bottom: 20px; }
.zh2-why-title-rule { width: 60px; height: 3px; background: linear-gradient(90deg, #e8232a, #ff5a5a); border-radius: 2px; margin: 0 auto; }
.zh2-why-card-outer { display: grid; grid-template-columns: 1fr auto 1fr; background: rgba(255,255,255,0.03); border: 1px solid rgba(232,35,42,0.15); border-radius: 20px; overflow: hidden; min-height: 440px; backdrop-filter: blur(6px); box-shadow: 0 30px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05); }
.zh2-why-panel { position: relative; display: flex; overflow: hidden; }
.zh2-why-panel-left, .zh2-why-panel-right { flex-direction: row; align-items: stretch; }
.zh2-why-img-wrap { position: relative; flex-shrink: 0; }
.zh2-why-img-right { width: 180px; overflow: hidden; }
.zh2-why-img-gradient-right { position: absolute; inset: 0; background: linear-gradient(to left, transparent 0%, rgba(8,20,50,0.7) 100%); pointer-events: none; z-index: 2; }
.zh2-why-server-bg { position: absolute; inset: 0; background: linear-gradient(160deg, rgba(20,0,5,0.9) 0%, rgba(4,2,8,0.98) 100%), repeating-linear-gradient(90deg, transparent, transparent 18px, rgba(232,35,42,0.04) 18px, rgba(232,35,42,0.04) 20px); z-index: 1; }
.zh2-why-content { flex: 1; padding: 40px 36px 40px 32px; position: relative; z-index: 3; }
.zh2-why-panel-right .zh2-why-content { padding: 40px 32px 40px 36px; }
.zh2-why-icon-row { margin-bottom: 16px; }
.zh2-why-icon-circle { width: 52px; height: 52px; border-radius: 14px; background: rgba(232,35,42,0.18); border: 1px solid rgba(232,35,42,0.3); display: flex; align-items: center; justify-content: center; }
.zh2-why-icon-circle i { font-size: 1.2rem; color: #ff5a5a; }
.zh2-why-icon-teal { background: rgba(0,130,130,0.2); border-color: rgba(0,200,200,0.25); }
.zh2-why-icon-teal i { color: #00d4e0; }
.zh2-why-card-sup { font-size: 0.78rem; font-weight: 600; color: #607a9a; margin-bottom: 2px; }
.zh2-why-card-title { font-size: 1.3rem; font-weight: 800; line-height: 1.2; margin-bottom: 14px; }
.zh2-why-card-title-red { color: #e8232a; }
.zh2-why-card-title-teal { color: #00c8d8; }
.zh2-why-card-desc { font-size: 0.85rem; color: #8aaac8; line-height: 1.7; margin-bottom: 20px; }
.zh2-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px; }
.zh2-why-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 0.84rem; color: #c8ddf4; line-height: 1.4; }
.zh2-why-list li small { display: block; color: #6888aa; font-size: 0.77rem; }
.zh2-why-list-icon { flex-shrink: 0; width: 30px; height: 30px; border-radius: 8px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.2); display: flex; align-items: center; justify-content: center; margin-top: 1px; }
.zh2-why-list-icon i { font-size: 0.75rem; color: #ff5a5a; }
.zh2-why-list-check-icon { background: rgba(0,160,120,0.15); border-color: rgba(0,200,160,0.2); }
.zh2-why-list-check-icon i { color: #00d4a0; }
.zh2-why-divider { width: 1px; background: linear-gradient(to bottom, transparent 5%, rgba(232,35,42,0.25) 25%, rgba(232,35,42,0.35) 50%, rgba(232,35,42,0.25) 75%, transparent 95%); flex-shrink: 0; align-self: stretch; }
.zh2-why-stats-bar { display: flex; align-items: center; justify-content: center; gap: 0; margin-top: 32px; background: rgba(255,255,255,0.025); border: 1px solid rgba(232,35,42,0.12); border-radius: 16px; padding: 22px 32px; flex-wrap: wrap; row-gap: 20px; }
.zh2-why-stat { display: flex; align-items: center; gap: 14px; flex: 1; justify-content: center; min-width: 160px; }
.zh2-why-stat-icon { width: 44px; height: 44px; border-radius: 12px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.zh2-why-stat-icon i { font-size: 1rem; color: #ff5a5a; }
.zh2-why-stat-text { display: flex; flex-direction: column; gap: 2px; }
.zh2-why-stat-text strong { font-size: 0.95rem; font-weight: 700; color: #dce8ff; }
.zh2-why-stat-text span { font-size: 0.75rem; color: #5a7aa0; }
.zh2-why-stat-sep { width: 1px; height: 40px; background: rgba(232,35,42,0.18); flex-shrink: 0; margin: 0 8px; }
@media (max-width:1024px) { .zh2-why-card-outer { grid-template-columns: 1fr; } .zh2-why-divider { width: 100%; height: 1px; background: linear-gradient(to right, transparent 5%, rgba(232,35,42,0.25) 50%, transparent 95%); } .zh2-why-img-right { display: none; } }
@media (max-width:768px) { .zh2-why-section { padding: 60px 0 0; } .zh2-why-container { padding: 0 16px 60px; } .zh2-why-content { padding: 24px 20px; } .zh2-why-stat-sep { display: none; } .zh2-why-stat { min-width: 130px; flex: 0 0 calc(50% - 12px); } }

/* PORTFOLIO */
.zh2-port-section { background: #040d1e; padding: 80px 0 90px; position: relative; overflow: hidden; }
.zh2-port-section::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 400px; background: radial-gradient(ellipse at 50% 0%, rgba(232,35,42,0.08) 0%, transparent 70%); pointer-events: none; }
.zh2-port-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
.zh2-port-header { text-align: center; margin-bottom: 48px; }
.zh2-port-header-icon { width: 56px; height: 56px; border-radius: 16px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.25); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
.zh2-port-header-icon i { font-size: 1.3rem; color: #ff5a5a; }
.zh2-port-title { font-size: clamp(2rem,4vw,3rem); font-weight: 900; color: #fff; letter-spacing: -0.02em; margin-bottom: 14px; }
.zh2-port-accent { color: #e8232a; }
.zh2-port-title-decor { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 14px; }
.zh2-port-decor-line { width: 60px; height: 2px; background: linear-gradient(90deg, transparent, rgba(232,35,42,0.6)); border-radius: 2px; }
.zh2-port-decor-line:last-child { background: linear-gradient(90deg, rgba(232,35,42,0.6), transparent); }
.zh2-port-decor-dot { width: 6px; height: 6px; border-radius: 50%; background: #e8232a; box-shadow: 0 0 8px rgba(232,35,42,0.8); }
.zh2-port-subtitle { font-size: 0.95rem; color: #6888aa; }
.zh2-port-top-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 20px; }
.zh2-port-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(232,35,42,0.12); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; }
.zh2-port-card:hover { border-color: rgba(232,35,42,0.38); transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
.zh2-port-card-img { position: relative; height: 200px; overflow: hidden; }
.zh2-port-img-sales, .zh2-port-img-finance, .zh2-port-img-marketing { background: linear-gradient(160deg, rgba(30,0,5,0.95) 0%, rgba(4,2,8,0.98) 100%), repeating-linear-gradient(135deg, transparent, transparent 20px, rgba(232,35,42,0.04) 20px, rgba(232,35,42,0.04) 22px); }
.zh2-port-img-sales::after, .zh2-port-img-finance::after, .zh2-port-img-marketing::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 80%, rgba(232,35,42,0.18) 0%, transparent 70%); pointer-events: none; }
.zh2-port-card-img-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to bottom, transparent, rgba(5,2,10,0.9)); z-index: 3; pointer-events: none; }
.zh2-port-card-body { padding: 22px 22px 26px; flex: 1; display: flex; flex-direction: column; }
.zh2-port-card-icon { width: 42px; height: 42px; border-radius: 12px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.25); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
.zh2-port-card-icon i { font-size: 1rem; color: #ff5a5a; }
.zh2-port-card-title { font-size: 1.1rem; font-weight: 800; color: #e8f0ff; margin-bottom: 8px; line-height: 1.3; }
.zh2-port-card-desc { font-size: 0.82rem; color: #6888aa; line-height: 1.65; margin-bottom: 14px; }
.zh2-port-list { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
.zh2-port-list li { display: flex; align-items: center; gap: 10px; font-size: 0.83rem; color: #b0c8e8; }
.zh2-port-list li i { color: #e8232a; font-size: 0.75rem; flex-shrink: 0; }
.zh2-port-link { display: inline-flex; align-items: center; gap: 8px; font-size: 0.83rem; font-weight: 700; color: #e8232a; text-decoration: none; transition: gap 0.2s, color 0.2s; margin-top: auto; }
.zh2-port-link:hover { gap: 12px; color: #ff5a5a; }
.zh2-port-bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.zh2-port-dc-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(232,35,42,0.12); border-radius: 16px; overflow: hidden; display: flex; flex-direction: row; transition: border-color 0.3s, box-shadow 0.3s; }
.zh2-port-dc-card:hover { border-color: rgba(232,35,42,0.32); box-shadow: 0 16px 40px rgba(0,0,0,0.35); }
.zh2-port-dc-img { position: relative; width: 200px; flex-shrink: 0; overflow: hidden; background: linear-gradient(160deg, rgba(20,0,5,0.96) 0%, rgba(4,2,8,0.99) 100%), repeating-linear-gradient(90deg, transparent, transparent 16px, rgba(232,35,42,0.04) 16px, rgba(232,35,42,0.04) 18px); }
.zh2-port-dc-img::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 30% 70%, rgba(232,35,42,0.16) 0%, transparent 70%); }
.zh2-port-dc-img-overlay { position: absolute; right: 0; top: 0; bottom: 0; width: 60px; background: linear-gradient(to right, transparent, rgba(4,2,8,0.9)); z-index: 3; }
.zh2-port-dc-body { padding: 28px 26px; flex: 1; display: flex; flex-direction: column; }
.zh2-port-dc-icon { margin-bottom: 14px; }
.zh2-port-why-panel { background: rgba(255,255,255,0.025); border: 1px solid rgba(232,35,42,0.12); border-radius: 16px; padding: 28px; display: flex; flex-direction: column; }
.zh2-port-why-title { font-size: 1.3rem; font-weight: 800; color: #e8f0ff; margin-bottom: 24px; }
.zh2-port-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px 24px; flex: 1; margin-bottom: 24px; }
.zh2-port-why-item { display: flex; flex-direction: column; gap: 6px; }
.zh2-port-why-icon { width: 36px; height: 36px; border-radius: 10px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 4px; }
.zh2-port-why-icon i { font-size: 0.9rem; color: #ff5a5a; }
.zh2-port-why-item strong { font-size: 0.88rem; font-weight: 700; color: #c8ddf4; }
.zh2-port-why-item span { font-size: 0.77rem; color: #5a7aa0; line-height: 1.5; }
.zh2-port-cta-bar { display: flex; align-items: center; gap: 14px; background: rgba(232,35,42,0.07); border: 1px solid rgba(232,35,42,0.18); border-radius: 12px; padding: 14px 16px; flex-wrap: wrap; row-gap: 10px; }
.zh2-port-cta-icon { width: 38px; height: 38px; border-radius: 10px; background: rgba(232,35,42,0.12); border: 1px solid rgba(232,35,42,0.28); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.zh2-port-cta-icon i { font-size: 0.95rem; color: #ff5a5a; }
.zh2-port-cta-text { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 120px; }
.zh2-port-cta-text strong { font-size: 0.84rem; font-weight: 700; color: #dce8ff; }
.zh2-port-cta-text span { font-size: 0.75rem; color: #5a7aa0; }
.zh2-port-cta-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 8px; background: linear-gradient(135deg, #aa0008 0%, #e8232a 100%); color: #fff; font-size: 0.82rem; font-weight: 700; text-decoration: none; white-space: nowrap; transition: all 0.3s ease; box-shadow: 0 4px 16px rgba(232,35,42,0.3); flex-shrink: 0; }
.zh2-port-cta-btn:hover { background: linear-gradient(135deg, #e8232a 0%, #ff5a5a 100%); box-shadow: 0 6px 24px rgba(232,35,42,0.5); color: #fff; transform: translateY(-1px); }

/* CERTIFICATIONS */
.zh2-cert-section { padding: 60px 0 0; }
.zh2-cert-title { font-size: clamp(1.4rem,2.5vw,2rem); font-weight: 900; color: #fff; text-align: center; margin-bottom: 32px; }
.zh2-cert-images { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
.zh2-cert-img-card { position: relative; border-radius: 16px; overflow: hidden; border: 1px solid rgba(232,35,42,0.2); background: rgba(255,255,255,0.03); transition: border-color 0.3s, transform 0.3s; }
.zh2-cert-img-card:hover { border-color: rgba(232,35,42,0.4); transform: translateY(-4px); }
.zh2-cert-img-card img { width: 260px; height: auto; display: block; }
.zh2-cert-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(4,8,20,0.4) 0%, transparent 60%); pointer-events: none; }

@media (max-width:1024px) { .zh2-port-top-row { grid-template-columns: 1fr 1fr; } .zh2-port-bottom-row { grid-template-columns: 1fr; } }
@media (max-width:768px) { .zh2-port-section { padding: 60px 0 70px; } .zh2-port-top-row { grid-template-columns: 1fr; } .zh2-port-dc-card { flex-direction: column; } .zh2-port-dc-img { width: 100%; height: 120px; } }

/* INDUSTRIES */
.zh2-ind-section { background: #040d1e; padding: 80px 0 90px; position: relative; overflow: hidden; }
.zh2-ind-bg-glow { position: absolute; width: 600px; height: 600px; border-radius: 50%; pointer-events: none; z-index: 0; }
.zh2-ind-bg-glow-left { top: -100px; left: -200px; background: radial-gradient(ellipse at center, rgba(232,35,42,0.07) 0%, transparent 70%); }
.zh2-ind-bg-glow-right { bottom: -100px; right: -200px; background: radial-gradient(ellipse at center, rgba(232,35,42,0.07) 0%, transparent 70%); }
.zh2-ind-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.zh2-ind-header { text-align: center; margin-bottom: 48px; }
.zh2-ind-badge { display: inline-flex; align-items: center; gap: 10px; padding: 9px 22px; border-radius: 50px; border: 1px solid rgba(232,35,42,0.3); background: rgba(160,0,10,0.15); font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #fca5a5; margin-bottom: 24px; }
.zh2-ind-badge i { color: #e8232a; }
.zh2-ind-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #e8232a; box-shadow: 0 0 6px rgba(232,35,42,0.8); }
.zh2-ind-title { font-size: clamp(1.8rem,3.5vw,2.8rem); font-weight: 900; color: #fff; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 12px; }
.zh2-ind-accent { color: #e8232a; }
.zh2-ind-subtitle { font-size: 0.95rem; color: #6888aa; }
.zh2-ind-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.zh2-ind-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(232,35,42,0.12); border-radius: 16px; padding: 24px 22px 52px; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; }
.zh2-ind-card:hover { border-color: rgba(232,35,42,0.35); transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.35); }
.zh2-ind-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.zh2-ind-icon-wrap { width: 44px; height: 44px; border-radius: 12px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.25); display: flex; align-items: center; justify-content: center; }
.zh2-ind-icon-wrap i { font-size: 1.1rem; color: #e8232a; }
.zh2-ind-num { font-size: 1.8rem; font-weight: 900; color: rgba(232,35,42,0.18); line-height: 1; }
.zh2-ind-num-rule { width: 32px; height: 2px; background: linear-gradient(90deg, #e8232a, transparent); border-radius: 2px; margin-bottom: 12px; }
.zh2-ind-card-title { font-size: 1rem; font-weight: 800; color: #e8f0ff; margin-bottom: 8px; }
.zh2-ind-card-desc { font-size: 0.82rem; color: #6888aa; line-height: 1.6; margin-bottom: 16px; }
.zh2-ind-arrow { position: absolute; bottom: 20px; right: 20px; width: 34px; height: 34px; border-radius: 10px; background: rgba(232,35,42,0.12); border: 1px solid rgba(232,35,42,0.2); display: flex; align-items: center; justify-content: center; color: #e8232a; text-decoration: none; transition: background 0.3s, transform 0.3s; }
.zh2-ind-arrow:hover { background: rgba(232,35,42,0.25); transform: translate(2px,-2px); }
.zh2-ind-arrow i { font-size: 0.8rem; }
.zh2-ind-card-bg-pattern { position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: radial-gradient(ellipse at center, rgba(232,35,42,0.06) 0%, transparent 70%); pointer-events: none; }
@media (max-width:1024px) { .zh2-ind-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width:600px) { .zh2-ind-grid { grid-template-columns: 1fr; } }

/* SPECIAL OFFER */
.zh2-special-offer { padding: 80px 0; background: #040d1e; }
.zh2-offer-banner { background: rgba(255,255,255,0.03); border: 1px solid rgba(232,35,42,0.2); border-radius: 24px; padding: 48px; display: flex; flex-direction: column; align-items: center; text-align: center; }
.zh2-offer-shield { width: 80px; height: 80px; border-radius: 50%; background: rgba(232,35,42,0.12); border: 2px solid rgba(232,35,42,0.3); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; }
.zh2-offer-shield i { font-size: 2rem; color: #e8232a; }
.zh2-offer-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; border-radius: 50px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.3); font-size: 0.72rem; font-weight: 700; letter-spacing: 1px; color: #fca5a5; margin-bottom: 16px; }
.zh2-offer-title { font-size: clamp(1.8rem,3.5vw,2.8rem); font-weight: 900; margin-bottom: 8px; }
.zh2-offer-title-accent { color: #e8232a; }
.zh2-offer-title-white { color: #fff; }
.zh2-offer-title-divider { width: 60px; height: 3px; background: linear-gradient(90deg, #e8232a, #ff5a5a); border-radius: 2px; margin: 12px auto 16px; }
.zh2-offer-subtitle { font-size: 1rem; color: #8aaac8; margin-bottom: 12px; }
.zh2-offer-desc { font-size: 0.88rem; color: #6888aa; max-width: 600px; line-height: 1.7; margin-bottom: 28px; }
.zh2-offer-cards { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-bottom: 28px; }
.zh2-offer-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(232,35,42,0.15); border-radius: 14px; padding: 18px 16px; display: flex; flex-direction: column; align-items: center; gap: 10px; min-width: 130px; flex: 1; max-width: 160px; }
.zh2-offer-card-icon { width: 42px; height: 42px; border-radius: 12px; background: rgba(232,35,42,0.15); border: 1px solid rgba(232,35,42,0.25); display: flex; align-items: center; justify-content: center; }
.zh2-offer-card-icon i { font-size: 1rem; color: #ff5a5a; }
.zh2-offer-card-label { font-size: 0.78rem; font-weight: 600; color: #c8ddf4; line-height: 1.4; text-align: center; }
.zh2-offer-card-line { width: 30px; height: 2px; background: rgba(232,35,42,0.4); border-radius: 2px; }
.zh2-contact-btn { display: inline-flex; align-items: center; gap: 10px; padding: 14px 32px; border-radius: 50px; background: linear-gradient(135deg, #aa0008 0%, #e8232a 60%, #ff5a5a 100%); color: #fff; font-size: 0.9rem; font-weight: 700; text-decoration: none; letter-spacing: 0.5px; box-shadow: 0 8px 28px rgba(232,35,42,0.4); transition: all 0.3s ease; margin-bottom: 20px; }
.zh2-contact-btn:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(232,35,42,0.6); color: #fff; }
.zh2-offer-trust { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center; }
.zh2-offer-trust-item { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 600; color: #8aaac8; }
.zh2-offer-trust-item i { color: #e8232a; font-size: 0.85rem; }
.zh2-offer-trust-sep { color: rgba(232,35,42,0.4); font-weight: 300; }

/* ── Career CTA background override ── */
.zoho-page.zh2-page .career-cta-section {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(4,13,30,0.84) 0%, rgba(20,2,4,0.80) 50%, rgba(4,13,30,0.88) 100%),
    url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}
.zoho-page.zh2-page .career-cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 50%, rgba(232,35,42,0.15) 0%, transparent 65%),
    radial-gradient(ellipse at 70% 50%, rgba(180,0,10,0.10) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}
.zoho-page.zh2-page .career-cta-section .career-cta-container {
  position: relative;
  z-index: 1;
}
