          <p className="career-cta-text">Speak with a senior backup consultant today. In 30 minutes you'll know:<br /><br />&#8226; Gaps in your current data protection strategy<br />&#8226; Quick wins to eliminate ransomware risks<br />&#8226; An exact timeline &amp; cost estimate&mdash;no obligations</p>
          <div className="about-two__btn-box"><a href="tel:7032224513" className="btn-get-started"><span className="btn-text">Book Your Free Strategy Call </span><span className="btn-arrow"></span></a></div>
        </div>
      </section>

      {/* Special Offer */}
      <section className="veeam2-special-offer" data-aos="fade-up" data-aos-duration="900">
        <div className="container">
          <div className="veeam2-offer-card">

            {/* Glows */}
            <div className="veeam2-offer-glow-left"  aria-hidden="true"></div>
            <div className="veeam2-offer-glow-right" aria-hidden="true"></div>
            <div className="veeam2-offer-stars"      aria-hidden="true">
              <span className="veeam2-star veeam2-star-1">&#10022;</span>
              <span className="veeam2-star veeam2-star-2">&#10022;</span>
              <span className="veeam2-star veeam2-star-3">&#10022;</span>
              <span className="veeam2-star veeam2-star-4">&#10022;</span>
            </div>

            {/* LEFT — image */}
            <div className="veeam2-offer-img-col">
              <img
                src="/assets/images/partners/VEEAM.jpg"
                alt="Veeam Backup & Data Protection"
                className="veeam2-offer-img"
              />
            </div>

            {/* RIGHT — content */}
            <div className="veeam2-offer-content">

              <div className="veeam2-offer-badge">
                <i className="fas fa-gift"></i>&nbsp; SPECIAL OFFER
              </div>

              <h2 className="veeam2-offer-title">
                <span className="veeam2-offer-free">FREE</span> POC &amp; Assessment
              </h2>

              <div className="veeam2-offer-pill">
                <span className="veeam2-offer-pill-dot"></span>
                EXCLUSIVE OFFERS ON VEEAM BACKUP SOLUTIONS
                <span className="veeam2-offer-pill-dot"></span>
              </div>

              <p className="veeam2-offer-desc">
                Experience the power of Veeam Backup firsthand — zero risk, zero commitment.
                Our certified team will set up a complete proof of concept tailored to your environment so you can
                see measurable results before you invest.
              </p>

              {/* Feature grid */}
              <div className="veeam2-offer-grid">
                {[
                  { icon: 'fas fa-database',       label: 'FREE Backup POC Setup'             },
                  { icon: 'fas fa-desktop',         label: 'Guided Platform Demo'              },
                  { icon: 'fas fa-shield-alt',      label: 'Ransomware Protection Assessment'  },
                  { icon: 'fas fa-headset',         label: 'Priority Implementation Support'   },
                ].map((pt) => (
                  <div className="veeam2-offer-feature" key={pt.label}>
                    <div className="veeam2-offer-feat-icon">
                      <i className={pt.icon}></i>
                    </div>
                    <span>{pt.label}</span>
                    <div className="veeam2-offer-feat-bar"></div>
                  </div>
                ))}
              </div>

              {/* Modules row */}
              <div className="veeam2-offer-modules-row">
                <span className="veeam2-offer-modules-label">Get Expert Guidance for:</span>
                <div className="veeam2-offer-modules-list">
                  {['VM Backup', 'Cloud Backup', 'Ransomware Protection', 'Disaster Recovery'].map((m, i) => (
                    <React.Fragment key={m}>
                      <span className="veeam2-offer-module">
                        <i className="fas fa-check-circle"></i> {m}
                      </span>
                      {i < 3 && <span className="veeam2-offer-sep">|</span>}
                    </React.Fragment>
                  ))}
                </div>
              </div>

              <Link to="/contact-us" className="veeam2-contact-btn">
                <i className="fas fa-paper-plane"></i>
                &nbsp; CONTACT TRACE NETWORK &nbsp;&#8594;
              </Link>

            </div>
          </div>
        </div>
      </section>

    </div>
  );
}
