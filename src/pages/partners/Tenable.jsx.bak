          <div className="about-two__btn-box"><a href="tel:7032224513" className="btn-get-started"><span className="btn-text">Book Your Free Strategy Call </span><span className="btn-arrow"></span></a></div>
        </div>
      </section>

      {/* Special Offer */}
      <section className="tnb2-special-offer" data-aos="fade-up" data-aos-duration="900">
        <div className="container">
          <div className="tnb2-offer-card">

            {/* Glows */}
            <div className="tnb2-offer-glow-left"  aria-hidden="true"></div>
            <div className="tnb2-offer-glow-right" aria-hidden="true"></div>
            <div className="tnb2-offer-stars"      aria-hidden="true">
              <span className="tnb2-star tnb2-star-1">&#10022;</span>
              <span className="tnb2-star tnb2-star-2">&#10022;</span>
              <span className="tnb2-star tnb2-star-3">&#10022;</span>
              <span className="tnb2-star tnb2-star-4">&#10022;</span>
            </div>

            {/* LEFT — image */}
            <div className="tnb2-offer-img-col">
              <img
                src="/assets/images/partners/TENABLE-2.jpg"
                alt="Tenable Cyber Exposure Platform"
                className="tnb2-offer-img"
              />
            </div>

            {/* RIGHT — content */}
            <div className="tnb2-offer-content">

              <div className="tnb2-offer-badge">
                <i className="fas fa-gift"></i>&nbsp; SPECIAL OFFER
              </div>

              <h2 className="tnb2-offer-title">
                <span className="tnb2-offer-free">FREE</span> POC &amp; Assessment
              </h2>

              <div className="tnb2-offer-pill">
                <span className="tnb2-offer-pill-dot"></span>
                EXCLUSIVE OFFERS ON TENABLE CYBER EXPOSURE SOLUTIONS
                <span className="tnb2-offer-pill-dot"></span>
              </div>

              <p className="tnb2-offer-desc">
                Experience the power of Tenable's vulnerability management firsthand — zero risk, zero commitment.
                Our certified team will set up a complete proof of concept tailored to your environment so you can
                see measurable results before you invest.
              </p>

              {/* Feature grid */}
              <div className="tnb2-offer-grid">
                {[
                  { icon: 'fas fa-search',         label: 'FREE Vulnerability Assessment'      },
                  { icon: 'fas fa-desktop',         label: 'Guided Platform Demo'              },
                  { icon: 'fas fa-shield-alt',      label: 'Cyber Exposure Consultation'       },
                  { icon: 'fas fa-headset',         label: 'Priority Implementation Support'   },
                ].map((pt) => (
                  <div className="tnb2-offer-feature" key={pt.label}>
                    <div className="tnb2-offer-feat-icon">
                      <i className={pt.icon}></i>
                    </div>
                    <span>{pt.label}</span>
                    <div className="tnb2-offer-feat-bar"></div>
                  </div>
                ))}
              </div>

              {/* Modules row */}
              <div className="tnb2-offer-modules-row">
                <span className="tnb2-offer-modules-label">Get Expert Guidance for:</span>
                <div className="tnb2-offer-modules-list">
                  {['Vulnerability Mgmt', 'Web App Security', 'OT & ICS Security', 'Cloud & Identity'].map((m, i) => (
                    <React.Fragment key={m}>
                      <span className="tnb2-offer-module">
                        <i className="fas fa-check-circle"></i> {m}
                      </span>
                      {i < 3 && <span className="tnb2-offer-sep">|</span>}
                    </React.Fragment>
                  ))}
                </div>
              </div>

              <Link to="/contact-us" className="tnb2-contact-btn">
                <i className="fas fa-paper-plane"></i>
                &nbsp; CONTACT TRACE NETWORK &nbsp;&#8594;
              </Link>

            </div>
          </div>
        </div>
      </section>

    </div>
  );
}
