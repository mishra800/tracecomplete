@import './shared.css';

/* ================================================================
   HPE PREMIUM — GREEN EDITION
   Accent: #00b08b   Secondary: #00d4a8
   ================================================================ */

.hpe-page.hpe2-page { overflow-x: hidden; }

.hpe-page .hpe2-hero, section.hpe2-hero {
  background: linear-gradient(135deg, #040d1e 0%, #040f0a 50%, #040d1e 100%) !important;
  padding: 0 !important; overflow: hidden !important; min-height: unset !important;
}
.hpe2-hero { position: relative; display: flex; align-items: center; overflow: hidden; }
.hpe2-hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.hpe2-hero-glow-left { position: absolute; top: 0; left: 0; width: 50%; height: 100%; z-index: 0; pointer-events: none; background: radial-gradient(ellipse at center, rgba(0,176,139,0.22) 0%, rgba(0,120,100,0.10) 50%, transparent 80%); animation: hpe2-glow-pulse 7s ease-in-out infinite alternate; }
.hpe2-hero-glow-right { position: absolute; bottom: 0; right: 0; width: 55%; height: 100%; z-index: 0; pointer-events: none; background: radial-gradient(ellipse at center, rgba(0,176,139,0.16) 0%, rgba(0,120,100,0.08) 50%, transparent 80%); animation: hpe2-glow-pulse 9s ease-in-out infinite alternate-reverse; }
@keyframes hpe2-glow-pulse { 0% { opacity: 0.7; } 100% { opacity: 1; } }
.hpe2-hero-inner { position: relative; z-index: 2; display: grid; grid-template-columns: 52% 48%; gap: 24px; align-items: flex-start; padding: 90px 20px 20px; max-width: 1280px; margin: 0 auto; width: 100%; }
.hpe2-headline { font-size: clamp(1.7rem,2.8vw,2.5rem); font-weight: 900; line-height: 1.12; color: #fff; letter-spacing: -0.02em; margin-bottom: 6px; }
.hpe2-headline-accent { color: #00b08b; display: block; }
.hpe2-headline-rule { width: 40px; height: 3px; background: #00b08b; border-radius: 2px; margin: 10px 0 12px; }
.hpe2-desc { font-size: 0.88rem; color: #b0c8e8; line-height: 1.6; max-width: 480px; margin-bottom: 14px; }
.hpe2-desc-link { color: #00d4a8; text-decoration: none; font-weight: 600; }
.hpe2-desc-link:hover { text-decoration: underline; }
.hpe2-feature-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 14px; }
.hpe2-feat { display: flex; flex-direction: column; gap: 4px; padding: 10px; border-radius: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(0,176,139,0.15); transition: border-color 0.3s, background 0.3s; }
.hpe2-feat:hover { border-color: rgba(0,176,139,0.35); background: rgba(0,120,100,0.08); }
.hpe2-feat-icon { width: 34px; height: 34px; border-radius: 8px; background: rgba(0,176,139,0.2); border: 1px solid rgba(0,176,139,0.3); display: flex; align-items: center; justify-content: center; margin-bottom: 4px; }
.hpe2-feat-icon i { font-size: 0.85rem; color: #00d4a8; }
.hpe2-feat-body strong { display: block; font-size: 0.82rem; font-weight: 700; color: #dce8ff; margin-bottom: 2px; }
.hpe2-feat-body span { font-size: 0.72rem; color: #6888aa; line-height: 1.4; }
.hpe2-stats-row { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
.hpe2-stat-card { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(0,176,139,0.2); backdrop-filter: blur(8px); min-width: 100px; flex: 1; }
.hpe2-stat-card > i { font-size: 1.2rem; color: #00b08b; flex-shrink: 0; }
.hpe2-stat-card > div { display: flex; flex-direction: column; gap: 2px; }
.hpe2-stat-num { font-size: 1.4rem; font-weight: 900; color: #fff; letter-spacing: -0.02em; line-height: 1; }
.hpe2-stat-lbl { font-size: 0.6rem; font-weight: 700; color: #5a7aa0; letter-spacing: 0.8px; text-transform: uppercase; line-height: 1.4; }
.hpe2-stat-brand { border-color: rgba(0,176,139,0.3); background: rgba(0,176,139,0.07); flex-direction: column; align-items: flex-start; gap: 4px; }
.hpe2-brand-logo { width: 90px; height: auto; object-fit: contain; border-radius: 6px; display: block; }
.hpe2-cta-row { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
.hpe2-btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 50px; background: linear-gradient(135deg, #006b55 0%, #00b08b 60%, #00d4a8 100%); background-size: 200% auto; color: #fff; font-size: 0.85rem; font-weight: 700; text-decoration: none; box-shadow: 0 6px 24px rgba(0,176,139,0.4); transition: all 0.4s ease; }
.hpe2-btn-primary:hover { background-position: right center; transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,176,139,0.6); color: #fff; }
.hpe2-btn-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 11px 18px; border-radius: 50px; background: transparent; border: 1px solid rgba(255,255,255,0.18); color: #c0d4f0; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: all 0.3s ease; }
.hpe2-btn-ghost:hover { border-color: rgba(0,176,139,0.5); background: rgba(0,176,139,0.08); color: #fff; transform: translateY(-2px); }
.hpe2-industry-strip { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; padding: 12px 12px 6px; border-top: 1px solid rgba(0,176,139,0.2); row-gap: 8px; width: 100%; max-width: 520px; margin-top: 12px; position: relative; z-index: 3; }
.hpe2-ind-item { display: inline-flex; align-items: center; gap: 8px; font-size: 0.92rem; font-weight: 600; color: #c8e8ff; padding: 4px 12px; white-space: nowrap; }
.hpe2-ind-item i { font-size: 1.05rem; color: #00b08b; }
.hpe2-ind-item:hover { color: #fff; }
.hpe2-ind-sep { width: 1px; height: 16px; background: rgba(0,176,139,0.25); flex-shrink: 0; }
.hpe2-right { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; margin-top: -10px; }
.hpe2-product-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 85% 70% at 55% 50%, rgba(0,176,139,0.28) 0%, rgba(0,120,100,0.12) 50%, transparent 80%); pointer-events: none; z-index: 0; animation: hpe2-glow-breathe 6s ease-in-out infinite; }
@keyframes hpe2-glow-breathe { 0%,100% { opacity: 0.8; } 50% { opacity: 1; } }
.hpe2-showcase { position: relative; width: 440px; z-index: 2; display: flex; align-items: center; justify-content: center; }
.hpe2-hero-product-img { width: 100%; max-width: 380px; height: auto; object-fit: contain; display: block; position: relative; z-index: 2; border-radius: 12px; filter: drop-shadow(0 30px 60px rgba(0,0,0,0.7)) drop-shadow(0 0 60px rgba(0,176,139,0.3)); animation: hpe2-float 6s ease-in-out infinite; }
@keyframes hpe2-float { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-14px) scale(1.012); } }
.hpe2-platform { position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); width: 360px; height: 90px; pointer-events: none; z-index: 1; }
.hpe2-plat-ring { position: absolute; left: 50%; transform: translateX(-50%); bottom: 0; border-radius: 50%; border: 1px solid rgba(0,176,139,0.3); animation: hpe2-ring-pulse 4s ease-in-out infinite; }
.hpe2-plat-ring-1 { width: 360px; height: 44px; background: radial-gradient(ellipse at 50% 80%, rgba(0,176,139,0.18) 0%, transparent 70%); }
.hpe2-plat-ring-2 { width: 240px; height: 28px; background: radial-gradient(ellipse at 50% 80%, rgba(0,176,139,0.28) 0%, transparent 70%); animation-delay: 0.5s; }
.hpe2-plat-ring-3 { width: 130px; height: 16px; background: radial-gradient(ellipse at 50% 80%, rgba(0,176,139,0.55) 0%, transparent 70%); animation-delay: 1s; }
.hpe2-plat-surface { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 2px; height: 60px; background: linear-gradient(to top, rgba(0,176,139,0.7), transparent); filter: blur(3px); }
@keyframes hpe2-ring-pulse { 0%,100% { opacity: 0.5; } 50% { opacity: 1; } }
@media (max-width:1100px) { .hpe2-hero-inner { grid-template-columns: 1fr; padding: 50px 20px 60px; } .hpe2-right { justify-content: center; margin-top: 0; } }
@media (max-width:768px) { .hpe2-hero-inner { padding: 90px 16px 32px; } .hpe2-feature-row { grid-template-columns: 1fr; } .hpe2-cta-row { flex-direction: column; align-items: flex-start; } .hpe2-btn-primary, .hpe2-btn-ghost { width: 100%; justify-content: center; } }

/* WHY SECTION */
.hpe2-why-section { background: #040d1e; padding: 90px 0 0; position: relative; overflow: hidden; }
.hpe2-why-section::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 900px; height: 500px; background: radial-gradient(ellipse at 50% 0%, rgba(0,176,139,0.1) 0%, transparent 70%); pointer-events: none; }
.hpe2-why-container { max-width: 1180px; margin: 0 auto; padding: 0 24px 80px; }
.hpe2-why-header { text-align: center; margin-bottom: 48px; }
.hpe2-why-badge { display: inline-flex; align-items: center; gap: 10px; padding: 9px 22px; border-radius: 50px; border: 1px solid rgba(0,176,139,0.35); background: rgba(0,100,80,0.18); backdrop-filter: blur(10px); font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #6ee7b7; margin-bottom: 28px; }
.hpe2-why-badge i { color: #00b08b; font-size: 0.85rem; }
.hpe2-why-title { font-size: clamp(2rem,4vw,3.2rem); font-weight: 900; line-height: 1.15; color: #fff; letter-spacing: -0.02em; margin-bottom: 16px; }
.hpe2-why-accent { color: #00b08b; }
.hpe2-why-subtitle { font-size: 1rem; color: #8aaac8; margin-bottom: 20px; }
.hpe2-why-title-rule { width: 60px; height: 3px; background: linear-gradient(90deg, #00b08b, #00d4a8); border-radius: 2px; margin: 0 auto; }
.hpe2-why-card-outer { display: grid; grid-template-columns: 1fr auto 1fr; background: rgba(255,255,255,0.03); border: 1px solid rgba(0,176,139,0.15); border-radius: 20px; overflow: hidden; min-height: 440px; backdrop-filter: blur(6px); box-shadow: 0 30px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05); }
.hpe2-why-panel { position: relative; display: flex; overflow: hidden; }
.hpe2-why-panel-left, .hpe2-why-panel-right { flex-direction: row; align-items: stretch; }
.hpe2-why-img-wrap { position: relative; flex-shrink: 0; }
.hpe2-why-img-right { width: 180px; overflow: hidden; }
.hpe2-why-img-gradient-right { position: absolute; inset: 0; background: linear-gradient(to left, transparent 0%, rgba(8,20,50,0.7) 100%); pointer-events: none; z-index: 2; }
.hpe2-why-server-bg { position: absolute; inset: 0; background: linear-gradient(160deg, rgba(0,15,10,0.9) 0%, rgba(2,8,4,0.98) 100%), repeating-linear-gradient(90deg, transparent, transparent 18px, rgba(0,176,139,0.04) 18px, rgba(0,176,139,0.04) 20px); z-index: 1; }
.hpe2-why-content { flex: 1; padding: 40px 36px 40px 32px; position: relative; z-index: 3; }
.hpe2-why-panel-right .hpe2-why-content { padding: 40px 32px 40px 36px; }
.hpe2-why-icon-row { margin-bottom: 16px; }
.hpe2-why-icon-circle { width: 52px; height: 52px; border-radius: 14px; background: rgba(0,176,139,0.18); border: 1px solid rgba(0,176,139,0.3); display: flex; align-items: center; justify-content: center; }
.hpe2-why-icon-circle i { font-size: 1.2rem; color: #00d4a8; }
.hpe2-why-icon-teal { background: rgba(0,130,130,0.2); border-color: rgba(0,200,200,0.25); }
.hpe2-why-icon-teal i { color: #00d4e0; }
.hpe2-why-card-sup { font-size: 0.78rem; font-weight: 600; color: #607a9a; margin-bottom: 2px; }
.hpe2-why-card-title { font-size: 1.3rem; font-weight: 800; line-height: 1.2; margin-bottom: 14px; }
.hpe2-why-card-title-green { color: #00b08b; }
.hpe2-why-card-title-teal { color: #00c8d8; }
.hpe2-why-card-desc { font-size: 0.85rem; color: #8aaac8; line-height: 1.7; margin-bottom: 20px; }
.hpe2-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px; }
.hpe2-why-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 0.84rem; color: #c8ddf4; line-height: 1.4; }
.hpe2-why-list li small { display: block; color: #6888aa; font-size: 0.77rem; }
.hpe2-why-list-icon { flex-shrink: 0; width: 30px; height: 30px; border-radius: 8px; background: rgba(0,176,139,0.15); border: 1px solid rgba(0,176,139,0.2); display: flex; align-items: center; justify-content: center; margin-top: 1px; }
.hpe2-why-list-icon i { font-size: 0.75rem; color: #00d4a8; }
.hpe2-why-list-check-icon { background: rgba(0,160,120,0.15); border-color: rgba(0,200,160,0.2); }
.hpe2-why-list-check-icon i { color: #00d4a0; }
.hpe2-why-divider { width: 1px; background: linear-gradient(to bottom, transparent 5%, rgba(0,176,139,0.25) 25%, rgba(0,176,139,0.35) 50%, rgba(0,176,139,0.25) 75%, transparent 95%); flex-shrink: 0; align-self: stretch; }
.hpe2-why-stats-bar { display: flex; align-items: center; justify-content: center; gap: 0; margin-top: 32px; background: rgba(255,255,255,0.025); border: 1px solid rgba(0,176,139,0.12); border-radius: 16px; padding: 22px 32px; flex-wrap: wrap; row-gap: 20px; }
.hpe2-why-stat { display: flex; align-items: center; gap: 14px; flex: 1; justify-content: center; min-width: 160px; }
.hpe2-why-stat-icon { width: 44px; height: 44px; border-radius: 12px; background: rgba(0,176,139,0.15); border: 1px solid rgba(0,176,139,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hpe2-why-stat-icon i { font-size: 1rem; color: #00d4a8; }
.hpe2-why-stat-text { display: flex; flex-direction: column; gap: 2px; }
.hpe2-why-stat-text strong { font-size: 0.95rem; font-weight: 700; color: #dce8ff; }
.hpe2-why-stat-text span { font-size: 0.75rem; color: #5a7aa0; }
.hpe2-why-stat-sep { width: 1px; height: 40px; background: rgba(0,176,139,0.18); flex-shrink: 0; margin: 0 8px; }
@media (max-width:1024px) { .hpe2-why-card-outer { grid-template-columns: 1fr; } .hpe2-why-divider { width: 100%; height: 1px; background: linear-gradient(to right, transparent 5%, rgba(0,176,139,0.25) 50%, transparent 95%); } .hpe2-why-img-right { display: none; } }
@media (max-width:768px) { .hpe2-why-section { padding: 60px 0 0; } .hpe2-why-container { padding: 0 16px 60px; } .hpe2-why-content { padding: 24px 20px; } .hpe2-why-stat-sep { display: none; } .hpe2-why-stat { min-width: 130px; flex: 0 0 calc(50% - 12px); } }

/* PORTFOLIO */
.hpe2-port-section { background: #040d1e; padding: 80px 0 90px; position: relative; overflow: hidden; }
.hpe2-port-section::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 400px; background: radial-gradient(ellipse at 50% 0%, rgba(0,176,139,0.08) 0%, transparent 70%); pointer-events: none; }
.hpe2-port-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
.hpe2-port-header { text-align: center; margin-bottom: 48px; }
.hpe2-port-header-icon { width: 56px; height: 56px; border-radius: 16px; background: rgba(0,176,139,0.15); border: 1px solid rgba(0,176,139,0.25); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
.hpe2-port-header-icon i { font-size: 1.3rem; color: #00d4a8; }
.hpe2-port-title { font-size: clamp(2rem,4vw,3rem); font-weight: 900; color: #fff; letter-spacing: -0.02em; margin-bottom: 14px; }
.hpe2-port-accent { color: #00b08b; }
.hpe2-port-title-decor { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 14px; }
.hpe2-port-decor-line { width: 60px; height: 2px; background: linear-gradient(90deg, transparent, rgba(0,176,139,0.6)); border-radius: 2px; }
.hpe2-port-decor-line:last-child { background: linear-gradient(90deg, rgba(0,176,139,0.6), transparent); }
.hpe2-port-decor-dot { width: 6px; height: 6px; border-radius: 50%; background: #00b08b; box-shadow: 0 0 8px rgba(0,176,139,0.8); }
.hpe2-port-subtitle { font-size: 0.95rem; color: #6888aa; }
.hpe2-port-top-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 20px; }
.hpe2-port-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(0,176,139,0.12); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; }
.hpe2-port-card:hover { border-color: rgba(0,176,139,0.38); transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
.hpe2-port-card-img { position: relative; height: 200px; overflow: hidden; }
.hpe2-port-img-rack, .hpe2-port-img-tower, .hpe2-port-img-cloud { background: linear-gradient(160deg, rgba(0,15,10,0.95) 0%, rgba(2,8,4,0.98) 100%), repeating-linear-gradient(135deg, transparent, transparent 20px, rgba(0,176,139,0.04) 20px, rgba(0,176,139,0.04) 22px); }
.hpe2-port-img-rack::after, .hpe2-port-img-tower::after, .hpe2-port-img-cloud::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 80%, rgba(0,176,139,0.18) 0%, transparent 70%); pointer-events: none; }
.hpe2-port-card-img-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(to bottom, transparent, rgba(2,8,4,0.9)); z-index: 3; pointer-events: none; }
.hpe2-port-card-body { padding: 22px 22px 26px; flex: 1; display: flex; flex-direction: column; }
.hpe2-port-card-icon { width: 42px; height: 42px; border-radius: 12px; background: rgba(0,176,139,0.15); border: 1px solid rgba(0,176,139,0.25); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
.hpe2-port-card-icon i { font-size: 1rem; color: #00d4a8; }
.hpe2-port-card-title { font-size: 1.1rem; font-weight: 800; color: #e8f0ff; margin-bottom: 8px; line-height: 1.3; }
.hpe2-port-card-desc { font-size: 0.82rem; color: #6888aa; line-height: 1.65; margin-bottom: 14px; }
.hpe2-port-list { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
.hpe2-port-list li { display: flex; align-items: center; gap: 10px; font-size: 0.83rem; color: #b0c8e8; }
.hpe2-port-list li i { color: #00b08b; font-size: 0.75rem; flex-shrink: 0; }
.hpe2-port-link { display: inline-flex; align-items: center; gap: 8px; font-size: 0.83rem; font-weight: 700; color: #00b08b; text-decoration: none; transition: gap 0.2s, color 0.2s; margin-top: auto; }
.hpe2-port-link:hover { gap: 12px; color: #00d4a8; }
.hpe2-port-bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.hpe2-port-dc-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(0,176,139,0.12); border-radius: 16px; overflow: hidden; display: flex; flex-direction: row; transition: border-color 0.3s, box-shadow 0.3s; }
.hpe2-port-dc-card:hover { border-color: rgba(0,176,139,0.32); box-shadow: 0 16px 40px rgba(0,0,0,0.35); }
.hpe2-port-dc-img { position: relative; width: 200px; flex-shrink: 0; overflow: hidden; background: linear-gradient(160deg, rgba(0,15,10,0.96) 0%, rgba(2,8,4,0.99) 100%), repeating-linear-gradient(90deg, transparent, transparent 16px, rgba(0,176,139,0.04) 16px, rgba(0,176,139,0.04) 18px); }
.hpe2-port-dc-img::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 30% 70%, rgba(0,176,139,0.16) 0%, transparent 70%); }
.hpe2-port-dc-img-overlay { position: absolute; right: 0; top: 0; bottom: 0; width: 60px; background: linear-gradient(to right, transparent, rgba(2,8,4,0.9)); z-index: 3; }
.hpe2-port-dc-body { padding: 28px 26px; flex: 1; display: flex; flex-direction: column; }
.hpe2-port-dc-icon { margin-bottom: 14px; }
.hpe2-port-why-panel { background: rgba(255,255,255,0.025); border: 1px solid rgba(0,176,139,0.12); border-radius: 16px; padding: 28px; display: flex; flex-direction: column; }
.hpe2-port-why-title { font-size: 1.3rem; font-weight: 800; color: #e8f0ff; margin-bottom: 24px; }
.hpe2-port-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px 24px; flex: 1; margin-bottom: 24px; }
.hpe2-port-why-item { display: flex; flex-direction: column; gap: 6px; }
.hpe2-port-why-icon { width: 36px; height: 36px; border-radius: 10px; background: rgba(0,176,139,0.15); border: 1px solid rgba(0,176,139,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 4px; }
.hpe2-port-why-icon i { font-size: 0.9rem; color: #00d4a8; }
.hpe2-port-why-item strong { font-size: 0.88rem; font-weight: 700; color: #c8ddf4; }
.hpe2-port-why-item span { font-size: 0.77rem; color: #5a7aa0; line-height: 1.5; }
.hpe2-port-cta-bar { display: flex; align-items: center; gap: 14px; background: rgba(0,176,139,0.07); border: 1px solid rgba(0,176,139,0.18); border-radius: 12px; padding: 14px 16px; flex-wrap: wrap; row-gap: 10px; }
.hpe2-port-cta-icon { width: 38px; height: 38px; border-radius: 10px; background: rgba(0,176,139,0.12); border: 1px solid rgba(0,176,139,0.28); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hpe2-port-cta-icon i { font-size: 0.95rem; color: #00d4a8; }
.hpe2-port-cta-text { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 120px; }
.hpe2-port-cta-text strong { font-size: 0.84rem; font-weight: 700; color: #dce8ff; }
.hpe2-port-cta-text span { font-size: 0.75rem; color: #5a7aa0; }
.hpe2-port-cta-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 8px; background: linear-gradient(135deg, #006b55 0%, #00b08b 100%); color: #fff; font-size: 0.82rem; font-weight: 700; text-decoration: none; white-space: nowrap; transition: all 0.3s ease; box-shadow: 0 4px 16px rgba(0,176,139,0.3); flex-shrink: 0; }
.hpe2-port-cta-btn:hover { background: linear-gradient(135deg, #00b08b 0%, #00d4a8 100%); box-shadow: 0 6px 24px rgba(0,176,139,0.5); color: #fff; transform: translateY(-1px); }
@media (max-width:1024px) { .hpe2-port-top-row { grid-template-columns: 1fr 1fr; } .hpe2-port-bottom-row { grid-template-columns: 1fr; } }
@media (max-width:768px) { .hpe2-port-section { padding: 60px 0 70px; } .hpe2-port-top-row { grid-template-columns: 1fr; } .hpe2-port-dc-card { flex-direction: column; } .hpe2-port-dc-img { width: 100%; height: 120px; } }

/* CERTIFICATIONS */
.hpe2-cert-section { background: #040d1e; padding: 80px 0; }
.hpe2-cert-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
.hpe2-cert-header { text-align: center; margin-bottom: 40px; }
.hpe2-cert-images { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
.hpe2-cert-img-card { border-radius: 16px; overflow: hidden; border: 1px solid rgba(0,176,139,0.2); background: rgba(255,255,255,0.03); transition: border-color 0.3s, transform 0.3s; }
.hpe2-cert-img-card:hover { border-color: rgba(0,176,139,0.4); transform: translateY(-4px); }
.hpe2-cert-img-card img { width: 220px; height: auto; display: block; }

/* INDUSTRIES */
.hpe2-ind-section { background: #040d1e; padding: 80px 0 90px; position: relative; overflow: hidden; }
.hpe2-ind-bg-glow { position: absolute; width: 600px; height: 600px; border-radius: 50%; pointer-events: none; z-index: 0; }
.hpe2-ind-bg-glow-left { top: -100px; left: -200px; background: radial-gradient(ellipse at center, rgba(0,176,139,0.07) 0%, transparent 70%); }
.hpe2-ind-bg-glow-right { bottom: -100px; right: -200px; background: radial-gradient(ellipse at center, rgba(0,176,139,0.07) 0%, transparent 70%); }
.hpe2-ind-container { max-width: 1180px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.hpe2-ind-header { text-align: center; margin-bottom: 48px; }
.hpe2-ind-badge { display: inline-flex; align-items: center; gap: 10px; padding: 9px 22px; border-radius: 50px; border: 1px solid rgba(0,176,139,0.3); background: rgba(0,100,80,0.15); font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #6ee7b7; margin-bottom: 24px; }
.hpe2-ind-badge i { color: #00b08b; }
.hpe2-ind-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #00b08b; box-shadow: 0 0 6px rgba(0,176,139,0.8); }
.hpe2-ind-title { font-size: clamp(1.8rem,3.5vw,2.8rem); font-weight: 900; color: #fff; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 12px; }
.hpe2-ind-accent { color: #00b08b; }
.hpe2-ind-subtitle { font-size: 0.95rem; color: #6888aa; }
.hpe2-ind-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.hpe2-ind-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(0,176,139,0.12); border-radius: 16px; padding: 24px 22px 52px; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; }
.hpe2-ind-card:hover { border-color: rgba(0,176,139,0.35); transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.35); }
.hpe2-ind-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.hpe2-ind-icon-wrap { width: 44px; height: 44px; border-radius: 12px; background: rgba(0,176,139,0.15); border: 1px solid rgba(0,176,139,0.25); display: flex; align-items: center; justify-content: center; }
.hpe2-ind-icon-wrap i { font-size: 1.1rem; color: #00b08b; }
.hpe2-ind-num { font-size: 1.8rem; font-weight: 900; color: rgba(0,176,139,0.18); line-height: 1; }
.hpe2-ind-num-rule { width: 32px; height: 2px; background: linear-gradient(90deg, #00b08b, transparent); border-radius: 2px; margin-bottom: 12px; }
.hpe2-ind-card-title { font-size: 1rem; font-weight: 800; color: #e8f0ff; margin-bottom: 8px; }
.hpe2-ind-card-desc { font-size: 0.82rem; color: #6888aa; line-height: 1.6; margin-bottom: 16px; }
.hpe2-ind-arrow { position: absolute; bottom: 20px; right: 20px; width: 34px; height: 34px; border-radius: 10px; background: rgba(0,176,139,0.12); border: 1px solid rgba(0,176,139,0.2); display: flex; align-items: center; justify-content: center; color: #00b08b; text-decoration: none; transition: background 0.3s, transform 0.3s; }
.hpe2-ind-arrow:hover { background: rgba(0,176,139,0.25); transform: translate(2px,-2px); }
.hpe2-ind-arrow i { font-size: 0.8rem; }
.hpe2-ind-card-bg-pattern { position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: radial-gradient(ellipse at center, rgba(0,176,139,0.06) 0%, transparent 70%); pointer-events: none; }
@media (max-width:1024px) { .hpe2-ind-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width:600px) { .hpe2-ind-grid { grid-template-columns: 1fr; } }

/* ── SPECIAL OFFER — Greythr-style two-column card ── */
.hpe2-special-offer { padding: 80px 0 100px; position: relative; }

.hpe2-offer-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 48px;
  background: linear-gradient(135deg, #040d1e 0%, #061524 50%, #040b18 100%);
  border: 1px solid rgba(0, 176, 139, 0.25);
  border-radius: 24px;
  padding: 56px 52px;
  overflow: hidden;
  box-shadow: 0 0 80px rgba(0, 176, 139, 0.16), inset 0 1px 0 rgba(255,255,255,0.04);
}
.hpe2-offer-card::before {
  content: ''; display: block; height: 2px; width: 100%;
  background: linear-gradient(90deg, transparent, rgba(0,212,168,.80), #00b08b, rgba(0,212,168,.80), transparent);
  background-size: 200% 100%;
  animation: hpe2-shimmer 3s linear infinite;
  position: absolute; top: 0; left: 0; right: 0; border-radius: 24px 24px 0 0;
}
@keyframes hpe2-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes hpe2-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-10px); }
}
@keyframes hpe2-star-twinkle {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.3); }
}

.hpe2-offer-glow-left {
  position: absolute; top: -60px; left: -60px;
  width: 320px; height: 320px; border-radius: 50%;
  background: radial-gradient(circle, rgba(0,176,139,0.20) 0%, transparent 70%);
  pointer-events: none;
}
.hpe2-offer-glow-right {
  position: absolute; bottom: -80px; right: -60px;
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(0,212,168,0.14) 0%, transparent 70%);
  pointer-events: none;
}
.hpe2-offer-stars { position: absolute; inset: 0; pointer-events: none; }
.hpe2-star { position: absolute; color: rgba(0,212,168,0.7); animation: hpe2-star-twinkle 3s ease-in-out infinite; }
.hpe2-star-1 { top: 12%; left: 48%; font-size: 1.1rem; animation-delay: 0s; }
.hpe2-star-2 { top: 8%;  right: 8%; font-size: 1.4rem; animation-delay: 0.6s; }
.hpe2-star-3 { bottom: 18%; left: 42%; font-size: 0.8rem; animation-delay: 1.1s; }
.hpe2-star-4 { top: 55%; right: 4%; font-size: 1rem; animation-delay: 1.7s; }

.hpe2-offer-img-col {
  flex: 0 0 280px;
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
}
.hpe2-offer-img {
  width: 100%; max-width: 270px; object-fit: contain;
  filter: drop-shadow(0 12px 40px rgba(0,176,139,0.40));
  animation: hpe2-float 4s ease-in-out infinite;
}
.hpe2-offer-content {
  flex: 1; position: relative; z-index: 2;
  display: flex; flex-direction: column; gap: 20px;
}
.hpe2-offer-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(0, 176, 139, 0.15); border: 1px solid rgba(0, 176, 139, 0.38);
  color: #6ee7b7; font-size: 0.72rem; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 6px 18px; border-radius: 100px; width: fit-content;
}
.hpe2-offer-title {
  font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900;
  color: #ffffff; line-height: 1.15; margin: 0;
}
.hpe2-offer-free {
  background: linear-gradient(90deg, #00b08b, #00d4a8);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hpe2-offer-pill {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid rgba(0,176,139,0.40); border-radius: 100px;
  padding: 7px 20px; color: #a7f3d0;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 1.8px;
  text-transform: uppercase; width: fit-content;
}
.hpe2-offer-pill-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #00b08b; box-shadow: 0 0 6px rgba(0,176,139,0.8);
}
.hpe2-offer-desc {
  font-size: 0.96rem; color: #b8d8d0; line-height: 1.75; max-width: 600px; margin: 0;
}
.hpe2-offer-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
}
.hpe2-offer-feature {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(0,176,139,0.18);
  border-radius: 14px; padding: 18px 18px 14px;
  display: flex; flex-direction: column; gap: 10px;
  transition: border-color 0.3s, background 0.3s;
}
.hpe2-offer-feature:hover {
  border-color: rgba(0,176,139,0.45); background: rgba(0,176,139,0.07);
}
.hpe2-offer-feat-icon {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(0,176,139,0.18); border: 1px solid rgba(0,176,139,0.35);
  display: flex; align-items: center; justify-content: center;
  color: #6ee7b7; font-size: 0.95rem;
}
.hpe2-offer-feature span { font-size: 0.88rem; font-weight: 700; color: #d0f0e8; line-height: 1.3; }
.hpe2-offer-feat-bar { width: 32px; height: 2px; border-radius: 2px; background: linear-gradient(90deg, #00b08b, #00d4a8); }

.hpe2-offer-modules-row { display: flex; flex-direction: column; gap: 10px; }
.hpe2-offer-modules-label {
  font-size: 0.82rem; color: #5a8878;
  display: flex; align-items: center; gap: 10px;
}
.hpe2-offer-modules-label::before, .hpe2-offer-modules-label::after {
  content: ''; flex: 1; height: 1px; background: rgba(0,176,139,0.25);
}
.hpe2-offer-modules-list { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 6px; }
.hpe2-offer-module { font-size: 0.83rem; color: #b8d8d0; display: flex; align-items: center; gap: 5px; }
.hpe2-offer-module i { color: #00b08b; }
.hpe2-offer-sep { color: rgba(0,176,139,0.4); font-size: 0.9rem; }

.hpe2-contact-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #00b08b 0%, #006b55 100%);
  color: #fff; font-size: 0.88rem; font-weight: 800;
  letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;
  padding: 16px 36px; border-radius: 100px; width: fit-content;
  box-shadow: 0 8px 28px rgba(0,176,139,0.45);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.hpe2-contact-btn:hover {
  transform: translateY(-3px); box-shadow: 0 14px 40px rgba(0,176,139,0.65); color: #fff;
}

@media (max-width: 900px) {
  .hpe2-offer-card { flex-direction: column; padding: 40px 28px; gap: 32px; }
  .hpe2-offer-img-col { flex: none; width: 220px; }
  .hpe2-offer-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .hpe2-offer-title { font-size: 1.7rem; }
  .hpe2-offer-modules-list { flex-direction: column; align-items: flex-start; }
  .hpe2-offer-sep { display: none; }
}

/* ── Career CTA — HPE page with bggg.jpg background ── */
.hpe-page.hpe2-page .career-cta-section {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(rgba(0, 10, 6, 0.82), rgba(2, 14, 10, 0.88)),
    url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}
.hpe-page.hpe2-page .career-cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(0,176,139,0.18) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 50%, rgba(0,120,100,0.12) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}
.hpe-page.hpe2-page .career-cta-section .career-cta-container {
  position: relative;
  z-index: 1;
}
