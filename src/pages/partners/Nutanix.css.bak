@import './shared.css';

/* ================================================================
   NUTANIX PREMIUM — ROYAL BLUE EDITION
   Accent: #024DA1  Secondary: #3b82f6
   Structure mirrors Motadata v2. All class names prefixed ntx2-
   ================================================================ */

.nutanix-page.ntx-v2-page { overflow-x: hidden; }

/* HERO */
.nutanix-page .ntx2-hero,
section.ntx2-hero {
  background: linear-gradient(135deg, #020509 0%, #040d1c 50%, #020509 100%) !important;
  background-image: none !important;
  padding: 0 !important; overflow: hidden !important;
  position: relative; display: flex; align-items: center;
}

.ntx2-hero-glow-left {
  position: absolute; top: 0; left: 0; width: 50%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(2,77,161,.28) 0%, rgba(2,77,161,.1) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: ntx2-glow 7s ease-in-out infinite alternate;
}
.ntx2-hero-glow-right {
  position: absolute; bottom: 0; right: 0; width: 55%; height: 100%;
  background: radial-gradient(ellipse at center, rgba(59,130,246,.18) 0%, rgba(2,77,161,.08) 50%, transparent 80%);
  z-index: 0; pointer-events: none; animation: ntx2-glow 9s ease-in-out infinite alternate-reverse;
}
@keyframes ntx2-glow { 0%{opacity:.7}100%{opacity:1} }

.ntx2-hero-inner {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 52% 48%; gap: 24px; align-items: flex-start;
  padding: 90px 20px 20px; max-width: 1280px; margin: 0 auto; width: 100%;
}
.ntx2-headline { font-size: clamp(1.7rem,2.8vw,2.5rem); font-weight: 900; line-height: 1.12; color: #fff; letter-spacing: -.02em; margin-bottom: 6px; }
.ntx2-headline-accent { color: #3b82f6; display: block; }
.ntx2-headline-rule { width: 60px; height: 3px; background: linear-gradient(90deg,#024DA1,#3b82f6); border-radius: 2px; margin: 14px 0 20px; }
.ntx2-desc { font-size: .97rem; color: rgba(255,255,255,.75); line-height: 1.65; margin-bottom: 22px; max-width: 520px; }
.ntx2-desc-link { color: #60a5fa; text-decoration: underline; }

.ntx2-feature-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.ntx2-feat { display: flex; align-items: flex-start; gap: 12px; }
.ntx2-feat-icon { min-width: 36px; height: 36px; background: rgba(2,77,161,.22); border: 1px solid rgba(59,130,246,.35); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: .85rem; }
.ntx2-feat-body { display: flex; flex-direction: column; }
.ntx2-feat-body strong { color: #fff; font-size: .88rem; font-weight: 700; }
.ntx2-feat-body span { color: rgba(255,255,255,.6); font-size: .78rem; }

.ntx2-stats-row { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
.ntx2-stat-card { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(59,130,246,.2); border-radius: 10px; padding: 10px 16px; }
.ntx2-stat-card i { color: #60a5fa; font-size: 1.1rem; }
.ntx2-stat-num { display: block; font-size: 1.2rem; font-weight: 800; color: #fff; }
.ntx2-stat-lbl { display: block; font-size: .62rem; color: rgba(255,255,255,.5); letter-spacing: .06em; text-transform: uppercase; }
.ntx2-stat-brand { border-color: rgba(59,130,246,.35); }
.ntx2-brand-logo { width: 48px; height: 32px; object-fit: contain; border-radius: 4px; background: #fff; padding: 2px; }

.ntx2-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
.ntx2-btn-primary { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,#024DA1,#3b82f6); color: #fff; font-weight: 700; font-size: .88rem; padding: 12px 24px; border-radius: 8px; text-decoration: none; transition: opacity .2s; }
.ntx2-btn-primary:hover { opacity: .88; color: #fff; }
.ntx2-btn-ghost { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(59,130,246,.5); color: #60a5fa; font-weight: 600; font-size: .88rem; padding: 12px 22px; border-radius: 8px; text-decoration: none; transition: background .2s; }
.ntx2-btn-ghost:hover { background: rgba(59,130,246,.12); color: #60a5fa; }

.ntx2-right { position: relative; display: flex; flex-direction: column; gap: 16px; padding-top: 20px; }
.ntx2-product-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 420px; height: 420px; background: radial-gradient(circle,rgba(2,77,161,.3) 0%,transparent 70%); pointer-events: none; z-index: 0; }
.ntx2-showcase { position: relative; z-index: 2; display: flex; justify-content: center; align-items: flex-end; }
.ntx2-hero-product-img { max-width: 340px; width: 100%; object-fit: contain; filter: drop-shadow(0 12px 40px rgba(59,130,246,.45)); border-radius: 12px; }
.ntx2-industry-strip { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; background: rgba(255,255,255,.04); border: 1px solid rgba(59,130,246,.18); border-radius: 10px; padding: 12px 16px; z-index: 2; position: relative; }
.ntx2-ind-item { display: flex; align-items: center; gap: 5px; font-size: .74rem; color: rgba(255,255,255,.7); white-space: nowrap; }
.ntx2-ind-item i { color: #60a5fa; }
.ntx2-ind-sep { width: 1px; height: 14px; background: rgba(255,255,255,.15); }

/* WHY CHOOSE */
.ntx2-why-section { background: #040d1c; padding: 70px 0 60px; }
.ntx2-why-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.ntx2-why-header { text-align: center; margin-bottom: 40px; }
.ntx2-why-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(59,130,246,.12); border: 1px solid rgba(59,130,246,.3); color: #60a5fa; font-size: .7rem; font-weight: 700; letter-spacing: .1em; padding: 6px 18px; border-radius: 50px; margin-bottom: 16px; text-transform: uppercase; }
.ntx2-why-title { font-size: clamp(1.6rem,2.5vw,2.2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.ntx2-why-accent { color: #3b82f6; }
.ntx2-why-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 16px; }
.ntx2-why-title-rule { width: 48px; height: 3px; background: linear-gradient(90deg,#024DA1,#3b82f6); margin: 0 auto; border-radius: 2px; }

.ntx2-why-card-outer { display: grid; grid-template-columns: 1fr 1fr; background: rgba(255,255,255,.03); border: 1px solid rgba(59,130,246,.15); border-radius: 20px; overflow: hidden; margin-bottom: 32px; }
.ntx2-why-panel { padding: 36px 32px; position: relative; }
.ntx2-why-panel-left { border-right: 1px solid rgba(59,130,246,.15); }
.ntx2-why-icon-circle { width: 52px; height: 52px; background: rgba(59,130,246,.18); border: 1px solid rgba(59,130,246,.4); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: 1.2rem; margin-bottom: 12px; }
.ntx2-why-icon-alt { background: rgba(96,165,250,.12); border-color: rgba(96,165,250,.4); }
.ntx2-why-card-sup { font-size: .7rem; font-weight: 700; color: rgba(255,255,255,.4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 4px; }
.ntx2-why-card-title { font-size: 1.25rem; font-weight: 800; margin-bottom: 10px; color: #60a5fa; }
.ntx2-why-card-title-alt { color: #93c5fd; }
.ntx2-why-card-desc { color: rgba(255,255,255,.65); font-size: .88rem; line-height: 1.6; margin-bottom: 16px; }
.ntx2-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.ntx2-why-list li { display: flex; align-items: flex-start; gap: 10px; color: rgba(255,255,255,.75); font-size: .85rem; }
.ntx2-why-list-icon { min-width: 28px; height: 28px; background: rgba(59,130,246,.12); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: .8rem; }
.ntx2-why-list-check-icon { color: #93c5fd; }
.ntx2-why-list li small { display: block; font-size: .75rem; color: rgba(255,255,255,.4); }

.ntx2-why-stats-bar { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; background: rgba(59,130,246,.08); border: 1px solid rgba(59,130,246,.2); border-radius: 14px; padding: 20px 28px; }
.ntx2-why-stat { display: flex; align-items: center; gap: 12px; padding: 8px 28px; }
.ntx2-why-stat-sep { width: 1px; height: 40px; background: rgba(255,255,255,.12); }
.ntx2-why-stat-icon { width: 38px; height: 38px; background: rgba(59,130,246,.18); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: .95rem; }
.ntx2-why-stat-text strong { display: block; color: #fff; font-size: .88rem; font-weight: 700; }
.ntx2-why-stat-text span { color: rgba(255,255,255,.5); font-size: .75rem; }

/* PORTFOLIO */
.ntx2-port-section { background: #020509; padding: 70px 0; }
.ntx2-port-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.ntx2-port-header { text-align: center; margin-bottom: 40px; }
.ntx2-port-header-icon { width: 56px; height: 56px; background: rgba(59,130,246,.15); border: 1px solid rgba(59,130,246,.35); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: 1.3rem; margin: 0 auto 12px; }
.ntx2-port-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; margin-bottom: 8px; }
.ntx2-port-accent { color: #3b82f6; }
.ntx2-port-title-decor { display: flex; align-items: center; justify-content: center; gap: 8px; margin: 8px 0; }
.ntx2-port-decor-line { flex: 0 0 40px; height: 2px; background: linear-gradient(90deg,transparent,rgba(59,130,246,.5)); }
.ntx2-port-decor-dot { width: 8px; height: 8px; border-radius: 50%; background: #3b82f6; }
.ntx2-port-subtitle { color: rgba(255,255,255,.6); font-size: .95rem; }
.ntx2-port-top-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 20px; }
.ntx2-port-card { background: rgba(255,255,255,.03); border: 1px solid rgba(59,130,246,.15); border-radius: 16px; overflow: hidden; transition: border-color .3s,transform .3s; }
.ntx2-port-card:hover { border-color: rgba(59,130,246,.5); transform: translateY(-4px); }
.ntx2-port-card-img { height: 140px; position: relative; }
.ntx2-port-img-a { background: linear-gradient(135deg,#040d1c,#0a1e40); }
.ntx2-port-img-b { background: linear-gradient(135deg,#020812,#061630); }
.ntx2-port-img-c { background: linear-gradient(135deg,#030710,#050e28); }
.ntx2-port-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(2,5,9,.9)); }
.ntx2-port-card-body { padding: 18px 20px; }
.ntx2-port-card-icon { width: 40px; height: 40px; background: rgba(59,130,246,.18); border: 1px solid rgba(59,130,246,.35); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: .9rem; margin-bottom: 10px; }
.ntx2-port-card-title { font-size: 1rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.ntx2-port-card-desc { color: rgba(255,255,255,.6); font-size: .82rem; line-height: 1.55; margin-bottom: 10px; }
.ntx2-port-list { list-style: none; padding: 0; margin: 0 0 12px; display: flex; flex-direction: column; gap: 5px; }
.ntx2-port-list li { color: rgba(255,255,255,.7); font-size: .8rem; display: flex; align-items: center; gap: 7px; }
.ntx2-port-list li i { color: #3b82f6; font-size: .75rem; }
.ntx2-port-link { color: #60a5fa; font-size: .82rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
.ntx2-port-link:hover { gap: 10px; }
.ntx2-port-bottom-row { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; }
.ntx2-port-dc-card { background: rgba(255,255,255,.03); border: 1px solid rgba(59,130,246,.15); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.ntx2-port-dc-img { height: 120px; background: linear-gradient(135deg,#030810,#060e20); position: relative; }
.ntx2-port-dc-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom,transparent 50%,rgba(2,5,9,.9)); }
.ntx2-port-dc-body { padding: 18px 20px; flex: 1; }
.ntx2-port-why-panel { background: rgba(59,130,246,.07); border: 1px solid rgba(59,130,246,.2); border-radius: 16px; padding: 24px 22px; }
.ntx2-port-why-title { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 18px; }
.ntx2-port-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }
.ntx2-port-why-item { display: flex; flex-direction: column; gap: 4px; }
.ntx2-port-why-icon { width: 32px; height: 32px; background: rgba(59,130,246,.18); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: .85rem; margin-bottom: 6px; }
.ntx2-port-why-item strong { color: #fff; font-size: .85rem; font-weight: 700; }
.ntx2-port-why-item span { color: rgba(255,255,255,.5); font-size: .77rem; line-height: 1.4; }
.ntx2-port-cta-bar { display: flex; align-items: center; gap: 14px; background: rgba(59,130,246,.1); border: 1px solid rgba(59,130,246,.25); border-radius: 10px; padding: 14px 16px; }
.ntx2-port-cta-icon { width: 36px; height: 36px; background: rgba(59,130,246,.25); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #60a5fa; font-size: .95rem; flex-shrink: 0; }
.ntx2-port-cta-text { flex: 1; }
.ntx2-port-cta-text strong { display: block; color: #fff; font-size: .82rem; font-weight: 700; }
.ntx2-port-cta-text span { color: rgba(255,255,255,.5); font-size: .76rem; }
.ntx2-port-cta-btn { display: inline-flex; align-items: center; gap: 5px; background: linear-gradient(135deg,#024DA1,#3b82f6); color: #fff; font-size: .78rem; font-weight: 700; padding: 9px 16px; border-radius: 7px; text-decoration: none; white-space: nowrap; }

/* CERTIFICATIONS */
.ntx2-cert-section { background: #040d1c; padding: 50px 0; }
.ntx2-cert-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.ntx2-cert-header { text-align: center; margin-bottom: 32px; }
.ntx2-cert-title { font-size: clamp(1.3rem,2vw,1.8rem); font-weight: 900; color: #fff; margin-bottom: 8px; }
.ntx2-cert-subtitle { color: rgba(255,255,255,.6); font-size: .9rem; }
.ntx2-cert-slider-wrapper { overflow: hidden; }
.ntx2-cert-images { display: flex; gap: 20px; animation: ntx2-cert-scroll 20s linear infinite; width: max-content; }
@keyframes ntx2-cert-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.ntx2-cert-img-card { width: 200px; background: rgba(255,255,255,.05); border: 1px solid rgba(59,130,246,.2); border-radius: 12px; padding: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ntx2-cert-img-card img { max-width: 100%; max-height: 120px; object-fit: contain; }

/* INDUSTRIES */
.ntx2-ind-section { background: #040d1c; padding: 70px 0; position: relative; overflow: hidden; }
.ntx2-ind-bg-glow { position: absolute; width: 400px; height: 400px; border-radius: 50%; pointer-events: none; z-index: 0; }
.ntx2-ind-bg-glow-left { top: -100px; left: -100px; background: radial-gradient(circle,rgba(2,77,161,.12) 0%,transparent 70%); }
.ntx2-ind-bg-glow-right { bottom: -100px; right: -100px; background: radial-gradient(circle,rgba(59,130,246,.08) 0%,transparent 70%); }
.ntx2-ind-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.ntx2-ind-header { text-align: center; margin-bottom: 40px; }
.ntx2-ind-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(59,130,246,.1); border: 1px solid rgba(59,130,246,.25); color: #60a5fa; font-size: .68rem; font-weight: 700; letter-spacing: .1em; padding: 6px 16px; border-radius: 50px; margin-bottom: 14px; text-transform: uppercase; }
.ntx2-ind-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: #3b82f6; }
.ntx2-ind-title { font-size: clamp(1.5rem,2.3vw,2rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 8px; }
.ntx2-ind-accent { color: #3b82f6; }
.ntx2-ind-subtitle { color: rgba(255,255,255,.6); font-size: .92rem; }
.ntx2-ind-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
.ntx2-ind-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 22px; position: relative; overflow: hidden; transition: border-color .3s,transform .3s; }
.ntx2-ind-card:hover { transform: translateY(-4px); }
.ntx2-ind-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.ntx2-ind-icon-wrap { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: .95rem; }

.ntx2-ind-card-blue   { border-color: rgba(59,130,246,.25); }  .ntx2-ind-card-blue:hover   { border-color: rgba(59,130,246,.6); }
.ntx2-ind-icon-blue   { background: rgba(59,130,246,.18); color: #60a5fa; }
.ntx2-ind-rule-blue   { height: 2px; background: linear-gradient(90deg,#3b82f6,transparent); margin-bottom: 10px; border-radius: 1px; }
.ntx2-ind-arrow-blue  { color: #60a5fa; }

.ntx2-ind-card-indigo { border-color: rgba(99,102,241,.25); }  .ntx2-ind-card-indigo:hover { border-color: rgba(99,102,241,.6); }
.ntx2-ind-icon-indigo { background: rgba(99,102,241,.18); color: #a5b4fc; }
.ntx2-ind-rule-indigo { height: 2px; background: linear-gradient(90deg,#6366f1,transparent); margin-bottom: 10px; border-radius: 1px; }
.ntx2-ind-arrow-indigo{ color: #a5b4fc; }

.ntx2-ind-card-violet { border-color: rgba(139,92,246,.25); }  .ntx2-ind-card-violet:hover { border-color: rgba(139,92,246,.6); }
.ntx2-ind-icon-violet { background: rgba(139,92,246,.18); color: #c4b5fd; }
.ntx2-ind-rule-violet { height: 2px; background: linear-gradient(90deg,#8b5cf6,transparent); margin-bottom: 10px; border-radius: 1px; }
.ntx2-ind-arrow-violet{ color: #c4b5fd; }

.ntx2-ind-card-cyan   { border-color: rgba(6,182,212,.25); }   .ntx2-ind-card-cyan:hover   { border-color: rgba(6,182,212,.6); }
.ntx2-ind-icon-cyan   { background: rgba(6,182,212,.18); color: #67e8f9; }
.ntx2-ind-rule-cyan   { height: 2px; background: linear-gradient(90deg,#06b6d4,transparent); margin-bottom: 10px; border-radius: 1px; }
.ntx2-ind-arrow-cyan  { color: #67e8f9; }

.ntx2-ind-card-sky    { border-color: rgba(14,165,233,.25); }   .ntx2-ind-card-sky:hover    { border-color: rgba(14,165,233,.6); }
.ntx2-ind-icon-sky    { background: rgba(14,165,233,.18); color: #7dd3fc; }
.ntx2-ind-rule-sky    { height: 2px; background: linear-gradient(90deg,#0ea5e9,transparent); margin-bottom: 10px; border-radius: 1px; }
.ntx2-ind-arrow-sky   { color: #7dd3fc; }

.ntx2-ind-card-teal   { border-color: rgba(20,184,166,.25); }   .ntx2-ind-card-teal:hover   { border-color: rgba(20,184,166,.6); }
.ntx2-ind-icon-teal   { background: rgba(20,184,166,.18); color: #2dd4bf; }
.ntx2-ind-rule-teal   { height: 2px; background: linear-gradient(90deg,#14b8a6,transparent); margin-bottom: 10px; border-radius: 1px; }
.ntx2-ind-arrow-teal  { color: #2dd4bf; }

.ntx2-ind-num { font-size: 1.3rem; font-weight: 900; color: rgba(255,255,255,.08); }
.ntx2-ind-card-title { font-size: .95rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.ntx2-ind-card-desc { color: rgba(255,255,255,.6); font-size: .8rem; line-height: 1.5; margin-bottom: 12px; }
.ntx2-ind-arrow { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); text-decoration: none; transition: background .2s; }
.ntx2-ind-arrow:hover { background: rgba(255,255,255,.12); }
.ntx2-ind-card-bg-pattern { position: absolute; right: -20px; bottom: -20px; width: 80px; height: 80px; border-radius: 50%; background: rgba(59,130,246,.04); pointer-events: none; }

/* ── SPECIAL OFFER — Greythr-style two-column card ── */
.ntx2-special-offer { padding: 80px 0 100px; position: relative; }

.ntx2-offer-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 48px;
  background: linear-gradient(135deg, #020509 0%, #030d20 50%, #020815 100%);
  border: 1px solid rgba(2, 77, 161, 0.28);
  border-radius: 24px;
  padding: 56px 52px;
  overflow: hidden;
  box-shadow: 0 0 80px rgba(2, 77, 161, 0.18), inset 0 1px 0 rgba(255,255,255,0.04);
}
.ntx2-offer-card::before {
  content: ''; display: block; height: 2px; width: 100%;
  background: linear-gradient(90deg, transparent, rgba(59,130,246,.80), #024DA1, rgba(59,130,246,.80), transparent);
  background-size: 200% 100%;
  animation: ntx2-shimmer 3s linear infinite;
  position: absolute; top: 0; left: 0; right: 0; border-radius: 24px 24px 0 0;
}
@keyframes ntx2-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes ntx2-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-10px); }
}
@keyframes ntx2-star-twinkle {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.3); }
}

.ntx2-offer-glow-left {
  position: absolute; top: -60px; left: -60px;
  width: 320px; height: 320px; border-radius: 50%;
  background: radial-gradient(circle, rgba(2,77,161,0.22) 0%, transparent 70%);
  pointer-events: none;
}
.ntx2-offer-glow-right {
  position: absolute; bottom: -80px; right: -60px;
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,0.16) 0%, transparent 70%);
  pointer-events: none;
}
.ntx2-offer-stars { position: absolute; inset: 0; pointer-events: none; }
.ntx2-star { position: absolute; color: rgba(96,165,250,0.7); animation: ntx2-star-twinkle 3s ease-in-out infinite; }
.ntx2-star-1 { top: 12%; left: 48%; font-size: 1.1rem; animation-delay: 0s; }
.ntx2-star-2 { top: 8%;  right: 8%; font-size: 1.4rem; animation-delay: 0.6s; }
.ntx2-star-3 { bottom: 18%; left: 42%; font-size: 0.8rem; animation-delay: 1.1s; }
.ntx2-star-4 { top: 55%; right: 4%; font-size: 1rem; animation-delay: 1.7s; }

.ntx2-offer-img-col {
  flex: 0 0 280px;
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
}
.ntx2-offer-img {
  width: 100%; max-width: 270px; object-fit: contain;
  filter: drop-shadow(0 12px 40px rgba(2,77,161,0.45));
  animation: ntx2-float 4s ease-in-out infinite;
}
.ntx2-offer-content {
  flex: 1; position: relative; z-index: 2;
  display: flex; flex-direction: column; gap: 20px;
}
.ntx2-offer-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(2, 77, 161, 0.15); border: 1px solid rgba(2, 77, 161, 0.38);
  color: #60a5fa; font-size: 0.72rem; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 6px 18px; border-radius: 100px; width: fit-content;
}
.ntx2-offer-title {
  font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 900;
  color: #ffffff; line-height: 1.15; margin: 0;
}
.ntx2-offer-free {
  background: linear-gradient(90deg, #024DA1, #60a5fa);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.ntx2-offer-pill {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid rgba(2,77,161,0.40); border-radius: 100px;
  padding: 7px 20px; color: #93c5fd;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 1.8px;
  text-transform: uppercase; width: fit-content;
}
.ntx2-offer-pill-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #024DA1; box-shadow: 0 0 6px rgba(2,77,161,0.8);
}
.ntx2-offer-desc {
  font-size: 0.96rem; color: #b8cde8; line-height: 1.75; max-width: 600px; margin: 0;
}
.ntx2-offer-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
}
.ntx2-offer-feature {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(2,77,161,0.18);
  border-radius: 14px; padding: 18px 18px 14px;
  display: flex; flex-direction: column; gap: 10px;
  transition: border-color 0.3s, background 0.3s;
}
.ntx2-offer-feature:hover {
  border-color: rgba(2,77,161,0.45); background: rgba(2,77,161,0.07);
}
.ntx2-offer-feat-icon {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(2,77,161,0.18); border: 1px solid rgba(2,77,161,0.35);
  display: flex; align-items: center; justify-content: center;
  color: #60a5fa; font-size: 0.95rem;
}
.ntx2-offer-feature span { font-size: 0.88rem; font-weight: 700; color: #d4e8ff; line-height: 1.3; }
.ntx2-offer-feat-bar { width: 32px; height: 2px; border-radius: 2px; background: linear-gradient(90deg, #024DA1, #60a5fa); }

.ntx2-offer-modules-row { display: flex; flex-direction: column; gap: 10px; }
.ntx2-offer-modules-label {
  font-size: 0.82rem; color: #7090b0;
  display: flex; align-items: center; gap: 10px;
}
.ntx2-offer-modules-label::before, .ntx2-offer-modules-label::after {
  content: ''; flex: 1; height: 1px; background: rgba(2,77,161,0.25);
}
.ntx2-offer-modules-list { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 6px; }
.ntx2-offer-module { font-size: 0.83rem; color: #b8cde8; display: flex; align-items: center; gap: 5px; }
.ntx2-offer-module i { color: #024DA1; }
.ntx2-offer-sep { color: rgba(2,77,161,0.4); font-size: 0.9rem; }

.ntx2-contact-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg, #024DA1 0%, #1d6bc8 100%);
  color: #fff; font-size: 0.88rem; font-weight: 800;
  letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none;
  padding: 16px 36px; border-radius: 100px; width: fit-content;
  box-shadow: 0 8px 28px rgba(2,77,161,0.45);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.ntx2-contact-btn:hover {
  transform: translateY(-3px); box-shadow: 0 14px 40px rgba(2,77,161,0.65); color: #fff;
}

@media (max-width: 900px) {
  .ntx2-offer-card { flex-direction: column; padding: 40px 28px; gap: 32px; }
  .ntx2-offer-img-col { flex: none; width: 220px; }
  .ntx2-offer-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .ntx2-offer-title { font-size: 1.7rem; }
  .ntx2-offer-modules-list { flex-direction: column; align-items: flex-start; }
  .ntx2-offer-sep { display: none; }
}

/* Career CTA */
.nutanix-page.ntx-v2-page .career-cta-section {
  position: relative; overflow: hidden;
  background: linear-gradient(rgba(1,2,5,0.85), rgba(2,5,9,0.9)), url('/assets/images/bggg.jpg') center center / cover no-repeat !important;
  background-attachment: fixed !important;
}
.nutanix-page.ntx-v2-page .career-cta-section::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 20% 50%, rgba(59,130,246,0.14) 0%, transparent 60%), radial-gradient(ellipse at 80% 50%, rgba(59,130,246,0.09) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}
.nutanix-page.ntx-v2-page .career-cta-section .career-cta-container { position: relative; z-index: 1; }
.nutanix-page.ntx-v2-page .career-cta-section .career-cta-title {
  background: linear-gradient(135deg, #ffffff 0%, #60a5fa 60%, #ffffff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .ntx2-hero-inner { grid-template-columns: 1fr; padding: 80px 20px 30px; }
  .ntx2-right { display: none; }
  .ntx2-why-card-outer { grid-template-columns: 1fr; }
  .ntx2-why-panel-left { border-right: none; border-bottom: 1px solid rgba(59,130,246,.15); }
  .ntx2-port-top-row { grid-template-columns: 1fr 1fr; }
  .ntx2-port-bottom-row { grid-template-columns: 1fr; }
  .ntx2-ind-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .ntx2-port-top-row { grid-template-columns: 1fr; }
  .ntx2-ind-grid { grid-template-columns: 1fr; }
  .ntx2-why-stats-bar { flex-direction: column; gap: 8px; }
  .ntx2-why-stat-sep { display: none; }
  .ntx2-offer-banner { padding: 32px 20px; }
}
