import { useEffect, useState } from 'react';
import { Link, useLocation } from 'react-router-dom';
import SEO from '../components/SEO';
import { getSEOData } from '../config/seoConfig';
import './Partners.css';

export default function Partners() {
  const location = useLocation();

  // Derive partner directly from URL — no useState needed, no render delay
  const partnerParam = new URLSearchParams(location.search).get('partner');

  // All known partner keys that have dedicated pages
  const KNOWN_PARTNERS = [
    'sophos', 'hpe', 'hpearubanetworking', 'nutanix', 'veeam', 'tenable',
    'sify', 'accops', 'cymmetri', 'motadata', 'paloalto', 'peoplelink',
    'qualys', 'safetica', 'manageengine', 'dell', 'seceon', '42gears', 'arcon', 'apple', 'gfisoftware', 'hp', 'lenovo', 'logrythm', 'microsoft365', 'poly', 'vmware', 'solarwinds', 'azure', 'forcepoint'
  ];

  // Derived booleans — computed on every render from the current URL, no flash
  const showSophosAward    = partnerParam === 'sophos';
  const showHPEServer      = partnerParam === 'hpe';
  const showAruba          = partnerParam === 'hpearubanetworking';
  const showNutanix        = partnerParam === 'nutanix';
  const showVeeam          = partnerParam === 'veeam';
  const showTenable        = partnerParam === 'tenable';
  const showSify           = partnerParam === 'sify';
  const showAccops         = partnerParam === 'accops';
  const showCymmetri       = partnerParam === 'cymmetri';
  const showMotadata       = partnerParam === 'motadata';
  const showPaloalto       = partnerParam === 'paloalto';
  const showPeoplelink     = partnerParam === 'peoplelink';
  const showQualys         = partnerParam === 'qualys';
  const showSafetica       = partnerParam === 'safetica';
  const showManageEngine   = partnerParam === 'manageengine';
  const showDell           = partnerParam === 'dell';
  const showSeceon         = partnerParam === 'seceon';
  const show42Gears        = partnerParam === '42gears';
  const showAcronis        = partnerParam === 'arcon';
  const showApple          = partnerParam === 'apple';
  const showGFISoftware    = partnerParam === 'gfisoftware';
  const showHP             = partnerParam === 'hp';
  const showLenovo         = partnerParam === 'lenovo';
  const showLogRhythm      = partnerParam === 'logrythm';
  const showMicrosoft365   = partnerParam === 'microsoft365';
  const showPoly           = partnerParam === 'poly';
  const showVMware         = partnerParam === 'vmware';
  const showSolarWinds     = partnerParam === 'solarwinds';
  const showAzure          = partnerParam === 'azure';
  const showForcepoint     = partnerParam === 'forcepoint';
  const unknownPartner     = partnerParam && !KNOWN_PARTNERS.includes(partnerParam) ? partnerParam : null;

  // Dynamic SEO based on partner parameter
  const getSEOForPartner = () => {
    if (partnerParam) {
      const partnerSEOKey = `partner${partnerParam.charAt(0).toUpperCase() + partnerParam.slice(1)}`;
      return getSEOData(partnerSEOKey) || getSEOData('partners');
    }
    return getSEOData('partners');
  };

  const seoData = getSEOForPartner();

  // Partner display names for the fallback page
  const PARTNER_DISPLAY_NAMES = {
    seceon: 'Seceon', k7security: 'K7 Security', hp: 'HP', lenovo: 'Lenovo',
    dell: 'Dell', apple: 'Apple', logrythm: 'LogRhythm', microsoft365: 'Microsoft 365',
    azure: 'Microsoft Azure', '42gears': '42Gears', arcon: 'ARCON',
    gfisoftware: 'GFI Software', poly: 'Poly', forcepoint: 'Forcepoint',
    vmware: 'VMware', solarwinds: 'SolarWinds', zoho: 'Zoho', everest: 'Everest', jiocloud: 'Jio Cloud'
  };

  const [scrollProgress, setScrollProgress] = useState(0);

  useEffect(() => {
    window.scrollTo(0, 0);

    // Scroll progress indicator
    const handleScroll = () => {
      const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (window.scrollY / totalHeight) * 100;
      setScrollProgress(progress);
    };

    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, [location]);

  return (
    <div className="sophos-page">
      {/* Scroll Progress Indicator */}
      <div className="scroll-progress-container">
