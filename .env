# React App Environment Variables

# API Configuration
# For local development, create a .env.local file with: VITE_API_URL=/api
# This file is for production — points to the deployed backend
VITE_API_URL=https://trace-backed-1.onrender.com/api
VITE_API_TIMEOUT=10000

# Application Settings
VITE_APP_NAME=Trace Network & Engineering
VITE_APP_URL=https://tracenetwork.in

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHATBOT=true

# Google Analytics
VITE_GA_TRACKING_ID=G-5QYGDDYL0Q
